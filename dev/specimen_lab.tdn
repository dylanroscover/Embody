    dock: glsl_bloomblur
- name: vertical_fibers
  type: baseCOMP
  custom_pars:
    Controls:
    - name: Strands
      style: Int
      default: 56
      min: 4.0
      max: 320.0
      clampMin: true
      clampMax: true
      normMin: 4.0
      normMax: 320.0
      help: number of fiber strands in the curtain. Because of the column-fold this costs NOTHING per pixel (no strand loop), so a dense premium bundle is free; raise it freely for a fuller curtain.
    - name: Converge
      style: Float
      clampMin: true
      clampMax: true
      help: how strongly the bundle narrows toward the top. 0 = parallel strands (a flat curtain); higher = strong upward perspective into the haze.
    - name: Bow
      style: Float
      default: 1
      max: 2.0
      clampMin: true
      clampMax: true
      normMax: 2.0
      help: amount of gentle per-strand bow so the strands read as relaxed cable, not laser-straight. 0 = dead-straight fibers.
    - name: Glassglow
      style: Float
      default: 1.15
      max: 6.0
      clampMin: true
      clampMax: true
      normMax: 6.0
      help: strength of the internal-reflection shimmer gradient along each glass tube. The light-bouncing-in-glass look.
    - name: Pulsespeed
      style: Float
      default: 0.6
      max: 2.0
      clampMin: true
      clampMax: true
      normMax: 2.0
      help: how fast the light pulses race UP the strands. 0 freezes them (and drops that time-dependence); higher = near-light-speed streaks.
    - name: Pulsedensity
      style: Int
      default: 4
      min: 1.0
      max: 4.0
      clampMin: true
      clampMax: true
      normMin: 1.0
      normMax: 4.0
      help: how many light pulses travel up each strand at once (1-4, the constant loop bound). More = a busier data stream.
    - name: Pulselength
      style: Float
      default: 0.32
      min: 0.02
      max: 0.5
      clampMin: true
      clampMax: true
      normMin: 0.02
      normMax: 0.5
      help: length of each Gaussian light dash (in vertical UV). Short = crisp countable packets; long = streaking light trails.
    - name: Haze
      style: Float
      default: 2.6
      max: 4.0
      clampMin: true
      clampMax: true
      normMax: 4.0
      help: volumetric haze building toward the top of the frame so distant strands dim into fog. Adds vertical depth.
    - name: Linewidth
      style: Float
      default: 0.0045
      min: 0.0012
      max: 0.02
      clampMin: true
      clampMax: true
      normMin: 0.0012
      normMax: 0.02
      help: base thickness of the glass tube core. Thin = crisp hairline fibers; thicker = heavier glowing tubes. Crisp at any resolution via fwidth().
    - name: Ptprate
      style: Float
      default: 0.5
      min: 0.1
      max: 2.0
      clampMin: true
      clampMax: true
      normMin: 0.1
      normMax: 2.0
      help: frequency of the PTP sync pulse all light pulses breathe brighter to in lockstep.
    - name: Bloom
      style: Float
      default: 0.55
      max: 3.0
      clampMin: true
      clampMax: true
      normMax: 3.0
      help: intensity of the downsampled bloom glow added back over the pulses. The booth-scale wow knob.
    - name: Bloomwidth
      style: Float
      default: 2.6
      min: 1.0
      max: 4.0
      clampMin: true
      clampMax: true
      normMin: 1.0
      normMax: 4.0
      help: the blur step in the 1/4-res bloom pass. Wider = a softer, more atmospheric glow halo (still cheap, since it runs at low res).
    - name: Grain
      style: Float
      default: 1
      max: 2.0
      clampMin: true
      clampMax: true
      normMax: 2.0
      help: film-grain amount in the finish pass. Kills banding on the dark gradient at large scale.
    - name: Vignette
      style: Float
      default: 0.95
      max: 1.5
      clampMin: true
      clampMax: true
      normMax: 1.5
      help: edge darkening so the curtain sits on a premium dark stage.
    Output:
      $t: output
  position: [400, 0]
  color: [0.67, 0.67, 0.67]
  children:
  - name: out1
    type: outTOP
    flags:
    - viewer
    position: [1500, 0]
    inputs:
    - glsl_finish
  - name: res_down
    type: resolutionTOP
    parameters:
      resolutionw: =int(parent().par.Resw.eval()/4)
      resolutionh: =int(parent().par.Resh.eval()/4)
    position: [300, -400]
    inputs:
    - glsl_fibers
  - name: comp_bloom
    type: compositeTOP
    parameters:
      operand: add
      outputresolution: custom
      resolutionw: =parent().par.Resw.eval()
      resolutionh: =parent().par.Resh.eval()
      format: rgba16float
    position: [900, 0]
    inputs:
    - glsl_fibers
    - glsl_bloomblur
  - name: glsl_fibers
    type: glslTOP
    parameters:
      pixeldat: glsl_fibers_pixel
      computedat: glsl_fibers_compute
      outputresolution: custom
      resolutionw: =parent().par.Resw.eval()
      resolutionh: =parent().par.Resh.eval()
      format: rgba16float
    sequences:
      vec:
      - name: uFiber
        valuex: =parent().par.Strands.eval()
        valuey: =parent().par.Converge.eval()
        valuez: =parent().par.Bow.eval()
        valuew: =parent().par.Glassglow.eval()
      - name: uPulse
        valuex: =parent().par.Pulsespeed.eval()
        valuey: =parent().par.Pulsedensity.eval()
        valuez: =parent().par.Pulselength.eval()
        valuew: =absTime.seconds*parent().par.Pulsespeed.eval()
      - name: uLook
        valuex: =parent().par.Haze.eval()
        valuey: =parent().par.Linewidth.eval()
        valuez: =parent().par.Ptprate.eval()
        valuew: =absTime.seconds
  - name: glsl_finish
    type: glslTOP
    parameters:
      pixeldat: glsl_finish_pixel
      computedat: glsl_finish_compute
      format: rgba16float
    sequences:
      vec:
      - name: uFin
        valuex: =parent().par.Grain.eval()
        valuey: =parent().par.Vignette.eval()
        valuez: =parent().par.Strands.eval()
        valuew: =absTime.seconds
    position: [1200, 0]
    inputs:
    - comp_bloom
  - name: glsl_bloomblur
    type: glslTOP
    parameters:
      pixeldat: glsl_bloomblur_pixel
      computedat: glsl_bloomblur_compute
      outputresolution: custom
      resolutionw: =int(parent().par.Resw.eval()/4)
      resolutionh: =int(parent().par.Resh.eval()/4)
      format: rgba16float
    sequences:
      vec:
      - name: uBloom
        valuex: =parent().par.Bloom.eval()
        valuey: 0.55
        valuez: =parent().par.Bloomwidth.eval()
    position: [600, -400]
    inputs:
    - res_down
  - name: glsl_fibers_info
    type: infoDAT
    parameters:
      op: glsl_streams
    position: [0, -120]
    dock: glsl_fibers
  - name: glsl_finish_info
    type: infoDAT
    parameters:
      op: glsl_finish
    position: [1200, -120]
    dock: glsl_finish
  - name: glsl_fibers_pixel
    type: textDAT
    parameters:
      language: glsl
      extension: frag
    flags:
    - viewer
    position: [150, -120]
    dock: glsl_fibers
  - name: glsl_finish_pixel
    type: textDAT
    parameters:
      language: glsl
      extension: frag
    flags:
    - viewer
    position: [1350, -120]
    dock: glsl_finish
  - name: glsl_bloomblur_info
    type: infoDAT
    parameters:
      op: glsl_bloomblur
    position: [600, -520]
    dock: glsl_bloomblur
  - name: glsl_fibers_compute
    type: textDAT
    parameters:
      language: glsl
    flags:
    - viewer
    position: [-150, -120]
    dock: glsl_fibers
  - name: glsl_finish_compute
    type: textDAT
    parameters:
      language: glsl
    flags:
    - viewer
    position: [1050, -120]
    dock: glsl_finish
  - name: glsl_bloomblur_pixel
    type: textDAT
    parameters:
      language: glsl
      extension: frag
    flags:
    - viewer
    position: [750, -520]
    dock: glsl_bloomblur
  - name: glsl_bloomblur_compute
    type: textDAT
    parameters:
      language: glsl
    flags:
    - viewer
    position: [450, -520]
    dock: glsl_bloomblur
- name: mandelbulb_march
  type: baseCOMP
  custom_pars:
    Mandelbulb:
    - name: Power
      style: Float
      startSection: true
      default: 8
      min: 2.0
      max: 12.0
      clampMin: true
      clampMax: true
      normMin: 2.0
      normMax: 12.0
      help: Mandelbulb exponent in z=z^Power+c. 8 is the classic bulb; 2-4 = blobby organic forms; 10-12 = more lobes and finer detail.
    - name: Detail
      style: Float
      label: Surface Detail
      default: 0.6
      clampMin: true
      clampMax: true
      help: Raymarch hit threshold, remapped to a 0.0015->0.0004 epsilon. Higher resolves finer fractal crenellation at more cost near grazing rays.
    - name: Glow
      style: Float
      default: 1
      max: 3.0
      clampMin: true
      clampMax: true
      normMax: 3.0
      help: Proximity/iteration glow added along every ray. Close-but-miss rays accumulate an exponential halo. 0 = matte; 3 = ethereal bloom.
    - name: Orbitspeed
      style: Float
      label: Orbit Speed
      startSection: true
      default: 1
      max: 3.0
      clampMin: true
      clampMax: true
      normMax: 3.0
      help: Multiplies absTime.seconds into the camera orbit. 0 freezes a still; 1 is a slow cinematic orbit. Only the camera moves -- the fractal math is identical each frame.
    - name: Hue
      style: Float
      default: 0.55
      clampMin: true
      clampMax: true
      help: Base hue offset of the orbit-trap cosine palette. Rotates the whole color identity (surface, glow, rim, background sun) through the spectrum.
    - name: Sunazim
      style: Float
      label: Sun Azimuth
      startSection: true
      default: 35
      min: -180.0
      max: 180.0
      clampMin: true
      clampMax: true
      normMin: -180.0
      normMax: 180.0
      help: Azimuth (degrees) of the key light, converted with elevation into a unit direction so normalize() never sees a zero vector. Rotates where the soft key light and shadow fall.
    - name: Sunelev
      style: Float
      label: Sun Elevation
      default: 45
      min: -10.0
      max: 90.0
      clampMin: true
      clampMax: true
      normMin: -10.0
      normMax: 90.0
      help: Elevation (degrees) of the key light. High = top-down soft light with short shadows; low = dramatic raking light with long soft shadows.
    Output:
      $t: output_2
  position: [800, -800]
  color: [0.67, 0.67, 0.67]
  children:
  - name: out1
    type: outTOP
    flags:
    - display
    position: [800, 0]
    inputs:
    - glsl_mandelbulb
  - name: annotate1
    type: annotateCOMP
    sequences:
      ext:
      - object: op.TDAnnotate.mod.AnnotateExt.AnnotateExt(me)
        promote: true
    custom_pars:
      Text:
        $t: text
        Titletext: Mandelbulb Raymarcher
        Bodytext: 'One GLSL TOP raymarches the Mandelbulb SDF. The distance estimator iterates z = z^Power + c in spherical form, tracking the running derivative (dr) for a true distance bound and the closest approach to the axes (an orbit trap) for color. An orbiting camera marches rays toward the surface; soft shadows, a fresnel rim, and a proximity glow finish it. Every loop is bounded by a constant (DE_ITER / MARCH_STEPS / SHADOW_STEPS) so the GPU stays safe. No input, no feedback. Params: Power, Surface Detail, Glow, Orbit Speed, Hue, Sun Azimuth, Sun Elevation.'
      Settings:
        $t: settings
        Mode: annotate
        Backcolorr: [0.16, 0.13, 0.22]
        Opacity: 0.3
      OP Viewer:
        $t: op_viewer
        Opvieweroversize: natural
      About:
        $t: about
    position: [180, -190]
    size: [820, 450]
    palette_clone: true
  - name: glsl_mandelbulb
    type: glslTOP
    parameters:
      pixeldat: glsl_mandelbulb_pixel
      computedat: glsl_mandelbulb_compute
      outputresolution: custom
      resolutionw: =parent().par.Resw.eval()
      resolutionh: =parent().par.Resh.eval()
      format: rgba16float
    sequences:
      vec:
      - name: uParams
        valuex: =parent().par.Power.eval()
        valuey: =parent().par.Detail.eval()
        valuez: =parent().par.Glow.eval()
        valuew: =absTime.seconds*parent().par.Orbitspeed.eval()
      - name: uLight
        valuex: =math.cos(math.radians(parent().par.Sunelev.eval()))*math.sin(math.radians(parent().par.Sunazim.eval()))
        valuey: =math.sin(math.radians(parent().par.Sunelev.eval()))
        valuez: =math.cos(math.radians(parent().par.Sunelev.eval()))*math.cos(math.radians(parent().par.Sunazim.eval()))
        valuew: =parent().par.Hue.eval()
    position: [400, 0]
  - name: glsl_mandelbulb_info
    type: infoDAT
    parameters:
      op: glsl_mandelbulb
    position: [400, -120]
    dock: glsl_mandelbulb
  - name: glsl_mandelbulb_pixel
    type: textDAT
    parameters:
      extension: frag
    position: [550, -120]
    dock: glsl_mandelbulb
  - name: glsl_mandelbulb_compute
    type: textDAT
    parameters:
      language: glsl
    flags:
    - viewer
    position: [250, -120]
    dock: glsl_mandelbulb
  annotations:
  - name: annotate1
    mode: annotate
    title: Mandelbulb Raymarcher
    text: 'One GLSL TOP raymarches the Mandelbulb SDF. The distance estimator iterates z = z^Power + c in spherical form, tracking the running derivative (dr) for a true distance bound and the closest approach to the axes (an orbit trap) for color. An orbiting camera marches rays toward the surface; soft shadows, a fresnel rim, and a proximity glow finish it. Every loop is bounded by a constant (DE_ITER / MARCH_STEPS / SHADOW_STEPS) so the GPU stays safe. No input, no feedback. Params: Power, Surface Detail, Glow, Orbit Speed, Hue, Sun Azimuth, Sun Elevation.'
    position: [180, -190]
    size: [820, 450]
    color: [0.16, 0.13, 0.22]
    opacity: 0.3
- name: crosspoint_matrix
  type: baseCOMP
  custom_pars:
    Matrix:
    - name: Gridsize
      style: Int
      label: Matrix Size (N)
      startSection: true
      default: 20
      min: 4.0
      max: 40.0
      clampMin: true
      clampMax: true
      normMin: 4.0
      normMax: 40.0
      help: NxN crosspoint matrix dimension.
    - name: Activeroutes
      style: Int
      label: Active Routes
      default: 16
      min: 1.0
      max: 20.0
      clampMin: true
      clampMax: true
      normMin: 1.0
      normMax: 20.0
      help: Routes lit simultaneously.
    - name: Latticeglow
      style: Float
      label: Lattice Glow
      default: 1
      max: 2.0
      clampMin: true
      clampMax: true
      normMax: 2.0
      help: Brightness of the dim unlit grid.
    - name: Crosspointglow
      style: Float
      label: Crosspoint Glow
      default: 1
      max: 2.0
      clampMin: true
      clampMax: true
      normMax: 2.0
      help: Brightness of lit crosspoints + paths.
    - name: Packetspeed
      style: Float
      label: Packet Speed
      startSection: true
      default: 0.5
      max: 2.0
      clampMin: true
      clampMax: true
      normMax: 2.0
      help: Speed packets race the L-path. 0 freezes.
    - name: Packetdensity
      style: Int
      label: Packet Density
      default: 8
      min: 1.0
      max: 10.0
      clampMin: true
      clampMax: true
      normMin: 1.0
      normMax: 10.0
      help: Packets per active route.
    - name: Streams
      style: Int
      label: Essence Streams
      default: 3
      min: 1.0
      max: 3.0
      clampMin: true
      clampMax: true
      normMin: 1.0
      normMax: 3.0
      help: Separated essence colors (cyan/green/amber).
    - name: Ptprate
      style: Float
      label: PTP Beat Rate
      startSection: true
      default: 0.5
      min: 0.1
      max: 2.0
      clampMin: true
      clampMax: true
      normMin: 0.1
      normMax: 2.0
      help: PTP sync pulse frequency.
    - name: Reconfigrate
      style: Float
      label: Reconfigure Rate
      default: 0.25
      min: 0.05
      clampMin: true
      clampMax: true
      normMin: 0.05
      help: How often active routes reconfigure.
    - name: Lockindicators
      style: Float
      label: Lock Indicators
      default: 1
      max: 2.0
      clampMin: true
      clampMax: true
      normMax: 2.0
      help: Corner PTP-lock dot brightness.
    - name: Bloom
      style: Float
      startSection: true
      default: 1.1
      max: 3.0
      clampMin: true
      clampMax: true
      normMax: 3.0
      help: Bloom over lit crosspoints + packets.
    - name: Glitch
      style: Float
      default: 0.8
      max: 2.0
      clampMin: true
      normMax: 2.0
      help: 'VHS glitch amount: chroma split, tape jitter/tear, rolling scanlines, grain.'
    Output:
      $t: output
  position: [800, 0]
  color: [0.67, 0.67, 0.67]
  children:
  - name: out1
    type: outTOP
    flags:
    - viewer
    position: [3000, 0]
    inputs:
    - glsl_bloom
  - name: res_down
    type: resolutionTOP
    parameters:
      resolutionw: =int(parent().par.Resw.eval()/4)
      resolutionh: =int(parent().par.Resh.eval()/4)
    position: [600, 0]
    inputs:
    - glsl_matrix
  - name: comp_bloom
    type: compositeTOP
    parameters:
      operand: add
      outputresolution: custom
      resolutionw: =parent().par.Resw.eval()
      resolutionh: =parent().par.Resh.eval()
      format: rgba16float
    position: [1800, 0]
    inputs:
    - glsl_matrix
    - glsl_bloomblur
  - name: glsl_bloom
    type: glslTOP
    parameters:
      pixeldat: glsl_bloom_pixel
      computedat: glsl_bloom_compute
      outputresolution: custom
      resolutionw: =parent().par.Resw.eval()
      resolutionh: =parent().par.Resh.eval()
      format: rgba16float
    sequences:
      vec:
      - name: uBloom
        valuex: =parent().par.Bloom.eval()
        valuey: 0.5
        valuez: =parent().par.Glitch.eval()
        valuew: =absTime.seconds
    position: [2400, 0]
    inputs:
    - comp_bloom
  - name: glsl_matrix
    type: glslTOP
    parameters:
      pixeldat: glsl_matrix_pixel
      computedat: glsl_matrix_compute
      outputresolution: custom
      resolutionw: =parent().par.Resw.eval()
      resolutionh: =parent().par.Resh.eval()
      format: rgba16float
    sequences:
      vec:
      - name: uGrid
        valuex: =parent().par.Gridsize.eval()
        valuey: =parent().par.Activeroutes.eval()
        valuez: =parent().par.Latticeglow.eval()
        valuew: =parent().par.Crosspointglow.eval()
      - name: uPacket
        valuex: =parent().par.Packetspeed.eval()
        valuey: =parent().par.Packetdensity.eval()
        valuez: =parent().par.Streams.eval()
        valuew: =absTime.seconds*parent().par.Packetspeed.eval()
      - name: uClock
        valuex: =parent().par.Ptprate.eval()
        valuey: =parent().par.Reconfigrate.eval()
        valuez: =parent().par.Lockindicators.eval()
        valuew: =absTime.seconds
  - name: glsl_bloomblur
    type: glslTOP
    parameters:
      pixeldat: glsl_bloomblur_pixel
      computedat: glsl_bloomblur_compute
      outputresolution: custom
      resolutionw: =int(parent().par.Resw.eval()/4)
      resolutionh: =int(parent().par.Resh.eval()/4)
      format: rgba16float
    sequences:
      vec:
      - name: uBloom
        valuex: =parent().par.Bloom.eval()
        valuey: 0.45
        valuez: 2.2
    position: [1200, 0]
    inputs:
    - res_down
  - name: glsl_bloom_info
    type: infoDAT
    parameters:
      op: glsl_bloom
    position: [2700, -120]
    dock: glsl_bloom
  - name: glsl_bloom_pixel
    type: textDAT
    parameters:
      language: glsl
      extension: frag
    flags:
    - viewer
    position: [2550, -120]
    dock: glsl_bloom
  - name: glsl_matrix_info
    type: infoDAT
    parameters:
      op: glsl_matrix
    position: [300, -120]
    dock: glsl_matrix
  - name: glsl_matrix_pixel
    type: textDAT
    parameters:
      language: glsl
      extension: frag
    flags:
    - viewer
    position: [150, -120]
    dock: glsl_matrix
  - name: glsl_bloom_compute
    type: textDAT
    parameters:
      language: glsl
    flags:
    - viewer
    position: [2400, -120]
    dock: glsl_bloom
  - name: glsl_bloomblur_info
    type: infoDAT
    parameters:
