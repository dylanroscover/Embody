      max: 3.0
      clampMin: true
      clampMax: true
      normMax: 3.0
    - name: Dotcrawl
      style: Float
      default: 1
      max: 3.0
      clampMin: true
      clampMax: true
      normMax: 3.0
    - name: Jitter
      style: Float
      default: 1
      max: 3.0
      clampMin: true
