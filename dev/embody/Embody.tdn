											"Fontcolor": "=parent.Widget.parGroup.Buttononfontcolor.eval() if me.par.Value.eval() else parent.Widget.parGroup.Buttonofffontcolor.eval()",
											"Facecolor": "=parent.Widget.parGroup.Buttononfacecolor.eval() if me.par.Value.eval() else parent.Widget.parGroup.Buttonofffacecolor.eval()",
