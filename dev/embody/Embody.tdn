								{
									"name": "rollover",
									"type": "containerCOMP",
									"parameters": {
										"layer": 7,
										"hmode": "fill",
										"vmode": "fill",
										"alignallow": "ignore",
										"display": "=parent().panel.rollover or parent().panel.lselect",
										"clickthrough": true,
										"bgcolorr": "=parent.Widget.par.Rollovercolorr.eval()",
										"bgcolorg": "=parent.Widget.par.Rollovercolorg.eval()",
