    bgcolorg: =parent.Embody.par.Backgroundcolorg
    bgcolorb: =parent.Embody.par.Backgroundcolorb
    bgalpha: =parent.Embody.par.Backgroundcolora
    topsmoothness: mipmap
    borderover: false
    justifyv: center
    reloadbuiltin: false
  sequences:
