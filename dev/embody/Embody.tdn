	"type_defaults": {
		"containerCOMP": {
			"parameters": {
				"resizecomp": "=me",
				"repocomp": "=me"
			},
			"color": [0.3, 0.5, 0.9],
			"tags": ["tdn"]
		},
		"textDAT": {
			"parameters": {
				"syncfile": true,
				"language": "python"
			},
			"size": [130, 90],
			"color": [0.9, 0.3, 0.4]
		},
		"annotateCOMP": {
			"parameters": {
				"includeinorder": true,
				"order": "=me.digits or 0",
				"layerzone": "=0 if hasattr(me, 'EncloseOPs') and me.EncloseOPs else 1"
			},
			"flags": ["display"]
		},
		"windowCOMP": {
			"parameters": {
				"title": "=me",
				"borders": false,
				"includedialog": false,
				"reloadbuiltin": false
			},
			"color": [0.3, 0.5, 0.9],
			"tags": ["tdn"]
		}
	},
