format: tdn
version: '2.0'
build: 816
generator: Embody/6.0.133
td_build: 099.2025.32820
source_file: Embody-6.134.toe
exported_at: '2026-07-18T01:34:02Z'
network_path: /embody/Embody
options:
  include_dat_content: false
  include_storage: true
type_defaults:
  containerCOMP:
    parameters:
      resizecomp: =me
      repocomp: =me
    color: [0.3, 0.5, 0.9]
    tags:
    - tdn
  textDAT:
    parameters:
      syncfile: true
      language: python
    size: [130, 90]
    color: [0.9, 0.3, 0.4]
  baseCOMP:
    size: [160, 130]
  tableDAT:
    parameters:
      syncfile: true
    size: [130, 90]
    color: [0.9, 0.3, 0.4]
    tags:
    - tsv
type: containerCOMP
custom_pars:
  Embody:
  - name: Setupwizard
    style: Pulse
    label: Setup Wizard
    help: Open the Embody setup wizard to review or change your mode, AI assistant, and where config files are written.
  - name: Embodymode
    style: Menu
    label: Mode
    default: auto
    menuNames:
    - auto
    - advanced
    menuLabels:
    - Auto - manage everything
    - Advanced - ask first
    help: How Embody handles invasive, project-level changes (git config, .venv, MCP/AI config files, network ops). 'Auto' manages everything silently -- recommended for most users. 'Advanced' asks before each such change and keeps the footprint minimal -- for users who want full control.
  - name: Folder
    style: Folder
    label: Ext. Folder (Rel. to Project)
    startSection: true
    help: Root folder where externalized files are saved. All .tox, .py, .json, and other externalized files are written relative to this folder.
  - name: Externalizeproject
    style: Pulse
    label: Externalize Full Project
    startSection: true
    help: Tags all eligible operators in the entire project for externalization. COMPs get .tox tags, DATs get file-type tags based on their content.
  - name: Disable
    style: Pulse
    startSection: true
    help: 'Disables Embody: removes all externalization tags from operators and stops tracking. Use Update to re-enable.'
  - name: Update
    style: Pulse
    label: Enable / Update
    help: 'Initializes Embody if not yet running, or triggers a full update cycle: scans all tagged operators, checks continuity, and syncs the externalizations table.'
  - name: Refresh
    style: Pulse
    help: Refreshes the externalizations table by re-scanning tagged operators without triggering saves or continuity checks.
  - name: Performmode
    style: Toggle
    label: Perform Mode
    startSection: true
  - name: Status
    style: Str
    label: Embody Status
    startSection: true
    readOnly: true
    help: Current Embody status (read-only). Shows whether Embody is initialized and running.
    value: Enabled
  Tags:
  - name: Toxtags
    style: Header
    label: tox Tags
    help: Tag strings and operator colors for TOX externalization. COMPs tagged with the Tox tag are externalized as .tox files.
  - name: Toxtagcolor
    style: RGBA
    label: tox Tag Color
    size: 3
    help: Color applied to tox-tagged COMP operators in the network editor. Makes externalized COMPs visually identifiable.
    values: [0.325, 0.8, 0.3]
  - name: Toxtag
    style: Str
    label: .tox Tag
    help: Tag string applied to COMP operators for .tox externalization. Operators with this tag are externalized as .tox files.
    value: tox
  - name: Dattags
    style: Header
    label: DAT Tags
    startSection: true
    help: Tag strings and operator colors for DAT externalization. DATs are tagged with format-specific tags (py, json, xml, etc.) and externalized to matching file types.
  - name: Dattagcolor
    style: RGBA
    label: DAT Tag Color
    size: 3
    help: Color applied to DAT-tagged operators in the network editor. Makes externalized DATs visually identifiable.
    values: [0.9, 0.3, 0.4]
  - name: Clonetagcolor
    style: RGBA
    label: Clone Tag Color
    size: 3
    help: Color applied to clone-tagged operators in the network editor. Distinguishes cloned externalized operators from originals.
    values: [1, 0.7, 0.1]
  - name: Pytag
    style: Str
    label: .py Tag
    help: Tag string for .py (Python) externalization. Applied to text DATs containing Python code.
    value: py
  - name: Jsontag
    style: Str
    label: .json Tag
    startSection: true
    help: Tag string for .json externalization. Applied to text DATs containing JSON data.
    value: json
  - name: Xmltag
    style: Str
    label: .xml Tag
    help: Tag string for .xml externalization. Applied to text DATs containing XML data.
    value: xml
  - name: Htmltag
    style: Str
    label: .html Tag
    help: Tag string for .html externalization. Applied to text DATs containing HTML content.
    value: html
  - name: Glsltag
    style: Str
    label: .glsl Tag
    startSection: true
    help: Tag string for .glsl externalization. Applied to text DATs containing GLSL shader code.
    value: glsl
  - name: Fragtag
    style: Str
    label: .frag Tag
    help: Tag string for .frag externalization. Applied to text DATs containing fragment shader code.
    value: frag
  - name: Verttag
    style: Str
    label: .vert Tag
    help: Tag string for .vert externalization. Applied to text DATs containing vertex shader code.
    value: vert
  - name: Txttag
    style: Str
    label: .txt Tag
    startSection: true
    help: Tag string for .txt externalization. Applied to text DATs containing plain text.
    value: txt
  - name: Mdtag
    style: Str
    label: .md Tag
    help: Tag string for .md externalization. Applied to text DATs containing Markdown content.
    value: md
  - name: Rtftag
    style: Str
    label: .rtf Tag
    help: Tag string for .rtf externalization. Applied to text DATs containing rich text format content.
    value: rtf
  - name: Csvtag
    style: Str
    label: .csv Tag
    startSection: true
    help: Tag string for .csv externalization. Applied to table DATs with comma-separated values.
    value: csv
  - name: Tsvtag
    style: Str
    label: .tsv Tag
    help: Tag string for .tsv externalization. Applied to table DATs with tab-separated values.
    value: tsv
  - name: Dattag
    style: Str
    label: .dat Tag
    help: Tag string for .dat externalization. Generic DAT externalization format.
    value: dat
  - name: Tdntags
    style: Header
    label: TDN Tags
    startSection: true
    help: Tag strings and operator colors for TDN externalization. COMPs tagged with the TDN tag have their children exported as human-readable .tdn JSON network files.
  - name: Tdntagcolor
    style: RGBA
    label: TDN Tag Color
    default: 0.3
    help: Color applied to TDN-tagged COMP operators in the network editor. Makes TDN-strategy COMPs visually identifiable.
  - name: Tdntag
    style: Str
    label: .tdn Tag
    help: Tag string for .tdn externalization. Applied to COMPs whose children are exported as human-readable JSON network files.
    value: tdn
  - name: Tdnexcludetag
    style: Str
    label: .tdn Exclude Tag
    startSection: true
    default: tdn_exclude
    help: 'Tag name (default ''tdn_exclude'') that opts a COMP out of the entire TDN system. Primary use: opt a single child out of cascade autotag (when Tdncascade is on, the tdn tag normally propagates from a tdn-tagged parent to all its children -- apply this tag to a child to keep it excluded). Also useful for app-managed COMPs (e.g. spawned via .copy() at runtime) that the application is responsible for. Excluded COMPs are invisible to TDN: never exported, never inlined in parent .tdn files, never stripped on save, never destroyed by reconstruction.'
  TDN:
  - name: Tdnmode
    style: Menu
    label: TDN Mode
    startSection: true
    default: export
    menuNames:
    - 'off'
    - export
    - full
    menuLabels:
    - 'Off'
    - Export-on-Save
    - Roundtrip (Experimental)
    help: Three-mode master for the TDN subsystem. Off = no TDN runtime (.tdn files on disk are preserved, Embody simply stops touching them). Export-on-Save (recommended) = write .tdn on save, .toe stays the source of truth, MCP reads live state via read_tdn. Roundtrip (Experimental) = bidirectional strip/restore of COMPs at save and open; may hit edge cases with extension reload timing on deeply-nested TDN COMPs.
  - name: Clipboardautopaste
    style: Toggle
    label: Clipboard Auto-Paste
    startSection: true
    default: true
    help: When on, Embody watches the OS clipboard and prompts to paste an Embody network the moment one is copied (e.g. the web "embody it" button) -- no keyboard shortcut needed. Turn off to disable the automatic prompt.
  - name: Tdncascade
    style: Toggle
    label: Cascade to Children
    startSection: true
    help: When tagging a COMP for TDN, automatically tag all child COMPs so each gets its own .tdn file.
  - name: Tdncascadewarn
    style: Menu
    label: Large TDN Warning
    default: ask
    menuNames:
    - ask
    - quiet
    menuLabels:
    - Ask
    - Quiet
    help: Controls whether a warning dialog is shown when a TDN file exceeds 5 MB. Set automatically when dismissed.
  - name: Embeddatsintdns
    style: Toggle
    label: Embed DATs (default)
    startSection: true
    help: When enabled, DAT content (text and table data) is included in TDN exports by default. Can be overridden per-export. Disabling reduces file size but loses DAT content.
  - name: Embedstorageintdns
    style: Toggle
    label: Embed Storage (default)
    default: true
    help: Include Python storage entries in TDN exports. Disable for COMPs with large storage to reduce file size. Can be overridden per-COMP from the tagging menu.
  - name: Autosave
    style: Toggle
    label: Auto-Save Checkpoints
    startSection: true
    default: true
    help: When on, after the agent (or you) goes idle Embody writes changed TDN COMPs to disk as a cheap ~6ms .tdn checkpoint -- NO full project save, no strip/restore, no freeze -- so a crash loses little unsaved work. Checkpointed COMPs are rebuilt on next open. Skips during Perform Mode and project saves.
  - name: Tdncreateonstart
    style: Toggle
    label: TDN Create on Start
    startSection: true
    default: true
    help: When enabled, reconstructs TDN-strategy COMP children from .tdn files on disk when the project opens. Required for TDN round-trip workflow where children are stripped on save.
  - name: Autosavestatus
    style: Str
    label: Auto-Save Status
    readOnly: true
    help: 'Read-only auto-save state: Idle / Saving / Bypassed (Perform Mode) / Disabled.'
    value: Saved 22:58:24 UTC
  - name: Tdnstriponsave
    style: Toggle
    label: Strip on Save
    default: true
    help: When enabled, strips children from TDN-strategy COMPs during project save. Children are recreated on next open via TDN Create on Start. Keeps .toe files minimal.
  - name: Tdnpalettehandling
    style: Menu
    label: Palette Handling
    startSection: true
    default: ask
    menuNames:
    - ask
    - blackbox
    - fullexport
    menuLabels:
    - Ask
    - Black Box
    - Full Export
    help: 'How to handle TD palette COMPs (e.g. abletonLink, Widget components) during TDN export. Ask: prompt on first encounter per COMP. Black Box: reference the palette and skip internal children -- the correct choice for stock palette components. Full Export: export all internals -- use when the palette COMP has been heavily customized internally.'
    value: blackbox
  - name: Tdnfile
    style: File
    label: TDN File
    startSection: true
    help: Path to a .tdn file to import. Select a file, set the Network Path target, then pulse Import TDN.
  - name: Networkpath
    style: COMP
    label: Network Path
    help: Target COMP where the TDN file will be imported. Operators from the .tdn are created as children of this COMP.
  - name: Importtdn
    style: Pulse
    label: Import TDN
    help: Imports the specified TDN File into the Network Path target. Creates all operators, sets parameters, connections, and positions.
  Envoy:
  - name: Aiclient
    style: Menu
    label: AI Client
    default: '0'
    menuNames:
    - claudecode
    - codex
    - gemini
    - vscode
    - cursor
    - windsurf
    - copilot
    - none
    menuLabels:
    - Claude Code
    - Codex
    - Gemini
    - VS Code
    - Cursor
    - Windsurf
    - GitHub Copilot
    - None
    help: Selects the AI client used with Envoy. Determines which MCP configuration file format is generated (e.g. .mcp.json for Claude Code).
    value: claudecode
  - name: Launchaiclient
    style: Pulse
    label: Launch AI Client
    help: 'Open the AI client selected above at the project root: editors (VS Code, Cursor, Windsurf, Copilot) open the folder as a workspace; CLI tools (Claude Code, Codex, Gemini) open in a new terminal at the root.'
  - name: Aiprojectroot
    style: Menu
    label: AI Project Root
    startSection: true
    default: gitroot
    menuNames:
    - gitroot
    - projectfolder
    - custom
    menuLabels:
    - Git repository root
    - Project folder (.toe directory)
    - Custom
    help: Where Embody writes AI config (AGENTS.md, CLAUDE.md, .claude/, .cursor/, .mcp.json, .embody/). "Git root" (default) writes at the top of the git repo. "Project folder" writes alongside the .toe -- use this when your TD project lives in a subdirectory of a larger repo and you open that subdirectory as your AI tool workspace.
  - name: Aiprojectrootcustom
    style: Folder
    label: AI Project Root (Custom)
    help: Custom directory for AI/MCP config when "AI Project Root" is set to "Custom". Relative paths are resolved against the .toe directory (e.g. "../" places config one level above the .toe -- useful when multiple TouchDesigner projects share a parent folder in a monorepo). Absolute paths are used as-is. Changing this path migrates Embody state and AI config to the new location.
  - name: Envoyenable
    style: Toggle
    label: Envoy Enable
    startSection: true
    help: Enables/disables the Envoy MCP server. When enabled, starts an HTTP server that exposes TouchDesigner operations to Claude Code and other MCP clients.
    value: true
  - name: Envoyport
    style: Int
    label: Envoy Port
    default: 9870
    help: 'Port number for the Envoy MCP server (default: 9870). Changing while running automatically restarts the server on the new port.'
  - name: Embotenable
    style: Toggle
    label: Embot
    startSection: true
    default: true
    help: Show the Embot builder mascot. He appears on each operator Envoy creates or edits and narrates what it does. Off hides him entirely (no character, no camera movement).
  - name: Envoyfollow
    style: Toggle
    label: Envoy Follow
    default: true
    help: Camera follows the operator Envoy is working on, panning the network editor to it. Works with or without the Embot character shown.
  - name: Autoexternalize
    style: Menu
    label: Auto-Externalize New Ops
    startSection: true
    default: neither
    menuNames:
    - neither
    - dats
    - comps
    - both
    menuLabels:
    - Neither
    - DATs
    - COMPs
    - DATs and COMPs
    help: 'Auto-tag operators that Envoy creates via create_op for externalization to version-control-friendly files. Neither = off. DATs = externalize created DATs (source files). COMPs = externalize created COMPs (TDN). DATs and COMPs = both. Only ops at an externalization boundary are tagged -- never ops already inside an externalized COMP, palette clones, or Embody itself. Additive only: it never deletes files or removes tags.'
  - name: Toolpermissions
    style: Menu
    label: Tool Permissions
    default: all
    menuNames:
    - all
    - some
    - prompt
    - leave
    menuLabels:
    - Don't prompt for any tool
    - Prompt for some tools (read-only auto-approved)
    - Prompt for all tools
    - Leave settings file alone
    help: Whether Embody pre-approves Envoy MCP tool calls in .claude/settings.local.json so Claude Code isn't prompted on every tool use. all = pre-approve all Envoy tools (no prompts). some = pre-approve read-only/query tools only; tools that create/edit/delete/execute still prompt. prompt = pre-approve nothing; every tool prompts. leave = never create or modify settings.local.json. Except for 'leave', Embody also whitelists the OS temp directory so captured TOP images can be read without a prompt. The setup wizard sets this; you can change it here anytime.
  - name: Envoystatus
    style: Str
    label: Envoy Status
    startSection: true
    readOnly: true
    help: Current status of the Envoy MCP server (read-only). Shows Running, Stopped, or error information.
    value: Running on port 9872
  Logs:
  - name: Verbose
    style: Toggle
    label: Verbose (Debug)
    help: Enables debug-level logging. When off, only INFO and above are logged. Enable for detailed diagnostics when troubleshooting issues.
  - name: Print
    style: Toggle
    label: Print to Textport
    help: Echoes all log messages to the TouchDesigner textport. Useful for monitoring Embody activity in real-time.
    value: true
  - name: Logtofile
    style: Toggle
    label: Log to File
    help: Writes log messages to a file on disk. Files are saved to the Log Folder with automatic rotation at 10 MB.
    value: true
  - name: Logfolder
    style: Folder
    label: Log Folder
    help: Folder where log files are saved. Defaults to dev/logs/ in the project directory. Files are named <project>_YYMMDD.log.
    value: logs
  UI:
  - name: Openmanager
    style: Pulse
    label: Open Manager
    help: Opens the Embody Manager window, which provides a list view of all externalized operators with status, actions, and strategy management.
  - name: Closemanager
    style: Pulse
    label: Close Manager
    help: Closes the Embody Manager window.
  - name: Textcolor
    style: RGBA
    label: Text Color
    startSection: true
    help: Text color used throughout the Embody UI (toolbar, manager, dialogs).
    values: [0.59472, 0.63, 0.599424, 1]
  - name: Backgroundcolor
    style: RGBA
    label: Background Color
    help: Background color for the Embody UI panels and windows.
    values: [0.0968, 0.121, 0.121, 0.8]
  - name: Buttonbackgroundcolor
    style: RGBA
    label: Button Background Color
    help: Background color for buttons in the Embody UI.
    values: [0.1246, 0.14, 0.13, 1]
  - name: Listheadercolor
    style: RGBA
    label: List Header Color
    help: Header row color in the Manager list view.
    values: [0.089419, 0.121, 0.103104, 1]
  - name: Listrowcolor
    style: RGBA
    label: List Row Color
    help: Default row color in the Manager list view.
    values: [0.1246, 0.14, 0.13, 1]
  - name: Listrowselectcolor
    style: RGBA
    label: List Row Select Color
    help: Selected row highlight color in the Manager list view.
    values: [0.220088, 0.244, 0.221283, 1]
  - name: Savedcolor
    style: RGBA
    label: Saved Color
    help: Color indicator for operators that are saved and up-to-date (not dirty).
    values: [0.227574, 0.423, 0.289133, 0.5]
  - name: Dirtycolor
    style: RGBA
    label: Dirty Color
    help: Color indicator for operators that have unsaved changes (dirty state).
    values: [0.675, 0.25668, 0.2268, 1]
  - name: Dirtyparcolor
    style: RGBA
    label: Dirty Par Color
    help: Color indicator for parameters that have been modified since last save.
    values: [0.49, 0.321897, 0.16464, 1]
  - name: Uncommittedcolor
    style: RGBA
    label: Uncommitted Color
    default: 0.6
    help: Color indicator for externalized files that are saved to disk but not yet committed to git (uncommitted). Distinct from the red unsaved color and the amber par-change color.
  - name: Taggingmenucolor
    style: RGBA
    label: Tagging Menu Color
    help: Background color for the tagging menu popup.
    values: [0.2, 0.2, 0.2, 1]
  - name: Highlightcolor
    style: RGBA
    label: Highlight Color
    help: Accent/highlight color used for interactive elements in the Embody UI.
    values: [1, 1, 1, 1]
  - name: Tdnsavedcolor
    style: RGBA
    label: TDN Saved Color
    help: Color indicator for TDN-strategy operators that are saved and up-to-date.
    values: [0.153552, 0.376081, 0.457, 1]
  Shortcuts:
  - name: Enablekeyboardshortcuts
    style: Toggle
    label: Enable Keyboard Shortcuts
    default: true
    help: Master switch for Embody's keyboard shortcuts. When off, the Keyboard In DAT is disabled and no Embody shortcut (including the tagger double-tap) fires.
  - name: Shortcutmanager
    style: Str
    label: Open Manager
    startSection: true
    default: ctrl+shift+o
    help: 'Keyboard shortcut for Open Manager. Lowercase combo like ''cmd+shift+o'' or ''ctrl+shift+o'': modifiers joined with ''+'' plus one trigger key. ctrl and cmd are distinct keys on macOS (matched exactly); on Windows/Linux, which has no Cmd key, a cmd binding fires via Ctrl. Each combo may be assigned to only one action. Leave empty to disable. Edit by hand or pulse Record below.'
    value: cmd+shift+o
  - name: Recordmanager
    style: Pulse
    label: Record
    help: 'Arm the shortcut recorder for Open Manager: press the desired key combo -- the first non-modifier key commits it with whatever modifiers are held. If the combo already drives another action, a dialog explains and recording continues. Esc cancels; times out after 10 seconds.'
  - name: Shortcutupdateall
    style: Str
    label: Update All Externalizations
    startSection: true
    default: ctrl+shift+u
    help: 'Keyboard shortcut for Update All Externalizations. Lowercase combo like ''cmd+shift+o'' or ''ctrl+shift+o'': modifiers joined with ''+'' plus one trigger key. ctrl and cmd are distinct keys on macOS (matched exactly); on Windows/Linux, which has no Cmd key, a cmd binding fires via Ctrl. Each combo may be assigned to only one action. Leave empty to disable. Edit by hand or pulse Record below.'
    value: cmd+shift+u
  - name: Recordupdateall
    style: Pulse
    label: Record
    help: 'Arm the shortcut recorder for Update All Externalizations: press the desired key combo -- the first non-modifier key commits it with whatever modifiers are held. If the combo already drives another action, a dialog explains and recording continues. Esc cancels; times out after 10 seconds.'
  - name: Shortcutupdatecomp
    style: Str
    label: Update Current COMP
    startSection: true
    default: ctrl+alt+u
    help: 'Keyboard shortcut for Update Current COMP. Lowercase combo like ''cmd+shift+o'' or ''ctrl+shift+o'': modifiers joined with ''+'' plus one trigger key. ctrl and cmd are distinct keys on macOS (matched exactly); on Windows/Linux, which has no Cmd key, a cmd binding fires via Ctrl. Each combo may be assigned to only one action. Leave empty to disable. Edit by hand or pulse Record below.'
    value: cmd+alt+u
  - name: Recordupdatecomp
    style: Pulse
    label: Record
    help: 'Arm the shortcut recorder for Update Current COMP: press the desired key combo -- the first non-modifier key commits it with whatever modifiers are held. If the combo already drives another action, a dialog explains and recording continues. Esc cancels; times out after 10 seconds.'
  - name: Shortcutrefresh
    style: Str
    label: Refresh Tracking
    startSection: true
    default: ctrl+shift+r
    help: 'Keyboard shortcut for Refresh Tracking. Lowercase combo like ''cmd+shift+o'' or ''ctrl+shift+o'': modifiers joined with ''+'' plus one trigger key. ctrl and cmd are distinct keys on macOS (matched exactly); on Windows/Linux, which has no Cmd key, a cmd binding fires via Ctrl. Each combo may be assigned to only one action. Leave empty to disable. Edit by hand or pulse Record below.'
    value: cmd+shift+r
  - name: Recordrefresh
    style: Pulse
    label: Record
    help: 'Arm the shortcut recorder for Refresh Tracking: press the desired key combo -- the first non-modifier key commits it with whatever modifiers are held. If the combo already drives another action, a dialog explains and recording continues. Esc cancels; times out after 10 seconds.'
  - name: Shortcutexportproject
    style: Str
    label: Export Project to TDN
    startSection: true
    default: ctrl+shift+e
    help: 'Keyboard shortcut for Export Project to TDN. Lowercase combo like ''cmd+shift+o'' or ''ctrl+shift+o'': modifiers joined with ''+'' plus one trigger key. ctrl and cmd are distinct keys on macOS (matched exactly); on Windows/Linux, which has no Cmd key, a cmd binding fires via Ctrl. Each combo may be assigned to only one action. Leave empty to disable. Edit by hand or pulse Record below.'
    value: cmd+shift+e
  - name: Recordexportproject
    style: Pulse
    label: Record
    help: 'Arm the shortcut recorder for Export Project to TDN: press the desired key combo -- the first non-modifier key commits it with whatever modifiers are held. If the combo already drives another action, a dialog explains and recording continues. Esc cancels; times out after 10 seconds.'
  - name: Shortcutexportcomp
    style: Str
    label: Export Current COMP to TDN
    startSection: true
    default: ctrl+alt+e
    help: 'Keyboard shortcut for Export Current COMP to TDN. Lowercase combo like ''cmd+shift+o'' or ''ctrl+shift+o'': modifiers joined with ''+'' plus one trigger key. ctrl and cmd are distinct keys on macOS (matched exactly); on Windows/Linux, which has no Cmd key, a cmd binding fires via Ctrl. Each combo may be assigned to only one action. Leave empty to disable. Edit by hand or pulse Record below.'
    value: cmd+alt+e
  - name: Recordexportcomp
    style: Pulse
    label: Record
    help: 'Arm the shortcut recorder for Export Current COMP to TDN: press the desired key combo -- the first non-modifier key commits it with whatever modifiers are held. If the combo already drives another action, a dialog explains and recording continues. Esc cancels; times out after 10 seconds.'
  - name: Shortcutcopytdn
    style: Str
    label: Copy Selected COMP as TDN
    startSection: true
    default: ctrl+shift+c
    help: 'Keyboard shortcut for Copy Selected COMP as TDN. Lowercase combo like ''cmd+shift+o'' or ''ctrl+shift+o'': modifiers joined with ''+'' plus one trigger key. ctrl and cmd are distinct keys on macOS (matched exactly); on Windows/Linux, which has no Cmd key, a cmd binding fires via Ctrl. Each combo may be assigned to only one action. Leave empty to disable. Edit by hand or pulse Record below.'
    value: cmd+shift+c
  - name: Recordcopytdn
    style: Pulse
    label: Record
    help: 'Arm the shortcut recorder for Copy Selected COMP as TDN: press the desired key combo -- the first non-modifier key commits it with whatever modifiers are held. If the combo already drives another action, a dialog explains and recording continues. Esc cancels; times out after 10 seconds.'
  - name: Shortcuttagger
    style: Menu
    label: Tagger Double-Tap Key
    startSection: true
    default: lctrl
    menuSource: op('./shortcuts').module.taggerMenu()
    help: 'Modifier key that opens the tagger for the operator under the cursor when double-tapped (two presses within half a second). Entries are physical keys and adapt per platform: macOS offers Left Ctrl plus left/right Cmd (Apple keyboards have no right Ctrl); Windows/Linux offers left/right Ctrl (no Cmd key). A choice a platform''s keyboard lacks falls back to its closest key -- the saved value is never rewritten, so it round-trips between platforms intact. Off disables the tagger shortcut.'
  - name: Resetshortcuts
    style: Pulse
    label: Reset Shortcuts to Defaults
    startSection: true
    help: Restore all keyboard shortcuts (and the tagger double-tap key) to factory defaults.
  Advanced:
  - name: Createexternalizationstable
    style: Pulse
    label: Create Externalizations Table
    startSection: true
    help: Creates the externalizations tracking table as a sibling operator if it does not already exist. Safe to pulse at any time — no-op if the table is already connected. Use this to recover if the table was lost after an Embody upgrade.
  - name: Externalizations
    style: DAT
    label: Externalizations Table
    help: Reference to the externalizations tracking table DAT (stored in TSV format). Lists all externalized operators with their paths, types, timestamps, and dirty state.
    value: /embody/externalizations
  - name: Openexternalizationstable
    style: Pulse
    label: Open Externalizations Table
    help: Opens the externalizations tracking table in a floating viewer window.
  - name: Detectduplicatepaths
    style: Toggle
    label: Detect Duplicate Paths
    startSection: true
    help: When enabled, warns if multiple operators resolve to the same externalized file path. Helps catch naming conflicts.
    value: true
  - name: Templatemaster
    style: Str
    label: Template Master Name
    default: __template__
    help: When duplicate external paths are detected, an operator whose path contains a folder/COMP with this exact name is auto-selected as the master (the rest are tagged as clones), with no prompt. Matches only when exactly one operator in the group contains this name. Clear this field to always choose the master manually, or set it to your own naming convention (e.g. '_master').
  - name: Localtimestamps
    style: Toggle
    label: Local Timestamps
    default: true
    help: When enabled, timestamps in the externalizations table are displayed in your local timezone instead of UTC.
  - name: Toxrestoreonstart
    style: Toggle
    label: Restore toxes on Start
    help: When enabled, automatically restores TOX-strategy COMPs from .tox files on disk when the project opens. Useful when COMPs were externalized but the .toe was not saved.
    value: true
  - name: Datrestoreonstart
    style: Toggle
    label: Restore DATs on Start
    default: true
    help: When enabled, automatically restores DAT-strategy operators from externalized files on disk when the project opens. Recreates missing DATs (py, json, xml, etc.) and configures file sync. Safely excludes Embody descendants and DATs inside TOX/TDN COMPs.
  - name: Filecleanup
    style: Menu
    label: File Cleanup
    startSection: true
    default: ask
    menuNames:
    - ask
    - keep
    - delete
    menuLabels:
    - Ask
    - Always Keep Files
    - Always Delete Files
    help: 'When a deleted operator''s external file still exists on disk: Ask prompts each time, Always Keep removes the tracking entry but leaves files on disk, Always Delete removes both the entry and the file.'
    value: keep
  - name: Toxdropexpr
    style: Menu
    label: Dropped .tox Expression
    startSection: true
    default: ask
    menuNames:
    - ask
    - clean
    - ignore
    menuLabels:
    - Ask
    - Always Clean
    - Always Ignore
    help: 'How to handle the default expression TouchDesigner writes into a COMP''s External .tox when a .tox is dragged in (me.parent().fileFolder + ''/'' + ...). Ask: prompt when detected (the dialog''s Always buttons set this parameter). Always Clean: silently clear the expression. Always Ignore: silently leave it. Embody''s own descendants are always cleaned regardless.'
  - name: Tdndatsafety
    style: Menu
    label: Content Safety
    default: ask
    menuNames:
    - ask
    - externalize
    - ignore
    menuLabels:
    - Ask Each Save
    - Always Externalize
    - Never Ask
    help: What to do when TDN COMPs contain DATs or storage that will be lost on save. 'Ask Each Save' prompts on each save (recommended), 'Always Externalize' auto-externalizes at-risk DATs without asking, 'Never Ask' suppresses the check entirely. Prefer 'Ask' or 'Always Externalize' -- 'Never Ask' is an opt-in escape hatch for power users who accept the risk.
  - name: Uninstall
    style: Pulse
    startSection: true
    help: 'Removes Embody from this project: deletes Embody-generated config (CLAUDE.md / AGENTS.md / .claude / .cursor / ...), Embody''s .venv, and .embody/ state; strips only Embody''s block from shared files (.gitignore, .gitattributes, .mcp.json); un-sets the .tdn git diff driver. Your own files, externalized .tox / .tdn / .py, and the Embody COMP are NOT removed. Asks for confirmation first.'
  About:
  - name: Version
    style: Str
    startSection: true
    readOnly: true
    help: Embody version string (read-only).
    value: 6.0.133
  - name: Touchbuild
    style: Str
    label: Touch Build
    readOnly: true
    help: TouchDesigner build number this version was developed on (read-only).
    value: '2025.32820'
  - name: Author
    style: Str
    readOnly: true
    help: Embody author (read-only).
    value: Dylan Roscover
  - name: Build
    style: Int
    label: Build Number
    readOnly: true
    help: Embody build number (read-only). Incremented with each release.
    value: 816
  - name: Github
    style: Pulse
    label: GitHub
    startSection: true
    help: Opens the Embody GitHub repository in your web browser.
  - name: Date
    style: Str
    label: Build Date
    readOnly: true
    help: Date of this Embody build (read-only).
    value: 2026-07-18 01:34:02 UTC
  - name: Help
    style: Pulse
    help: Opens the Embody help documentation.
