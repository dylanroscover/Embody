- name: execute
  type: executeDAT
  parameters:
    fromop: =parent()
    start: true
    create: true
    projectpresave: true
    projectpostsave: true
    file: embody/Embody/execute.py
    defaultreadencoding: cp1252
    syncfile: true
    language: input
  flags:
  - display
  position: [-300, 200]
  size: [130, 90]
  color: [0.9, 0.3, 0.4]
  tags:
  - py
- name: manager
  type: containerCOMP
  parameters:
    y: 13
    w: 1080
    h: 440
    resizer: true
    resizeb: true
    resizewmin: 250
    resizewmax: 3840
    resizehmin: 50
    resizehmax: 2160
    topsmoothness: mipmap
    borderar: =parent.Embody.par.Textcolorr * 0.5
    borderag: =parent.Embody.par.Textcolorg * 0.5
    borderab: =parent.Embody.par.Textcolorb * 0.5
    borderaalpha: =parent.Embody.par.Textcolora
    leftborder: bordera
    rightborder: bordera
    bottomborder: bordera
    topborder: bordera
    align: verttb
    reloadbuiltin: false
  position: [650, 250]
  size: [160, 92]
  color: [0.3, 0.5, 0.9]
  tags:
  - tdn
  tdn_ref: embody/Embody/manager.tdn
- name: parexec
  type: parameterexecuteDAT
  parameters:
    pars: '*'
    file: embody/Embody/parexec.py
    syncfile: true
    language: input
  position: [-300, 100]
  size: [130, 90]
  color: [0.9, 0.3, 0.4]
  tags:
  - py
- name: select1
