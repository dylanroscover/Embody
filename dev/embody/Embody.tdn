										"defaultreadencoding": "cp1252"
									},
									"position": [-300, 200],
									"color": [0.05, 0.5, 0.05],
									"comment": "Execution for parameter changes",
									"dat_content": "def valueChange(par, val, prev):\n\text.SubWidgetExt.onParSettingsChange(par, prev)\n\ndef onPulse(par):\n\text.SubWidgetExt.onParSettingsPulse(par)\n\n",
									"dat_content_format": "text"
								},
								{
									"name": "text1_callbacks",
									"type": "textDAT",
									"position": [400, 50],
									"size": [160, 130],
									"dat_content": "# Text Component callbacks\n\ndef onValueChange(comp, value, prevValue):\n\t\"\"\"\n\tCalled whenever the text component's value parameter changes for any reason including typing\n\tin the text window or changing the parameter directly. The callback is equivalent to the\n\tonValueChange in the parameter exectute DAT.\n\t\n\tArgs:\n\t\tcomp: the text component\n\t\tvalue: the new value\n\t\tprevValue: the previous value\n\t\"\"\"\n\t#debug('\\nonValueChange comp:', comp.path, '- new value: ', value, ', prev value: ', prevValue )\n\treturn\n\t\ndef onFocus(comp):\n\t\"\"\"\n\tCalled when one of the text components viewers gets keyboard focus. \n\t\n\tArgs:\n\t\tcomp: the text component\n\t\"\"\"\n\t#debug('\\nonFocus comp:', comp.path)\n\treturn\n\ndef onFocusEnd(comp, info):\n\t\"\"\"\n\tCalled when one of the text component's viewers loses keyboard focus. In regular editing mode\n\tthis is right after the contents are saved back to the value parameter. This function is called\n\teverytime the viewer loses focus, even if the text does not change.\n\t\n\tArgs:\n\t\tcomp: the text component\n\t\tinfo: a dictionary containing information about the event including:\n\t\t\treason: a string indicating what caused the viewer to lose focus e.g. 'enter', 'escape', 'tab', 'unknown'\n\t\n\t\"\"\"\n\t#debug('\\nonFocusEnd comp:', comp.path, '- info:\\n', info)\n\treturn\n\t\ndef onTextEdit(comp):\n\t\"\"\"\n\tCalled each time the contents of the text component viewer change i.e. when typing a character,\n\tdeleting text, cutting or pasting. \n\t\n\tArgs:\n\t\tcomp: the text component\n\t\"\"\"\n\t#debug('\\nonTextEdit comp:', comp.path, '- text: ', comp.editText)\n\treturn\n\t\ndef onTextEditEnd(comp, value, prevValue):\n\t\"\"\"\n\tCalled when the user finishes editing and the value has been changed. Not called in 'Continuous Edit' mode. Use\n\tonTextEdit and onFocusEnd when using continuous editing.\n\t\n\tArgs:\n\t\tcomp: the text component\n\t\tvalue: the new value\n\t\tprevValue: the previous value\n\t\"\"\"\n\t#debug('\\nonTextEditEnd comp:', comp.path, '- new value: ', value, ', prev value: ', prevValue )\n\treturn\n\t\n\t",
									"dat_content_format": "text"
								}
							]
						},
						{
							"name": "parexec_width",
							"type": "parameterexecuteDAT",
							"parameters": {
								"fromop": "=parent()",
								"op": "../../manager",
								"pars": "w h",
								"language": "python"
							},
							"position": [-375, 100],
							"dat_content": "# me - this DAT\n# par - the Par object that has changed\n# val - the current value\n# prev - the previous value\n# \n# Make sure the corresponding toggle is enabled in the Parameter Execute DAT.\n\ndef onValueChange(par, prev):\n\t# use par.eval() to get current value\n\text = parent.minMaxClose.ext.MinMaxCloseExt\n\n\tif ext.win_state == 1:\n\t\tif par.name == 'w':\n\t\t\text.max_width = par.eval()\n\t\telse:\n\t\t\text.max_height = par.eval()\n\t\n\treturn\n\n# Called at end of frame with complete list of individual parameter changes.\n# The changes are a list of named tuples, where each tuple is (Par, previous value)\ndef onValuesChanged(changes):\n\tfor c in changes:\n\t\t# use par.eval() to get current value\n\t\tpar = c.par\n\t\tprev = c.prev\n\treturn\n\ndef onPulse(par):\n\treturn\n\ndef onExpressionChange(par, val, prev):\n\treturn\n\ndef onExportChange(par, val, prev):\n\treturn\n\ndef onEnableChange(par, val, prev):\n\treturn\n\ndef onModeChange(par, val, prev):\n\treturn\n\t",
							"dat_content_format": "text"
						},
						{
							"name": "MinMaxCloseExt",
							"type": "textDAT",
							"position": [-200, 100],
							"size": [130, 90],
							"tags": ["TDExtension"],
							"dat_content": "\nimport TDFunctions as TDF\n\nclass MinMaxCloseExt:\n\t\"\"\"\n\tManages minimize/maximize/close for the Embody manager window.\n\tCompact mode hides non-essential toolbar buttons for a widget-like footprint.\n\t\"\"\"\n\tdef __init__(self, ownerComp):\n\t\tself.ownerComp = ownerComp\n\t\tself.windowCompPar = self.ownerComp.parent.Widget.par.Windowcomp\n\t\tself.panelCompPar = self.ownerComp.parent.Widget.par.Panelcomp\n\n\t\tself.mgr = parent.Embody\n\t\tself.tools = parent.Embody.op('toolbar')\n\t\tself.lister = parent.Embody.op('list')\n\t\tself.filter = self.tools.op('container_right')\n\t\tself.container_left = self.tools.op('container_left')\n\n\t\t# Buttons hidden in compact mode (envoy_toggle stays visible)\n\t\tself.compact_hide_names = (\n\t\t\t'save_folder',\n\t\t\t'envoy_status', 'disable'\n\t\t)\n\n\t\t# Known-good default display states for maximize restore\n\t\tself._defaults = {\n\t\t\t'status':       {'mode': 'constant', 'val': 0},\n\t\t\t'disable':      {'mode': 'constant', 'val': 1},\n\t\t\t'initialize':   {'mode': 'constant', 'val': 1},\n\t\t\t'refresh':      {'mode': 'expression', 'expr': \"1 if parent.Embody.par.Status == 'Enabled' else 0\"},\n\t\t\t'save_folder':  {'mode': 'expression', 'expr': \"1 if parent.Embody.par.Status == 'Enabled' else 0\"},\n\t\t\t'export_comp_tdn': {'mode': 'constant', 'val': 1},\n\t\t\t'export_tdn':   {'mode': 'constant', 'val': 1},\n\t\t\t'import_tdn':   {'mode': 'constant', 'val': 1},\n\t\t\t'envoy_status': {'mode': 'constant', 'val': 1},\n\t\t\t'envoy_toggle': {'mode': 'constant', 'val': 1},\n\t\t}\n\n\t\tself.win_state = 1\n\n\t\tself.min_width = 370\n\t\tself.min_height = 72\n\t\tself.max_width = 1080\n\t\tself.max_height = 440\n\n\t\tself.status_compact_w = 80\n\t\tself.status_default_w = 80\n\n\tdef Windowclose(self, par):\n\t\t\"\"\"Close the manager window.\"\"\"\n\t\twindowComp = self.windowCompPar.eval()\n\t\tif isinstance(windowComp, windowCOMP):\n\t\t\twindowComp.par.winclose.pulse()\n\n\tdef Windowmaximize(self, par):\n\t\t\"\"\"Restore to full manager view.\"\"\"\n\t\tself.win_state = 1\n\t\t# Restore ALL buttons to their known defaults\n\t\tif self.container_left:\n\t\t\tfor name, dflt in self._defaults.items():\n\t\t\t\tbtn = self.container_left.op(name)\n\t\t\t\tif not btn:\n\t\t\t\t\tcontinue\n\t\t\t\tif dflt['mode'] == 'expression':\n\t\t\t\t\tbtn.par.display.mode = ParMode.EXPRESSION\n\t\t\t\t\tbtn.par.display.expr = dflt['expr']\n\t\t\t\telse:\n\t\t\t\t\tbtn.par.display = dflt['val']\n\t\t\t# Restore status widget width\n\t\t\tstatus = self.container_left.op('status')\n\t\t\tif status:\n\t\t\t\tstatus.par.w = self.status_default_w\n\t\tself.tools.par.display = 1\n\t\tself.lister.par.display = 1\n\t\tself.filter.par.display = 1\n\t\tself.mgr.par.w = self.max_width\n\t\trun(f\"op('{self.mgr}').par.h = {self.max_height}\", delayFrames=1)\n\t\tparent.Embody.Refresh()\n\n\tdef Windowminimize(self, par):\n\t\t\"\"\"Collapse to compact widget mode.\"\"\"\n\t\tself.win_state = 0\n\t\tif self.container_left:\n\t\t\t# Hide non-essential buttons\n\t\t\tfor name in self.compact_hide_names:\n\t\t\t\tbtn = self.container_left.op(name)\n\t\t\t\tif btn:\n\t\t\t\t\tbtn.par.display = 0\n\t\t\t# Show status label with dirty count\n\t\t\tstatus = self.container_left.op('status')\n\t\t\tif status:\n\t\t\t\tstatus.par.display = 1\n\t\t\t\tstatus.par.w = self.status_compact_w\n\t\tself.lister.par.display = 0\n\t\tself.filter.par.display = 0\n\t\tself.mgr.par.w = self.min_width\n\t\trun(f\"op('{self.mgr}').par.h = {self.min_height}\", delayFrames=1)\n",
							"dat_content_format": "text"
						},
						{
							"name": "extensionParExec",
							"type": "parameterexecuteDAT",
							"parameters": {
								"fromop": "=parent()",
								"op": "=parent()",
								"pars": "*",
								"builtin": false,
								"defaultreadencoding": "cp1252"
							},
							"position": [-200, -125],
							"dat_content": "# This is a callback system for parameters. \n# to use:\n#\t- create a function in ParCallbacksExt/ParCallbacks\n#\t  using the same name as the parameter.\n\t\ndef onValueChange(par, val, prev):\n\tcomp = op(me.par.op)\n\tif hasattr(comp, par.name):\n\t\tgetattr(comp, par.name)(par, val, prev)\n\ndef onPulse(par):\n\t#debug(par)\n\tcomp = op(me.par.op)\n\tif hasattr(comp, par.name):\n\t\tgetattr(comp, par.name)(par)\n\ndef onExpressionChange(par, val, prev):\n\tcomp = op(me.par.op)\n\tif hasattr(comp, par.name):\n\t\tgetattr(comp, par.name)(par, val, prev)\n\ndef onExportChange(par, val, prev):\n\tcomp = op(me.par.op)\n\tif hasattr(comp, par.name):\n\t\tgetattr(comp, par.name)(par, val, prev)\n\ndef onEnableChange(par, val, prev):\n\treturn\n\t",
							"dat_content_format": "text"
						}
					]
				}
			]
		},
