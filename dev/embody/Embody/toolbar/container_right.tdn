						}
					]
				},
				{
					"name": "label",
					"type": "containerCOMP",
					"parameters": {
						"w": "=parent().par.Labelwidth",
						"h": "=parent().par.Labelheight",
						"layer": 1,
						"hmode": "=parent.Widget.par.Labelhorizontalmode",
						"hfillweight": "=parent.Widget.par.Labelhfillweight",
						"vmode": "=parent.Widget.par.Labelverticalmode",
						"vfillweight": "=parent.Widget.par.Labelvfillweight",
						"display": "=parent.Widget.par.Labeldisplay",
						"helpdat": "./code/help",
						"uvbuttonsleft": false,
						"bgcolorr": "=parent.Widget.par.Labelbgcolorr",
						"bgcolorg": "=parent.Widget.par.Labelbgcolorg",
						"bgcolorb": "=parent.Widget.par.Labelbgcolorb",
						"bgalpha": "=parent.Widget.par.Labelbgcolora",
						"enablecloning": false
					},
					"custom_pars": {
						"Label": {
							"$t": "label",
							"Widgetlabel": "Momentary Button",
							"Labelfontsize": 9,
							"Labelalignx": "left",
							"Labelaligny": "center",
							"Labeloffsetx": [6, 0],
							"Labelbgcolor": [0.2, 0.2, 0.2, 1],
							"Labelfontcolor": [0.65, 0.65, 0.65, 1],
							"Labelwidth": 120,
							"Labelverticalmode": "fill",
							"Labelheight": 32
						}
					},
					"flags": ["viewer"],
					"position": [200, -200],
					"size": [160, 76],
					"color": [0.5, 0.35, 0.05],
					"tags": ["TDSubComp", "TDPub"],
					"children": [
						{
							"name": "text",
							"type": "textCOMP",
							"parameters": {
								"text": "=parent.Widget.par.Widgetlabel.eval()",
								"type": "multiline",
								"wordwrap": "=parent.Widget.par.Labelwordwrap.eval()",
								"callbacks": "text1_callbacks",
								"font": "=parent.Widget.par.Font.eval()",
								"bold": "=parent.Widget.par.Labelfontbold.eval()",
								"scaletofit": "='onlyshrink' if parent.Widget.par.Labelscaletoolarge.eval() else 'never'",
								"fontsize": "=parent.Widget.par.Labelfontsize.eval() if parent.Widget.par.Labelfontsizemode.eval() in ['points', 'panelunits'] else parent.Widget.par.Labelfontfraction.eval()",
								"fontsizeunits": "=parent.Widget.par.Labelfontsizemode.eval()",
								"fontcolorr": "=parent.Widget.par.Labelfontcolorr.eval()",
								"fontcolorg": "=parent.Widget.par.Labelfontcolorg.eval()",
								"fontcolorb": "=parent.Widget.par.Labelfontcolorb.eval()",
								"fontalpha": "=parent.Widget.par.Labelfontcolora.eval()",
								"textoffsetx": "=parent.Widget.par.Labeloffsetx.eval()",
								"textoffsety": "=parent.Widget.par.Labeloffsety.eval()",
								"textpaddingl": "=parent.Widget.par.Labelpadding1.eval()",
								"textpaddingr": "=parent.Widget.par.Labelpadding2.eval()",
								"textpaddingb": "=parent.Widget.par.Labelpadding3.eval()",
								"textpaddingt": "=parent.Widget.par.Labelpadding4.eval()",
								"alignx": "=parent.Widget.par.Labelalignx.eval()",
								"aligny": "=parent.Widget.par.Labelaligny.eval()",
								"bottomanchor": 0.039,
								"clickthrough": true,
								"top": "=parent.Widget.par.Labeltop.eval()",
