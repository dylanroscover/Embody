						},
						{
							"name": "parexecRunCommand",
							"type": "parameterexecuteDAT",
							"parameters": {
								"fromop": "=me.parent()",
								"op": "=parent.Widget",
								"pars": "Labelhorizontalmode Labelverticalmode",
								"onpulse": false,
								"defaultreadencoding": "cp1252"
							},
							"flags": ["viewer"]
						}
					]
				},
				{
					"name": "output",
					"type": "baseCOMP",
					"custom_pars": {
						"Widget": {
							"$t": "widget_2"
						}
					},
					"flags": ["viewer"],
					"position": [200, 0],
					"children": [
						{
							"name": "dat",
							"type": "outDAT",
							"flags": ["viewer"],
							"position": [400, -600],
							"color": [0.5, 0.05, 0.5],
							"inputs": ["datValues"]
						},
						{
							"name": "chop",
							"type": "outCHOP",
							"parameters": {
								"autoexportroot": "=me.parent()"
							},
							"flags": ["viewer"],
							"position": [200, -300],
							"color": [0.05, 0.5, 0.05],
							"inputs": ["Value0"]
						},
						{
							"name": "Value0",
							"type": "parameterCHOP",
							"position": [0, -300]
						},
						{
							"name": "datValues",
							"type": "evaluateDAT",
							"parameters": {
								"expr": "getattr(parent.Widget.par, ['Valname', 'Value'][me.inputCell.col] + str(me.inputCell.row))"
							},
							"position": [200, -600],
							"color": [0.5, 0.05, 0.5],
							"inputs": ["numValues"]
						},
						{
							"name": "numValues",
							"type": "tableDAT",
							"position": [0, -600]
						},
						{
							"name": "valuesParexec",
							"type": "parameterexecuteDAT",
							"parameters": {
								"fromop": "=parent()",
								"op": "=parent.Widget",
								"pars": "=['Createeditvalueparexec'] + ['Value' + str(i) for i in range(4) if any([getattr(parent.Widget.par, parName, None) for parName in ['Onvaluechangescript' + str(i), 'Ontooffscript' + str(i), 'Offtoonscript' + str(i)]])]",
								"defaultreadencoding": "cp1252"
							},
							"flags": ["viewer"],
							"position": [0, -775],
							"color": [0.75, 0.75, 0.75]
						},
						{
							"name": "valueParOPExec",
