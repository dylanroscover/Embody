    computedat: glsl_ntsc_compute
    outputresolution: custom
    resolutionw: =parent().par.Resw.eval()
    resolutionh: =parent().par.Resh.eval()
  sequences:
    vec:
    - name: uNtsc
      valuex: =parent().par.Bleed.eval()
      valuey: =parent().par.Dotcrawl.eval()
      valuez: =parent().par.Noise.eval()
      valuew: =parent().par.Jitter.eval()
    - name: uScan
      valuex: =parent().par.Scanlines.eval()
      valuey: =parent().par.Bandcount.eval()
      valuez: =parent().par.Hue.eval()
      valuew: =parent().par.Speed.eval()
    - name: uTime
      valuex: =absTime.seconds
      valuey: 0
      valuez: 0
      valuew: 0
- name: comp_bloom
  type: compositeTOP
  parameters:
    operand: add
    outputresolution: custom
    resolutionw: =parent().par.Resw.eval()
    resolutionh: =parent().par.Resh.eval()
    format: rgba16float
