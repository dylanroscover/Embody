operators:
- name: out1
  type: outTOP
  parameters:
    label: =me.name
  flags:
  - viewer
  position: [1500, 0]
  size: [130, 90]
  color: [0.67, 0.67, 0.67]
  inputs:
  - glsl_finish
- name: res_down
  type: resolutionTOP
  parameters:
    outputresolution: custom
    resolutionw: =int(parent().par.Resw.eval()/4)
    resolutionh: =int(parent().par.Resh.eval()/4)
    format: rgba16float
  position: [300, -400]
  size: [130, 90]
  color: [0.67, 0.67, 0.67]
  inputs:
  - glsl_streams
- name: comp_bloom
  type: compositeTOP
  parameters:
    operand: add
    outputresolution: custom
    resolutionw: =parent().par.Resw.eval()
    resolutionh: =parent().par.Resh.eval()
    format: rgba16float
  position: [900, 0]
  size: [130, 90]
  color: [0.67, 0.67, 0.67]
  inputs:
  - glsl_streams
  - glsl_bloomblur
- name: glsl_finish
  type: glslTOP
  parameters:
    pixeldat: glsl_finish_pixel
    computedat: glsl_finish_compute
  sequences:
    vec:
    - name: uFin
      valuex: =parent().par.Grain.eval()
      valuey: =parent().par.Vignette.eval()
      valuez: =parent().par.Streams.eval()
      valuew: =absTime.seconds
    - valuex: 1
      valuey: 1
      valuez: 1
      valuew: 1
    - valuex: 1
      valuey: 1
      valuez: 1
      valuew: 1
    - valuex: 1
      valuey: 1
      valuez: 1
      valuew: 1
    - valuex: 1
      valuey: 1
      valuez: 1
      valuew: 1
    - valuex: 1
      valuey: 1
      valuez: 1
      valuew: 1
    - valuex: 1
      valuey: 1
      valuez: 1
      valuew: 1
    - valuex: 1
      valuey: 1
      valuez: 1
      valuew: 1
  position: [1200, 0]
  inputs:
  - comp_bloom
- name: glsl_streams
  type: glslTOP
  parameters:
    pixeldat: glsl_streams_pixel
    computedat: glsl_streams_compute
    outputresolution: custom
    resolutionw: =parent().par.Resw.eval()
    resolutionh: =parent().par.Resh.eval()
  sequences:
    vec:
    - name: uChan
      valuex: =parent().par.Streams.eval()
      valuey: =parent().par.Gutter.eval()
      valuez: =parent().par.Edgeglow.eval()
      valuew: =parent().par.Celldensity.eval()
    - name: uFlow
      valuex: =parent().par.Flowspeed.eval()
      valuey: =parent().par.Filaments.eval()
      valuez: =parent().par.Shimmer.eval()
      valuew: =absTime.seconds*parent().par.Flowspeed.eval()
    - name: uLook
      valuex: =parent().par.Ptprate.eval()
      valuey: =parent().par.Syncline.eval()
      valuez: =parent().par.Brightness.eval()
      valuew: =absTime.seconds
    - valuex: 1
      valuey: 1
      valuez: 1
      valuew: 1
    - valuex: 1
      valuey: 1
      valuez: 1
      valuew: 1
    - valuex: 1
      valuey: 1
      valuez: 1
      valuew: 1
    - valuex: 1
      valuey: 1
      valuez: 1
      valuew: 1
    - valuex: 1
      valuey: 1
      valuez: 1
      valuew: 1
- name: glsl_bloomblur
  type: glslTOP
  parameters:
    pixeldat: glsl_bloomblur_pixel
    computedat: glsl_bloomblur_compute
    outputresolution: custom
    resolutionw: =int(parent().par.Resw.eval()/4)
    resolutionh: =int(parent().par.Resh.eval()/4)
  sequences:
    vec:
    - name: uBloom
      valuex: =parent().par.Bloom.eval()
      valuey: 0.55
      valuez: =parent().par.Bloomwidth.eval()
    - valuex: 1
      valuey: 1
      valuez: 1
      valuew: 1
    - valuex: 1
      valuey: 1
      valuez: 1
      valuew: 1
    - valuex: 1
