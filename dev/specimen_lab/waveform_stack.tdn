options:
  include_dat_content: false
  include_storage: true
type_defaults:
  resolutionTOP:
    parameters:
      outputresolution: custom
      format: rgba16float
    size: [130, 90]
    color: [0.67, 0.67, 0.67]
  compositeTOP:
    size: [130, 90]
    color: [0.67, 0.67, 0.67]
  glslTOP:
    parameters:
      outputresolution: custom
      format: rgba16float
    size: [130, 90]
    color: [0.67, 0.67, 0.67]
  infoDAT:
    flags:
    - viewer
