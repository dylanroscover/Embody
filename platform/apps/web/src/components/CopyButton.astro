---
interface Props {
  text?: string;
  targetId?: string;
  ariaLabel?: string;
  class?: string;
}

const {
  text,
  targetId,
  ariaLabel = "copy to clipboard",
  class: className = ""
} = Astro.props;
---

<button
  type="button"
  class:list={["copy-button", className]}
  data-copy={text}
  data-copy-target={targetId}
  data-copy-aria={ariaLabel}
  aria-label={ariaLabel}
  title={ariaLabel}
>
  <svg class="copy-icon copy-icon--copy" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <rect x="9" y="9" width="11" height="11" rx="2" />
    <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
  </svg>
  <svg class="copy-icon copy-icon--check" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M20 6 9 17l-5-5" />
  </svg>
  <span class="sr-only">copy</span>
</button>
