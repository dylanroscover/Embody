---
import { env } from "cloudflare:workers";
import type { SpecimenDetail } from "@embody/contracts";
import { TdnViewer } from "@embody/tdn-viewer";
import CopyButton from "../../components/CopyButton.astro";
import CopyTdnEnvelopeButton from "../../components/CopyTdnEnvelopeButton";
import Base from "../../layouts/Base.astro";
import {
  findFixtureSpecimen,
  firstFixtureSpecimen,
  type FixtureSpecimen
} from "../../lib/specimenFallback";
import { sampleTdn } from "../../fixtures/sample-tdn";
import { getCurrentTdnBlobForSlug, getSpecimenBySlug } from "../../server/db";
import { getTdn } from "../../server/r2";

export const prerender = false;

type DisplaySpecimen = {
  slug: string;
  name: string;
  category: string;
  difficulty: string;
  description: string;
  requires: string;
  operator_count: number;
  key_ops: string[];
  prompt: string;
  current_version?: number;
};

const fallback = firstFixtureSpecimen();
const slug = Astro.params.slug ?? fallback.slug;
const fixtureSpecimen = findFixtureSpecimen(slug) ?? fallback;
let specimen = specimenFromFixture(fixtureSpecimen);
let tdn: Record<string, unknown> = sampleTdn;

try {
  const liveSpecimen = await getSpecimenBySlug(env.DB, slug);
  if (liveSpecimen) {
    specimen = specimenFromLive(liveSpecimen, fixtureSpecimen);
  }
} catch {
  specimen = specimenFromFixture(fixtureSpecimen);
}

try {
  const blob = await getCurrentTdnBlobForSlug(env.DB, specimen.slug);
  if (blob) {
    const rawBlob = await getTdn(env.BLOBS, blob.key);
    const parsedTdn = parseTdnObject(rawBlob);
    if (parsedTdn) {
      tdn = parsedTdn;
    }
  }
} catch {
  tdn = sampleTdn;
}

const keyOps = specimen.key_ops.length > 0 ? specimen.key_ops : collectOperatorTypes(tdn);
const rawTdn = JSON.stringify(tdn, null, 2);
const embodyPrompt = `embody the ${specimen.slug} specimen into my project`;

function specimenFromFixture(fixture: FixtureSpecimen): DisplaySpecimen {
  return {
    slug: fixture.slug,
    name: fixture.name,
    category: fixture.category,
    difficulty: fixture.difficulty,
    description: fixture.description,
    requires: fixture.requires,
    operator_count: fixture.operator_count,
    key_ops: fixture.key_ops,
    prompt: fixture.prompt
  };
}

function specimenFromLive(
  live: SpecimenDetail,
  fixture: FixtureSpecimen | undefined
): DisplaySpecimen {
  return {
    slug: live.slug,
    name: live.name,
    category: live.category,
    difficulty: live.difficulty,
    description: live.description,
    requires: live.requires,
    operator_count: live.op_count,
    key_ops: fixture?.key_ops ?? [],
    prompt: fixture?.prompt ?? `Embody the ${live.slug} specimen into my project.`,
    current_version: live.current_version
  };
}

function parseTdnObject(value: string | null): Record<string, unknown> | null {
  if (!value) return null;

  try {
    const parsed = JSON.parse(value) as unknown;
    if (parsed && typeof parsed === "object" && !Array.isArray(parsed)) {
      return parsed as Record<string, unknown>;
    }
  } catch {
    return null;
  }

  return null;
}

function collectOperatorTypes(value: unknown): string[] {
  const seen = new Set<string>();
  collectOperatorTypesInto(value, seen);
  return [...seen].slice(0, 6);
}

function collectOperatorTypesInto(value: unknown, seen: Set<string>): void {
  if (!value || typeof value !== "object" || Array.isArray(value)) return;

  const record = value as Record<string, unknown>;
  if (typeof record.type === "string" && record.type.trim()) {
    seen.add(record.type);
  }

  for (const key of ["operators", "children"] as const) {
    const children = record[key];
    if (!Array.isArray(children)) continue;
    for (const child of children) {
      collectOperatorTypesInto(child, seen);
    }
  }
}
---

<Base
  title={`${specimen.name} - embody.tools`}
  description={specimen.description}
>
  <section class="page-section detail-hero">
    <p class="eyebrow">Specimen / {specimen.category}</p>
    <h1>{specimen.name}</h1>
    <p class="lede">{specimen.description}</p>
    <div class="badge-row">
      <span class="badge">{specimen.difficulty}</span>
      <span class:list={["badge", specimen.requires === "none" ? "stock" : "needs"]}>
        {specimen.requires === "none" ? "stock TD" : `needs ${specimen.requires}`}
      </span>
      <span class="badge">{specimen.operator_count} operators</span>
    </div>
  </section>

  <section class="page-section tight specimen-layout">
    <div class="viewer-panel pillar">
      <div class="panel-head">
        <div>
          <p class="eyebrow">Node graph preview</p>
          <h2>{specimen.name} graph</h2>
        </div>
        <span class="badge stock">inert preview</span>
      </div>
      <TdnViewer tdn={tdn} client:load />
    </div>

    <aside class="specimen-sidebar">
      <section class="side-block pillar">
        <p class="eyebrow">Key ops</p>
        <div class="op-list">
          {keyOps.map((opName) => <span>{opName}</span>)}
        </div>
      </section>

      <section class="side-block pillar">
        <p class="eyebrow">Example prompt</p>
        <div class="copy-shell">
          <p class="copy-shell__text">{specimen.prompt}</p>
          <CopyButton text={specimen.prompt} ariaLabel={`Copy ${specimen.name} example prompt`} />
        </div>
      </section>

      <section class="side-block embody-block pillar">
        <p class="eyebrow">How to embody it</p>
        <div class="copy-shell">
          <p>Tell your agent:</p>
          <p class="copy-shell__text">{embodyPrompt}</p>
          <CopyButton text={embodyPrompt} ariaLabel={`Copy embody command for ${specimen.name}`} />
        </div>
      </section>
    </aside>
  </section>

  <section class="page-section tight raw-section">
    <details class="raw-details pillar">
      <summary>Show raw TDN JSON</summary>
      <CopyTdnEnvelopeButton
        tdn={tdn}
        slug={specimen.slug}
        version={specimen.current_version}
        className="copy-button--corner"
        client:load
      />
      <p class="raw-copy-hint">Paste in TouchDesigner with Embody running.</p>
      <pre id="raw-tdn-json"><code>{rawTdn}</code></pre>
    </details>
  </section>
</Base>

<style>
  .detail-hero {
    padding-bottom: 48px;
  }

  .specimen-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 330px;
    gap: 20px;
    align-items: start;
  }

  .viewer-panel,
  .side-block,
  details {
    border: 1px solid var(--border-faint);
    border-radius: var(--radius);
    background: var(--bg-elevated);
  }

  .viewer-panel {
    padding: 18px;
  }

  .panel-head {
    display: flex;
    align-items: start;
    justify-content: space-between;
    gap: 18px;
    margin-bottom: 18px;
  }

  .panel-head h2 {
    margin-bottom: 0;
    font-size: clamp(24px, 3vw, 38px);
  }

  .specimen-sidebar {
    display: grid;
    gap: 14px;
  }

  .side-block {
    padding: 18px;
  }

  .side-block p {
    color: var(--text-muted);
    line-height: 1.45;
  }

  .op-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .op-list span {
    border: 1px solid var(--border-faint);
    border-radius: var(--radius-sm);
    background: rgba(40, 48, 40, 0.54);
    padding: 8px 10px;
    color: var(--text);
    font: 600 12px/1 var(--font-mono);
  }

  .embody-block {
    border-color: var(--border);
  }

  details {
    position: relative;
    overflow: hidden;
  }

  summary {
    cursor: pointer;
    padding: 18px 7.4rem 18px 18px;
    color: var(--accent);
    font: 600 13px/1 var(--font-mono);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .raw-copy-hint {
    margin: -6px 18px 14px;
    color: var(--text-faint);
    font: 12px/1.4 var(--font-mono);
  }

  pre {
    max-height: 520px;
    margin: 0;
    overflow: auto;
    border: 0;
    border-top: 1px solid var(--border-faint);
    border-radius: 0;
    background: var(--bg-code);
    padding: 18px;
    color: var(--text);
    font: 12px/1.55 var(--font-mono);
  }

  @media (max-width: 920px) {
    .specimen-layout {
      grid-template-columns: 1fr;
    }
  }
</style>
