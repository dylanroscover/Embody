---
import { env } from "cloudflare:workers";
import { SUBMIT_CATEGORIES, SUBMIT_LEVELS, SUBMIT_LICENSES, SUBMIT_REQUIRE_GROUPS } from "@embody/contracts";
import Base from "../../../layouts/Base.astro";
import TdnYamlEditor from "../../../components/TdnYamlEditor";
import { getCurrentTdnBlobForSlug, getSpecimenForEdit } from "../../../server/db";
import { getTdn } from "../../../server/r2";

export const prerender = false;

const slug = Astro.params.slug ?? "";

// Real session gate: unauthenticated visitors go to sign-in and bounce back.
const user = Astro.locals.user;
if (!user) {
  return Astro.redirect(`/signin?next=${encodeURIComponent(`/c/${slug}/edit`)}`);
}

const specimen = await getSpecimenForEdit(env.DB, slug);
if (!specimen) {
  return Astro.redirect("/collection");
}

// Ownership is by author_id (the authoritative key). Non-owners are bounced to
// the read-only specimen page. The API enforces this again on PUT.
if (specimen.authorId !== user.id) {
  return Astro.redirect(`/c/${slug}`);
}

// Pre-fill the editor with the current network text (raw TDN exactly as stored).
let currentTdn = "";
try {
  // user.id (ownership verified above) so a private draft's network prefills too.
  const blob = await getCurrentTdnBlobForSlug(env.DB, slug, user.id);
  if (blob) currentTdn = (await getTdn(env.BLOBS, blob.key)) ?? "";
} catch {
  currentTdn = "";
}

const levelOptions = SUBMIT_LEVELS;
// Offer the whitelist PLUS any category this specimen already carries that the
// current taxonomy no longer lists, so editing never silently drops (or blocks
// saving) a legacy/retired category. Stored extras sort after the whitelist.
const categoryOptions = [
  ...SUBMIT_CATEGORIES,
  ...specimen.categories.filter((c) => !SUBMIT_CATEGORIES.includes(c))
];
const requireGroups = SUBMIT_REQUIRE_GROUPS;
const tagsValue = specimen.tags.join(", ");
// License dropdown options. If the specimen carries a legacy license outside the
// current whitelist (e.g. a bare "CC-BY"), prepend it so the edit never silently
// changes it -- the server also accepts the existing value through.
const currentLicense = specimen.license || "CC-BY-4.0";
const licenseOptions = SUBMIT_LICENSES.some((l) => l.value === currentLicense)
  ? SUBMIT_LICENSES
  : [{ value: currentLicense, label: `${currentLicense} (current)` }, ...SUBMIT_LICENSES];
const currentLicenseLabel =
  licenseOptions.find((l) => l.value === currentLicense)?.label ?? currentLicense;
---

<Base
  title={`edit ${specimen.title} - embody.tools`}
  description={`Edit your specimen "${specimen.title}".`}
>
  <section class="page-section submit">
    <p class="eyebrow">edit specimen</p>
    <h1>edit {specimen.title}</h1>
    <p class="lede">
      Update your specimen's details and network. Editing the TDN re-runs the
      capability scan and saves a new version of the network.
    </p>

    <form class="submit-form" data-edit-form data-slug={specimen.slug} data-tdn-prefilled={currentTdn.trim() ? "1" : "0"} novalidate>
      <div class="submit-cols">
      <div class="submit-col submit-col--fields">
      <label class="submit-field">
        <span>title</span>
        <input type="text" name="title" required maxlength="160" value={specimen.title} />
        <small class="submit-error" data-error-for="title" role="alert"></small>
      </label>
      <label class="submit-field">
        <span>description</span>
        <textarea name="description" rows="3" maxlength="4000">{specimen.description}</textarea>
      </label>
      <label class="submit-field">
        <span>tags <em>(comma separated)</em></span>
        <input type="text" name="tags" value={tagsValue} placeholder="feedback, generative, TOP" />
      </label>
      <div class="submit-row">
      <div class="submit-field">
        <span class="submit-field__label" id="ddlbl-level">level</span>
        <div class="dd" data-dd>
          <button type="button" class="dd__btn" aria-haspopup="listbox" aria-expanded="false" aria-labelledby="ddlbl-level dd-val-level">
            <span class="dd__val" id="dd-val-level">{specimen.level}</span>
            <svg class="dd__chev" width="10" height="6" viewBox="0 0 10 6" fill="none" aria-hidden="true"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.4" /></svg>
          </button>
          <ul class="dd__menu" role="listbox" aria-labelledby="ddlbl-level" hidden>
            {levelOptions.map((value) => (
              <li class="dd__opt" role="option" data-value={value} aria-selected={value === specimen.level ? "true" : "false"}>{value}</li>
            ))}
          </ul>
          <select class="dd__native" name="level" aria-hidden="true" tabindex="-1">
            {levelOptions.map((value) => (
              <option value={value} selected={value === specimen.level}>{value}</option>
            ))}
          </select>
        </div>
      </div>
      <div class="submit-field">
        <span class="submit-field__label" id="ddlbl-categories">categories <em>(max 3)</em></span>
        <div class="msdd" data-msdd data-msdd-max="3">
          <button type="button" class="dd__btn msdd__btn" aria-haspopup="dialog" aria-expanded="false" aria-labelledby="ddlbl-categories msdd-summary-categories" data-msdd-toggle>
            <span class="dd__val msdd__summary" id="msdd-summary-categories" data-msdd-summary>none</span>
            <svg class="dd__chev" width="10" height="6" viewBox="0 0 10 6" fill="none" aria-hidden="true"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.4" /></svg>
          </button>
          <div class="msdd__panel" data-msdd-panel hidden>
            <input class="msdd__search" type="search" placeholder="" aria-label="Search categories" data-msdd-search />
            <div class="msdd__group" data-msdd-group>
              {categoryOptions.map((value) => (
                <label class="msdd__opt" data-msdd-opt data-label={value.toLowerCase()}>
                  <input type="checkbox" name="categories" value={value} checked={specimen.categories.includes(value)} data-msdd-checkbox />
                  <span class="msdd__opt-label">{value}</span>
                </label>
              ))}
            </div>
            <p class="msdd__empty" data-msdd-empty hidden>no matches.</p>
          </div>
        </div>
      </div>
      <div class="submit-field">
        <span class="submit-field__label" id="ddlbl-requires">requires</span>
        <div class="msdd" data-msdd>
          <button type="button" class="dd__btn msdd__btn" aria-haspopup="dialog" aria-expanded="false" aria-labelledby="ddlbl-requires msdd-summary-requires" data-msdd-toggle>
            <span class="dd__val msdd__summary" id="msdd-summary-requires" data-msdd-summary>none</span>
            <svg class="dd__chev" width="10" height="6" viewBox="0 0 10 6" fill="none" aria-hidden="true"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.4" /></svg>
          </button>
          <div class="msdd__panel" data-msdd-panel hidden>
            <input class="msdd__search" type="search" placeholder="" aria-label="Search requirements" data-msdd-search />
            {requireGroups.map((g) => (
              <div class="msdd__group" data-msdd-group>
                <p class="msdd__group-label">{g.group}</p>
                {g.items.map((item) => (
                  <label class="msdd__opt" data-msdd-opt data-label={item.toLowerCase()}>
                    <input type="checkbox" name="requires" value={item} checked={specimen.requires.includes(item)} data-msdd-checkbox />
                    <span class="msdd__opt-label">{item}</span>
                  </label>
                ))}
              </div>
            ))}
            <p class="msdd__empty" data-msdd-empty hidden>no matches.</p>
          </div>
        </div>
      </div>
      </div>
      <div class="submit-field">
        <span class="submit-field__label" id="ddlbl-license">license</span>
        <div class="dd" data-dd>
          <button type="button" class="dd__btn" aria-haspopup="listbox" aria-expanded="false" aria-labelledby="ddlbl-license dd-val-license">
            <span class="dd__val" id="dd-val-license">{currentLicenseLabel}</span>
            <svg class="dd__chev" width="10" height="6" viewBox="0 0 10 6" fill="none" aria-hidden="true"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.4" /></svg>
          </button>
          <ul class="dd__menu" role="listbox" aria-labelledby="ddlbl-license" hidden>
            {licenseOptions.map((l) => (
              <li class="dd__opt" role="option" data-value={l.value} aria-selected={l.value === currentLicense ? "true" : "false"}>{l.label}</li>
            ))}
          </ul>
          <select class="dd__native" name="license" aria-hidden="true" tabindex="-1">
            {licenseOptions.map((l) => (
              <option value={l.value} selected={l.value === currentLicense}>{l.label}</option>
            ))}
          </select>
        </div>
      </div>
      <label class="submit-field">
        <span>thumbnail <em>(optional - replaces the current cover, resized to 640x360)</em></span>
        <span class="submit-file" data-file>
          <input type="file" name="thumbnail" accept="image/png,image/jpeg,image/webp" class="submit-file__input" data-file-input />
          <span class="submit-file__btn" aria-hidden="true">choose image</span>
          <span class="submit-file__name" data-file-name>keep current</span>
        </span>
      </label>
      </div>

      <div class="submit-col submit-col--tdn">
      <div class="submit-field submit-field--editor">
        <span>TDN (YAML)</span>
        <small class="submit-hint">
          edit the network directly. saving a changed TDN re-runs the capability scan and creates a new version.
        </small>
        <TdnYamlEditor client:load name="tdn" initialValue={currentTdn} />
      </div>
      </div>
      <div class="submit-footer">
        <p class="submit-status" data-edit-status role="status"></p>
        <button type="submit" class="btn btn--primary submit-go" data-edit-go aria-disabled="true">
          save changes
        </button>
      </div>
      </div>
    </form>

    <p class="submit-back">
      <a href={`/c/${specimen.slug}`}>cancel and return to the specimen</a>
    </p>
  </section>
</Base>

<script>
  // Owner edit. PUTs the form to /api/specimens/:slug; on success returns to the
  // specimen page. Includes the (editable) TDN body -- a changed network re-runs
  // the capability scan + saves a new version server-side.
  const form = document.querySelector("[data-edit-form]") as HTMLFormElement | null;
  const statusBox = document.querySelector("[data-edit-status]") as HTMLElement | null;
  const goBtn = document.querySelector("[data-edit-go]") as HTMLButtonElement | null;

  function setStatus(message: string, kind: "pending" | "ok" | "error") {
    if (!statusBox) return;
    statusBox.textContent = message;
    statusBox.dataset.kind = kind;
  }

  // Mirror the chosen filename into the styled file row (the real <input> is
  // visually hidden). data-has-file switches it from faint placeholder to text.
  const fileInput = document.querySelector("[data-file-input]") as HTMLInputElement | null;
  const fileName = document.querySelector("[data-file-name]") as HTMLElement | null;
  fileInput?.addEventListener("change", () => {
    if (!fileName) return;
    const picked = fileInput.files && fileInput.files[0];
    fileName.textContent = picked ? picked.name : "keep current";
    if (picked) fileName.setAttribute("data-has-file", "");
    else fileName.removeAttribute("data-has-file");
  });

  // Resize a chosen thumbnail to a 640x360 (16:9) cover-cropped WebP on the
  // client, so a multi-MB original never gets uploaded for a small card slot.
  // The API + R2 also enforce WebP + a byte cap as defense in depth.
  async function thumbDataUrl(file: File): Promise<string> {
    const bitmap = await createImageBitmap(file);
    const W = 640;
    const H = 360;
    const canvas = document.createElement("canvas");
    canvas.width = W;
    canvas.height = H;
    const ctx = canvas.getContext("2d");
    if (!ctx) throw new Error("canvas unavailable");
    // cover: scale to fill the 16:9 box, then center-crop the overflow.
    const scale = Math.max(W / bitmap.width, H / bitmap.height);
    const dw = bitmap.width * scale;
    const dh = bitmap.height * scale;
    ctx.drawImage(bitmap, (W - dw) / 2, (H - dh) / 2, dw, dh);
    bitmap.close();
    return canvas.toDataURL("image/webp", 0.82);
  }

  function setFieldError(name: string, message: string) {
    const el = form?.querySelector(`[data-error-for="${name}"]`) as HTMLElement | null;
    if (!el) return;
    el.textContent = message || "";
  }

  function titleEl() {
    return form?.querySelector('[name="title"]') as HTMLInputElement | null;
  }
  function titleMissing() {
    const el = titleEl();
    return !el || !String(el.value || "").trim();
  }

  // The TDN editor (React island) validates on every edit and broadcasts a
  // bubbling `tdn:change` with its validity, so "save changes" stays greyed while
  // the network is unparseable. Seed the flag from the SERVER-prefilled content
  // (data-tdn-prefilled): the stored network was already valid when saved, so a
  // rename that never touches the editor still passes the gate even if the
  // island's mount event fires before this listener attaches (a race that would
  // otherwise leave the button permanently greyed and silently block saves).
  let tdnValid = form?.dataset.tdnPrefilled === "1";
  form?.addEventListener("tdn:change", (event) => {
    tdnValid = Boolean((event as CustomEvent).detail?.valid);
    refreshReady();
  });

  function isReady() {
    return !titleMissing() && tdnValid;
  }
  function refreshReady() {
    if (!goBtn) return;
    goBtn.setAttribute("aria-disabled", isReady() ? "false" : "true");
  }
  form?.addEventListener("input", () => {
    if (!titleMissing()) setFieldError("title", "");
    refreshReady();
  });
  refreshReady();

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();
    if (!goBtn || !form) return;
    const slug = form.dataset.slug ?? "";
    const data = new FormData(form);

    const title = String(data.get("title") || "").trim();
    if (!isReady()) {
      const probs: string[] = [];
      if (titleMissing()) probs.push("a title");
      if (!tdnValid) probs.push("a valid TDN network");
      setFieldError("title", titleMissing() ? "add a title." : "");
      setStatus(`fix ${probs.join(" and ")} before saving.`, "error");
      return;
    }

    const tags = String(data.get("tags") || "")
      .split(",")
      .map((tag) => tag.trim())
      .filter(Boolean);

    // Categories: at least one is required (max 3 is enforced by the picker).
    const categoriesSel = data.getAll("categories").map(String);
    if (categoriesSel.length === 0) {
      setStatus("choose at least one category.", "error");
      return;
    }

    // Optional replacement thumbnail: resize to a 640x360 WebP on the client, the
    // same as contribute. Omitted from the payload when no new file is chosen, so
    // the server leaves the current cover untouched.
    let thumbnail: string | undefined;
    const thumbFile = data.get("thumbnail");
    if (thumbFile && typeof thumbFile === "object" && "size" in thumbFile && thumbFile.size > 0) {
      if (thumbFile.size > 8_000_000) {
        setStatus("thumbnail source is too large (max 8 MB).", "error");
        return;
      }
      try {
        thumbnail = await thumbDataUrl(thumbFile as File);
      } catch (err) {
        console.error("thumbnail resize failed", err);
        setStatus("could not process the thumbnail image.", "error");
        return;
      }
    }

    const payload = {
      title,
      description: String(data.get("description") || "").trim(),
      tags,
      license: String(data.get("license") || "CC-BY-4.0").trim() || "CC-BY-4.0",
      level: String(data.get("level") || "intermediate"),
      categories: categoriesSel,
      requires: data.getAll("requires").map(String),
      tdn: String(data.get("tdn") || ""),
      ...(thumbnail ? { thumbnail } : {})
    };

    goBtn.disabled = true;
    const original = goBtn.textContent;
    goBtn.textContent = "saving...";
    setStatus("saving changes...", "pending");

    try {
      const res = await fetch(`/api/specimens/${encodeURIComponent(slug)}`, {
        method: "PUT",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload)
      });
      const body = (await res.json().catch(() => ({}))) as { detail?: string; error?: string };
      if (res.status === 401) {
        window.location.assign(`/signin?next=${encodeURIComponent(`/c/${slug}/edit`)}`);
        return;
      }
      if (!res.ok) {
        setStatus(body.detail || body.error || `update failed (${res.status}).`, "error");
        goBtn.disabled = false;
        goBtn.textContent = original;
        return;
      }
      setStatus("saved. returning to your specimen...", "ok");
      window.location.assign(`/c/${slug}`);
    } catch {
      setStatus("something went wrong. please try again.", "error");
      goBtn.disabled = false;
      goBtn.textContent = original;
    }
  });
</script>

<script>
  // App-native dropdowns for the edit form. Each .dd wraps a visually-hidden
  // native <select> (the value the form's FormData reads via
  // data.get("level"/"category"/"requires")) plus a styled trigger + ARIA
  // listbox. The native select is pre-selected to the specimen's CURRENT value
  // (server-rendered), and the .dd__val + aria-selected mirror it, so the
  // initial state shows the existing choice. Choosing an option writes the
  // native select's value and dispatches a 'change' event, so the submitted
  // value tracks the visible choice. Mirrors contribute.astro's [data-dd].

  // One-open-at-a-time across BOTH dropdown systems (.dd single-selects and the
  // .msdd multi-selects). Opening any dropdown broadcasts; the rest close.
  const DD_OPEN_EVENT = "edit:dropdown-open";
  const broadcastDropdownOpen = (source: Element): void => {
    document.dispatchEvent(new CustomEvent(DD_OPEN_EVENT, { detail: { source } }));
  };

  // Multi-select grouped pickers (requires + categories). Checkboxes (server-
  // rendered with the specimen's current selection checked) carry their field
  // name so getAll reads them; the trigger summary reflects the count.
  document.querySelectorAll<HTMLElement>("[data-msdd]").forEach((msdd) => {
    const toggle = msdd.querySelector("[data-msdd-toggle]") as HTMLButtonElement | null;
    const panel = msdd.querySelector("[data-msdd-panel]") as HTMLElement | null;
    const summary = msdd.querySelector("[data-msdd-summary]") as HTMLElement | null;
    const search = msdd.querySelector("[data-msdd-search]") as HTMLInputElement | null;
    const empty = msdd.querySelector("[data-msdd-empty]") as HTMLElement | null;
    const groups = Array.from(msdd.querySelectorAll("[data-msdd-group]")) as HTMLElement[];
    const boxes = Array.from(
      msdd.querySelectorAll("[data-msdd-checkbox]")
    ) as HTMLInputElement[];
    if (!toggle || !panel || !summary) return;
    const tg = toggle;
    const pn = panel;
    const sm = summary;
    // Optional selection cap (e.g. categories allow at most 3). Infinity = no cap.
    const max = Number(msdd.getAttribute("data-msdd-max")) || Infinity;
    let open = false;

    const refresh = (): void => {
      const picked = boxes.filter((b) => b.checked).map((b) => b.value);
      sm.textContent =
        picked.length === 0
          ? "none"
          : picked.length === 1
            ? picked[0] ?? ""
            : `${picked.length} selected`;
      // At the cap, lock the remaining unchecked boxes; unlock below the cap.
      if (Number.isFinite(max)) {
        const atCap = picked.length >= max;
        boxes.forEach((b) => { b.disabled = atCap && !b.checked; });
      }
    };
    const applyFilter = (q: string): void => {
      const needle = q.trim().toLowerCase();
      let anyVisible = false;
      groups.forEach((g) => {
        // A group-name match (e.g. "depth") reveals the whole group.
        const groupLabel = (g.querySelector(".msdd__group-label")?.textContent || "").toLowerCase();
        const groupMatch = needle.length > 0 && groupLabel.includes(needle);
        let groupVisible = false;
        g.querySelectorAll<HTMLElement>("[data-msdd-opt]").forEach((opt) => {
          const match = !needle || groupMatch || (opt.getAttribute("data-label") || "").includes(needle);
          opt.hidden = !match;
          if (match) groupVisible = true;
        });
        g.hidden = !groupVisible;
        if (groupVisible) anyVisible = true;
      });
      if (empty) empty.hidden = anyVisible;
    };
    const setOpen = (next: boolean): void => {
      open = next;
      pn.hidden = !next;
      tg.setAttribute("aria-expanded", next ? "true" : "false");
      if (next) {
        broadcastDropdownOpen(msdd);
        if (search) search.focus();
      }
    };

    tg.addEventListener("click", (e) => {
      e.stopPropagation();
      setOpen(!open);
    });
    // Close when any OTHER dropdown opens.
    document.addEventListener(DD_OPEN_EVENT, (e) => {
      if ((e as CustomEvent).detail?.source !== msdd) setOpen(false);
    });
    search?.addEventListener("input", () => applyFilter(search.value));
    boxes.forEach((b) => b.addEventListener("change", refresh));
    document.addEventListener("click", (e) => {
      if (!msdd.contains(e.target as Node)) setOpen(false);
    });
    msdd.addEventListener("keydown", (e) => {
      if ((e as KeyboardEvent).key === "Escape") {
        setOpen(false);
        tg.focus();
      }
    });
    refresh();
  });

  const closeDropdown = (dd: Element): void => {
    dd.removeAttribute("data-open");
    const menu = dd.querySelector(".dd__menu");
    if (menu) (menu as HTMLElement).hidden = true;
    const button = dd.querySelector(".dd__btn");
    if (button) button.setAttribute("aria-expanded", "false");
  };

  // Unique id seed so every option across the dropdowns gets a stable id for
  // aria-activedescendant (the listbox points at the active option's id).
  let ddOptSeq = 0;
  const dropdowns = Array.from(document.querySelectorAll(".dd[data-dd]"));

  dropdowns.forEach((dd) => {
    const btn = dd.querySelector(".dd__btn") as HTMLButtonElement | null;
    const menu = dd.querySelector(".dd__menu") as HTMLElement | null;
    const valEl = dd.querySelector(".dd__val") as HTMLElement | null;
    const native = dd.querySelector(".dd__native") as HTMLSelectElement | null;
    const opts = Array.from(dd.querySelectorAll(".dd__opt")) as HTMLElement[];
    if (!btn || !menu || !valEl || !native) return;

    // Optional search filter (present only on dropdowns with a .dd__search).
    const ddSearch = dd.querySelector(".dd__search") as HTMLInputElement | null;
    const ddEmpty = dd.querySelector(".dd__empty") as HTMLElement | null;
    const filterOpts = (q: string): void => {
      const needle = q.trim().toLowerCase();
      let any = false;
      opts.forEach((o) => {
        const match = !needle || (o.textContent || "").toLowerCase().includes(needle);
        o.hidden = !match;
        if (match) any = true;
      });
      if (ddEmpty) ddEmpty.hidden = any;
    };
    if (ddSearch) {
      ddSearch.addEventListener("input", () => filterOpts(ddSearch.value));
      ddSearch.addEventListener("keydown", (e: KeyboardEvent) => {
        if (e.key === "Enter") e.preventDefault();
        else if (e.key === "Escape") {
          e.preventDefault();
          closeDropdown(dd);
          btn.focus();
        }
      });
      ddSearch.addEventListener("click", (e) => e.stopPropagation());
    }

    // Give every option a stable id so the listbox can name the ACTIVE option
    // via aria-activedescendant (focus stays on the button; this is how a
    // screen reader announces the highlighted option without moving DOM focus).
    opts.forEach((opt) => {
      if (!opt.id) opt.id = `dd-opt-${ddOptSeq++}`;
    });

    // The active (keyboard-highlighted) option index. -1 == none highlighted.
    let active = -1;
    const setActive = (index: number): void => {
      const next = Math.max(0, Math.min(index, opts.length - 1));
      const opt = opts[next];
      if (!opt) return;
      opts.forEach((o, i) => o.classList.toggle("is-active", i === next));
      active = next;
      menu.setAttribute("aria-activedescendant", opt.id);
      opt.scrollIntoView({ block: "nearest" });
    };
    const clearActive = (): void => {
      active = -1;
      opts.forEach((o) => o.classList.remove("is-active"));
      menu.removeAttribute("aria-activedescendant");
    };

    const open = (highlightSelected = true): void => {
      broadcastDropdownOpen(dd);
      dd.setAttribute("data-open", "");
      menu.hidden = false;
      btn.setAttribute("aria-expanded", "true");
      if (ddSearch) { ddSearch.value = ""; filterOpts(""); }
      if (highlightSelected) {
        // Open with the currently-selected option highlighted (or the first).
        const sel = opts.findIndex((o) => o.getAttribute("aria-selected") === "true");
        setActive(sel >= 0 ? sel : 0);
      }
    };
    const close = (): void => {
      clearActive();
      closeDropdown(dd);
    };
    const choose = (opt: HTMLElement): void => {
      if (opt.hidden) return;
      native.value = opt.getAttribute("data-value") || "";
      native.dispatchEvent(new Event("change", { bubbles: true }));
      valEl.textContent = opt.textContent;
      opts.forEach((o) => o.setAttribute("aria-selected", String(o === opt)));
      close();
      btn.focus();
    };

    btn.addEventListener("click", () => {
      if (dd.hasAttribute("data-open")) close();
      else open();
    });
    // Close when any OTHER dropdown opens (sibling .dd or an .msdd picker).
    document.addEventListener(DD_OPEN_EVENT, (e) => {
      if ((e as CustomEvent).detail?.source !== dd) close();
    });
    btn.addEventListener("keydown", (e: KeyboardEvent) => {
      const isOpen = dd.hasAttribute("data-open");
      switch (e.key) {
        case "Escape":
          if (isOpen) {
            e.preventDefault();
            close();
            btn.focus();
          }
          return;
        case "Tab":
          // Tab moves focus away -- close without swallowing the Tab.
          if (isOpen) close();
          return;
        case "Enter":
        case " ": {
          e.preventDefault();
          if (!isOpen) {
            open();
            return;
          }
          const activeOpt = active >= 0 ? opts[active] : undefined;
          if (activeOpt) choose(activeOpt);
          return;
        }
        case "ArrowDown":
          e.preventDefault();
          if (!isOpen) {
            open();
            return;
          }
          setActive(active < 0 ? 0 : active + 1);
          return;
        case "ArrowUp":
          e.preventDefault();
          if (!isOpen) {
            open();
            return;
          }
          setActive(active < 0 ? opts.length - 1 : active - 1);
          return;
        case "Home":
          if (isOpen) {
            e.preventDefault();
            setActive(0);
          }
          return;
        case "End":
          if (isOpen) {
            e.preventDefault();
            setActive(opts.length - 1);
          }
          return;
        default:
          return;
      }
    });

    // Pointer: hover syncs the active highlight so mouse + keyboard agree.
    opts.forEach((opt, i) => {
      opt.addEventListener("click", () => choose(opt));
      opt.addEventListener("mousemove", () => setActive(i));
    });
  });

  document.addEventListener("click", (e: MouseEvent) => {
    const target = e.target instanceof Node ? e.target : null;
    dropdowns.forEach((dd) => {
      if (dd.hasAttribute("data-open") && (target === null || !dd.contains(target))) {
        closeDropdown(dd);
      }
    });
  });
  document.addEventListener("keydown", (e: KeyboardEvent) => {
    if (e.key === "Escape") dropdowns.forEach((dd) => closeDropdown(dd));
  });
</script>

