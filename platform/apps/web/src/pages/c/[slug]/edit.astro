---
import { env } from "cloudflare:workers";
import { SUBMIT_CATEGORIES, SUBMIT_DIFFICULTIES, SUBMIT_REQUIRES } from "@embody/contracts";
import Base from "../../../layouts/Base.astro";
import TdnYamlEditor from "../../../components/TdnYamlEditor";
import { getCurrentTdnBlobForSlug, getSpecimenForEdit } from "../../../server/db";
import { getTdn } from "../../../server/r2";

export const prerender = false;

const slug = Astro.params.slug ?? "";

// Real session gate: unauthenticated visitors go to sign-in and bounce back.
const user = Astro.locals.user;
if (!user) {
  return Astro.redirect(`/signin?next=${encodeURIComponent(`/c/${slug}/edit`)}`);
}

const specimen = await getSpecimenForEdit(env.DB, slug);
if (!specimen) {
  return Astro.redirect("/collection");
}

// Ownership is by author_id (the authoritative key). Non-owners are bounced to
// the read-only specimen page. The API enforces this again on PUT.
if (specimen.authorId !== user.id) {
  return Astro.redirect(`/c/${slug}`);
}

// Pre-fill the editor with the current network text (raw TDN exactly as stored).
let currentTdn = "";
try {
  const blob = await getCurrentTdnBlobForSlug(env.DB, slug);
  if (blob) currentTdn = (await getTdn(env.BLOBS, blob.key)) ?? "";
} catch {
  currentTdn = "";
}

const difficultyOptions = SUBMIT_DIFFICULTIES;
const categoryOptions = SUBMIT_CATEGORIES;
const requiresOptions = SUBMIT_REQUIRES;
const tagsValue = specimen.tags.join(", ");
---

<Base
  title={`edit ${specimen.title} - embody.tools`}
  description={`Edit your specimen "${specimen.title}".`}
>
  <section class="page-section submit">
    <p class="eyebrow">edit specimen</p>
    <h1>edit {specimen.title}</h1>
    <p class="lede">
      Update your specimen's details and network. Editing the TDN re-runs the
      capability scan and saves a new version of the network.
    </p>

    <form class="submit-form" data-edit-form data-slug={specimen.slug} novalidate>
      <div class="submit-cols">
      <div class="submit-col submit-col--fields">
      <label class="submit-field">
        <span>title</span>
        <input type="text" name="title" required maxlength="160" value={specimen.title} />
        <small class="submit-error" data-error-for="title" role="alert"></small>
      </label>
      <label class="submit-field">
        <span>description</span>
        <textarea name="description" rows="3" maxlength="4000">{specimen.description}</textarea>
      </label>
      <label class="submit-field">
        <span>tags <em>(comma separated)</em></span>
        <input type="text" name="tags" value={tagsValue} placeholder="feedback, generative, TOP" />
      </label>
      <div class="submit-row">
      <div class="submit-field">
        <span class="submit-field__label" id="ddlbl-difficulty">difficulty</span>
        <div class="dd" data-dd>
          <button type="button" class="dd__btn" aria-haspopup="listbox" aria-expanded="false" aria-labelledby="ddlbl-difficulty dd-val-difficulty">
            <span class="dd__val" id="dd-val-difficulty">{specimen.difficulty}</span>
            <svg class="dd__chev" width="10" height="6" viewBox="0 0 10 6" fill="none" aria-hidden="true"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.4" /></svg>
          </button>
          <ul class="dd__menu" role="listbox" aria-labelledby="ddlbl-difficulty" hidden>
            {difficultyOptions.map((value) => (
              <li class="dd__opt" role="option" data-value={value} aria-selected={value === specimen.difficulty ? "true" : "false"}>{value}</li>
            ))}
          </ul>
          <select class="dd__native" name="difficulty" aria-hidden="true" tabindex="-1">
            {difficultyOptions.map((value) => (
              <option value={value} selected={value === specimen.difficulty}>{value}</option>
            ))}
          </select>
        </div>
      </div>
      <div class="submit-field">
        <span class="submit-field__label" id="ddlbl-category">category</span>
        <div class="dd" data-dd>
          <button type="button" class="dd__btn" aria-haspopup="listbox" aria-expanded="false" aria-labelledby="ddlbl-category dd-val-category">
            <span class="dd__val" id="dd-val-category">{specimen.category}</span>
            <svg class="dd__chev" width="10" height="6" viewBox="0 0 10 6" fill="none" aria-hidden="true"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.4" /></svg>
          </button>
          <ul class="dd__menu" role="listbox" aria-labelledby="ddlbl-category" hidden>
            {categoryOptions.map((value) => (
              <li class="dd__opt" role="option" data-value={value} aria-selected={value === specimen.category ? "true" : "false"}>{value}</li>
            ))}
          </ul>
          <select class="dd__native" name="category" aria-hidden="true" tabindex="-1">
            {categoryOptions.map((value) => (
              <option value={value} selected={value === specimen.category}>{value}</option>
            ))}
          </select>
        </div>
      </div>
      <div class="submit-field">
        <span class="submit-field__label" id="ddlbl-requires">requires</span>
        <div class="dd" data-dd>
          <button type="button" class="dd__btn" aria-haspopup="listbox" aria-expanded="false" aria-labelledby="ddlbl-requires dd-val-requires">
            <span class="dd__val" id="dd-val-requires">{specimen.requires}</span>
            <svg class="dd__chev" width="10" height="6" viewBox="0 0 10 6" fill="none" aria-hidden="true"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.4" /></svg>
          </button>
          <ul class="dd__menu" role="listbox" aria-labelledby="ddlbl-requires" hidden>
            {requiresOptions.map((value) => (
              <li class="dd__opt" role="option" data-value={value} aria-selected={value === specimen.requires ? "true" : "false"}>{value}</li>
            ))}
          </ul>
          <select class="dd__native" name="requires" aria-hidden="true" tabindex="-1">
            {requiresOptions.map((value) => (
              <option value={value} selected={value === specimen.requires}>{value}</option>
            ))}
          </select>
        </div>
      </div>
      </div>
      <label class="submit-field">
        <span>license</span>
        <input type="text" name="license" value={specimen.license} maxlength="80" />
      </label>
      </div>

      <div class="submit-col submit-col--tdn">
      <div class="submit-field submit-field--editor">
        <span>TDN (YAML)</span>
        <small class="submit-hint">
          edit the network directly. saving a changed TDN re-runs the capability scan and creates a new version.
        </small>
        <TdnYamlEditor client:load name="tdn" initialValue={currentTdn} />
      </div>
      <p class="submit-status" data-edit-status role="status"></p>
      <button type="submit" class="btn btn--primary submit-go" data-edit-go aria-disabled="true">
        save changes
      </button>
      </div>
      </div>
    </form>

    <p class="submit-back">
      <a href={`/c/${specimen.slug}`}>cancel and return to the specimen</a>
    </p>
  </section>
</Base>

<script>
  // Owner edit. PUTs the form to /api/specimens/:slug; on success returns to the
  // specimen page. Includes the (editable) TDN body -- a changed network re-runs
  // the capability scan + saves a new version server-side.
  const form = document.querySelector("[data-edit-form]") as HTMLFormElement | null;
  const statusBox = document.querySelector("[data-edit-status]") as HTMLElement | null;
  const goBtn = document.querySelector("[data-edit-go]") as HTMLButtonElement | null;

  function setStatus(message: string, kind: "pending" | "ok" | "error") {
    if (!statusBox) return;
    statusBox.textContent = message;
    statusBox.dataset.kind = kind;
  }

  function setFieldError(name: string, message: string) {
    const el = form?.querySelector(`[data-error-for="${name}"]`) as HTMLElement | null;
    if (!el) return;
    el.textContent = message || "";
  }

  function titleEl() {
    return form?.querySelector('[name="title"]') as HTMLInputElement | null;
  }
  function titleMissing() {
    const el = titleEl();
    return !el || !String(el.value || "").trim();
  }

  // The TDN editor (React island) validates on every edit and broadcasts a
  // bubbling `tdn:change` with its validity, so "save changes" stays greyed while
  // the network is unparseable.
  let tdnValid = false;
  form?.addEventListener("tdn:change", (event) => {
    tdnValid = Boolean((event as CustomEvent).detail?.valid);
    refreshReady();
  });

  function isReady() {
    return !titleMissing() && tdnValid;
  }
  function refreshReady() {
    if (!goBtn) return;
    goBtn.setAttribute("aria-disabled", isReady() ? "false" : "true");
  }
  form?.addEventListener("input", () => {
    if (!titleMissing()) setFieldError("title", "");
    refreshReady();
  });
  refreshReady();

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();
    if (!goBtn || !form) return;
    const slug = form.dataset.slug ?? "";
    const data = new FormData(form);

    const title = String(data.get("title") || "").trim();
    if (!isReady()) {
      const probs: string[] = [];
      if (titleMissing()) probs.push("a title");
      if (!tdnValid) probs.push("a valid TDN network");
      setFieldError("title", titleMissing() ? "add a title." : "");
      setStatus(`fix ${probs.join(" and ")} before saving.`, "error");
      return;
    }

    const tags = String(data.get("tags") || "")
      .split(",")
      .map((tag) => tag.trim())
      .filter(Boolean);

    const payload = {
      title,
      description: String(data.get("description") || "").trim(),
      tags,
      license: String(data.get("license") || "CC-BY-4.0").trim() || "CC-BY-4.0",
      difficulty: String(data.get("difficulty") || "intermediate"),
      category: String(data.get("category") || ""),
      requires: String(data.get("requires") || "none"),
      tdn: String(data.get("tdn") || "")
    };

    goBtn.disabled = true;
    const original = goBtn.textContent;
    goBtn.textContent = "saving...";
    setStatus("saving changes...", "pending");

    try {
      const res = await fetch(`/api/specimens/${encodeURIComponent(slug)}`, {
        method: "PUT",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload)
      });
      const body = (await res.json().catch(() => ({}))) as { detail?: string; error?: string };
      if (res.status === 401) {
        window.location.assign(`/signin?next=${encodeURIComponent(`/c/${slug}/edit`)}`);
        return;
      }
      if (!res.ok) {
        setStatus(body.detail || body.error || `update failed (${res.status}).`, "error");
        goBtn.disabled = false;
        goBtn.textContent = original;
        return;
      }
      setStatus("saved. returning to your specimen...", "ok");
      window.location.assign(`/c/${slug}`);
    } catch {
      setStatus("something went wrong. please try again.", "error");
      goBtn.disabled = false;
      goBtn.textContent = original;
    }
  });
</script>

<script>
  // App-native dropdowns for the edit form. Each .dd wraps a visually-hidden
  // native <select> (the value the form's FormData reads via
  // data.get("difficulty"/"category"/"requires")) plus a styled trigger + ARIA
  // listbox. The native select is pre-selected to the specimen's CURRENT value
  // (server-rendered), and the .dd__val + aria-selected mirror it, so the
  // initial state shows the existing choice. Choosing an option writes the
  // native select's value and dispatches a 'change' event, so the submitted
  // value tracks the visible choice. Mirrors contribute.astro's [data-dd].
  const closeDropdown = (dd: Element): void => {
    dd.removeAttribute("data-open");
    const menu = dd.querySelector(".dd__menu");
    if (menu) (menu as HTMLElement).hidden = true;
    const button = dd.querySelector(".dd__btn");
    if (button) button.setAttribute("aria-expanded", "false");
  };

  // Unique id seed so every option across the dropdowns gets a stable id for
  // aria-activedescendant (the listbox points at the active option's id).
  let ddOptSeq = 0;
  const dropdowns = Array.from(document.querySelectorAll(".dd[data-dd]"));

  dropdowns.forEach((dd) => {
    const btn = dd.querySelector(".dd__btn") as HTMLButtonElement | null;
    const menu = dd.querySelector(".dd__menu") as HTMLElement | null;
    const valEl = dd.querySelector(".dd__val") as HTMLElement | null;
    const native = dd.querySelector(".dd__native") as HTMLSelectElement | null;
    const opts = Array.from(dd.querySelectorAll(".dd__opt")) as HTMLElement[];
    if (!btn || !menu || !valEl || !native) return;

    // Give every option a stable id so the listbox can name the ACTIVE option
    // via aria-activedescendant (focus stays on the button; this is how a
    // screen reader announces the highlighted option without moving DOM focus).
    opts.forEach((opt) => {
      if (!opt.id) opt.id = `dd-opt-${ddOptSeq++}`;
    });

    // The active (keyboard-highlighted) option index. -1 == none highlighted.
    let active = -1;
    const setActive = (index: number): void => {
      const next = Math.max(0, Math.min(index, opts.length - 1));
      const opt = opts[next];
      if (!opt) return;
      opts.forEach((o, i) => o.classList.toggle("is-active", i === next));
      active = next;
      menu.setAttribute("aria-activedescendant", opt.id);
      opt.scrollIntoView({ block: "nearest" });
    };
    const clearActive = (): void => {
      active = -1;
      opts.forEach((o) => o.classList.remove("is-active"));
      menu.removeAttribute("aria-activedescendant");
    };

    const open = (highlightSelected = true): void => {
      dropdowns.forEach((other) => {
        if (other !== dd) closeDropdown(other);
      });
      dd.setAttribute("data-open", "");
      menu.hidden = false;
      btn.setAttribute("aria-expanded", "true");
      if (highlightSelected) {
        // Open with the currently-selected option highlighted (or the first).
        const sel = opts.findIndex((o) => o.getAttribute("aria-selected") === "true");
        setActive(sel >= 0 ? sel : 0);
      }
    };
    const close = (): void => {
      clearActive();
      closeDropdown(dd);
    };
    const choose = (opt: HTMLElement): void => {
      native.value = opt.getAttribute("data-value") || "";
      native.dispatchEvent(new Event("change", { bubbles: true }));
      valEl.textContent = opt.textContent;
      opts.forEach((o) => o.setAttribute("aria-selected", String(o === opt)));
      close();
      btn.focus();
    };

    btn.addEventListener("click", () => {
      if (dd.hasAttribute("data-open")) close();
      else open();
    });
    btn.addEventListener("keydown", (e: KeyboardEvent) => {
      const isOpen = dd.hasAttribute("data-open");
      switch (e.key) {
        case "Escape":
          if (isOpen) {
            e.preventDefault();
            close();
            btn.focus();
          }
          return;
        case "Tab":
          // Tab moves focus away -- close without swallowing the Tab.
          if (isOpen) close();
          return;
        case "Enter":
        case " ": {
          e.preventDefault();
          if (!isOpen) {
            open();
            return;
          }
          const activeOpt = active >= 0 ? opts[active] : undefined;
          if (activeOpt) choose(activeOpt);
          return;
        }
        case "ArrowDown":
          e.preventDefault();
          if (!isOpen) {
            open();
            return;
          }
          setActive(active < 0 ? 0 : active + 1);
          return;
        case "ArrowUp":
          e.preventDefault();
          if (!isOpen) {
            open();
            return;
          }
          setActive(active < 0 ? opts.length - 1 : active - 1);
          return;
        case "Home":
          if (isOpen) {
            e.preventDefault();
            setActive(0);
          }
          return;
        case "End":
          if (isOpen) {
            e.preventDefault();
            setActive(opts.length - 1);
          }
          return;
        default:
          return;
      }
    });

    // Pointer: hover syncs the active highlight so mouse + keyboard agree.
    opts.forEach((opt, i) => {
      opt.addEventListener("click", () => choose(opt));
      opt.addEventListener("mousemove", () => setActive(i));
    });
  });

  document.addEventListener("click", (e: MouseEvent) => {
    const target = e.target instanceof Node ? e.target : null;
    dropdowns.forEach((dd) => {
      if (dd.hasAttribute("data-open") && (target === null || !dd.contains(target))) {
        closeDropdown(dd);
      }
    });
  });
  document.addEventListener("keydown", (e: KeyboardEvent) => {
    if (e.key === "Escape") dropdowns.forEach((dd) => closeDropdown(dd));
  });
</script>

<style>
  /* Scoped form styles mirrored from contribute.astro. The edit form reuses the
     same submit-form / submit-field markup classes, so it needs the same scoped
     rules to look consistent. embody.css can't be edited here, so duplicating
     the relevant block is the accepted approach. Contribute-only bits
     (.submit-tdn, .submit-turnstile, sign-out chrome) are intentionally omitted
     since this form has none of that markup. */

  /* Centered reading column, same treatment as the manifesto body: a narrow
     max-width with auto inline margins so the whole form sits centered on the
     page instead of pinned to the left gutter. */
  .submit {
    max-width: 72rem;
    margin-inline: auto;
    padding-bottom: 56px;
  }

  .submit-form {
    margin-top: 2rem;
    max-width: 100%;
  }

  /* Two columns, mirroring the contribute form: metadata fields left, the large
     editable TDN editor (+ status + submit) right. The whole form sits inside one
     bordered panel (matching the site's .pillar cards). Collapses on narrow
     viewports. */
  .submit-cols {
    display: grid;
    grid-template-columns: minmax(0, 30rem) minmax(0, 1fr);
    gap: 2rem;
    align-items: start;
    padding: clamp(1.25rem, 3vw, 2rem);
    border: 1px solid var(--border-faint);
    border-radius: var(--radius);
    background: var(--bg-elevated);
  }

  .submit-col {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
    min-width: 0;
  }

  .submit-col--tdn {
    min-height: 100%;
  }

  .submit-field--editor {
    flex: 1;
    min-height: 0;
  }

  @media (max-width: 60rem) {
    .submit-cols {
      grid-template-columns: 1fr;
    }
  }

  /* The three short dropdowns share one row on wider screens. */
  .submit-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.1rem;
    align-items: start;
  }

  @media (max-width: 34rem) {
    .submit-row {
      grid-template-columns: 1fr;
    }
  }

  .submit-field {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .submit-error {
    font-size: 0.8rem;
    line-height: 1.4;
    color: #ff9b9b;
  }

  .submit-hint {
    font-size: 0.8rem;
    line-height: 1.5;
    color: var(--text-faint);
  }

  .submit-field > span {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .submit-field > span em {
    text-transform: none;
    letter-spacing: 0;
    color: var(--text-faint);
    font-style: normal;
  }

  .submit-field input,
  .submit-field textarea {
    padding: 0.65rem 0.75rem;
    background-color: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    color: var(--text);
    font-size: 1rem;
  }

  /* The dropdown label is a plain <span> (not a wrapping <label>), so it needs
     the same mono/uppercase treatment the wrapping-label fields get from
     `.submit-field > span`. */
  .submit-field__label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  /* ---- App-native dropdown ---- */
  /* A styled trigger + ARIA listbox over a visually-hidden native <select>.
     Replaces the OS/browser-native <select> so the option list matches the
     dark UI instead of the OS theme. Mirrors contribute.astro's .dd*. The
     hidden <select class="dd__native"> still carries the form value (its
     name + options are submitted via FormData). */
  .dd {
    position: relative;
    display: inline-flex;
    align-self: flex-start;
  }

  /* Visually-hidden value carrier the form's FormData reads/writes. */
  .dd__native {
    position: absolute;
    width: 1px;
    height: 1px;
    margin: -1px;
    padding: 0;
    border: 0;
    opacity: 0;
    overflow: hidden;
    clip: rect(0 0 0 0);
    pointer-events: none;
  }

  .dd__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background-color: var(--bg);
    padding: 0.65rem 0.9rem;
    color: var(--text);
    font-size: 1rem;
    line-height: 1;
    cursor: pointer;
    transition: border-color 140ms ease;
  }

  .dd__btn:hover {
    border-color: var(--accent);
  }

  .dd__btn:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 1px;
    border-color: var(--accent);
  }

  .dd[data-open] .dd__btn {
    border-color: var(--accent);
  }

  .dd__val {
    white-space: nowrap;
  }

  .dd__chev {
    flex: none;
    color: var(--text-faint);
    transition: transform 180ms ease;
  }

  .dd[data-open] .dd__chev {
    transform: rotate(180deg);
  }

  .dd__menu {
    position: absolute;
    top: calc(100% + 6px);
    left: 0;
    z-index: 60;
    min-width: 100%;
    width: max-content;
    max-width: 18rem;
    max-height: 16rem;
    margin: 0;
    padding: 0.3rem;
    list-style: none;
    overflow-y: auto;
    border: 1px solid var(--border);
    border-radius: 12px;
    background: var(--bg-elevated, #14181a);
    box-shadow: 0 18px 44px -20px rgba(0, 0, 0, 0.85);
  }

  .dd__menu[hidden] {
    display: none;
  }

  .dd__opt {
    display: block;
    padding: 0.5rem 0.7rem;
    border-radius: 7px;
    color: var(--text-muted, #b6bfb8);
    font-size: 0.92rem;
    white-space: nowrap;
    cursor: pointer;
  }

  .dd__opt:hover,
  .dd__opt.is-active {
    background: var(--accent-dim, rgba(120, 200, 150, 0.14));
    color: var(--accent);
  }

  .dd__opt[aria-selected="true"] {
    color: var(--accent);
  }

  .submit-field input:focus,
  .submit-field textarea:focus {
    outline: 2px solid var(--accent);
    outline-offset: 1px;
    border-color: var(--accent);
  }

  .submit-go {
    align-self: flex-start;
  }

  /* Greyed while the title is empty or the TDN is unparseable. Stays clickable
     (aria-disabled, not disabled) so a click can explain what's missing. */
  .submit-go[aria-disabled="true"],
  .submit-go[aria-disabled="true"]:hover {
    background: var(--bg-elevated-2);
    color: var(--text-faint);
    cursor: not-allowed;
    transform: none;
  }

  .submit-status {
    margin-top: 0;
    padding: 0.65rem 0.75rem;
    border-radius: var(--radius-sm);
    font-size: 0.9rem;
    border: 1px solid var(--border);
  }

  .submit-status[data-kind="error"] {
    background: rgba(220, 80, 80, 0.12);
    border-color: rgba(220, 80, 80, 0.4);
    color: #ff9b9b;
  }

  .submit-status[data-kind="ok"] {
    background: rgba(110, 230, 104, 0.12);
    border-color: rgba(110, 230, 104, 0.4);
    color: var(--accent);
  }

  /* Empty -> collapsed, but the element STAYS in the DOM / a11y tree (never
     display:none or hidden) so this role=status/alert live region is registered
