    line-height: 1.08;
    /* Cap the title at 2 lines so a long name ellipsizes instead of pushing the
       byline + description down the panel. Two lines is fine here (unlike the
       collection list's single line) -- this page has the vertical room. */
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    overflow: hidden;
  }
  .specimen-app__desc {
    margin: 0;
    color: var(--text-muted);
