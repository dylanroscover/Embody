---
import { env } from "cloudflare:workers";
import type { SpecimenSummary } from "@embody/contracts";
import Base from "../../layouts/Base.astro";
import { searchFixtureSummaries } from "../../lib/specimenFallback";
import { specimenThumbnail } from "../../lib/specimenThumb";
import { searchSpecimensFts } from "../../server/db";

export const prerender = false;

const query = (Astro.url.searchParams.get("q") ?? "").trim();
let specimens: SpecimenSummary[] = [];

if (query) {
  try {
    const response = await searchSpecimensFts(env.DB, query, 24);
    specimens = response.results.length > 0 ? response.results : searchFixtureSummaries(query);
  } catch {
    specimens = searchFixtureSummaries(query);
  }
}

const resultLabel = query
  ? `${specimens.length} ${specimens.length === 1 ? "result" : "results"}`
  : "Enter a search query";
---

<Base
  title="Search the Collection - embody.tools"
  description="Search transparent TouchDesigner Specimens."
>
  <section class="page-section search-hero">
    <p class="eyebrow">Search the Collection</p>
    <h1>find a transparent network</h1>
    <p class="lede">
      Search specimen names, categories, prompts, tags, and embedded DAT text.
    </p>
    <form class="search-form" method="get" action="/specimens/search">
      <label class="sr-only" for="specimen-search">Search specimens</label>
      <input
        id="specimen-search"
        class="search-input"
        type="search"
        name="q"
        value={query}
        placeholder="feedback, particles, bloom"
        autocomplete="off"
      />
      <button class="btn btn--primary" type="submit">Search</button>
    </form>
  </section>

  <section class="page-section tight search-results" aria-live="polite">
    <div class="collection-toolbar">
      <span class="collection-total mono">{resultLabel}</span>
      <a class="card-link" href="/specimens">Browse all specimens</a>
    </div>

    {specimens.length > 0 ? (
      <div class="card-grid search-card-grid">
        {specimens.map((specimen) => (
          <a class="specimen-card pillar" href={`/s/${specimen.slug}`}>
            <div class="thumb">
              <img
                src={specimenThumbnail(specimen)}
                loading="lazy"
                alt={`${specimen.name} thumbnail placeholder`}
              />
            </div>
            <div class="specimen-card__body">
              <div class="badge-row">
                <span class="badge">{specimen.difficulty}</span>
                <span class:list={["badge", specimen.requires === "none" ? "stock" : "needs"]}>
                  {specimen.requires === "none" ? "stock TD" : `needs ${specimen.requires}`}
                </span>
                <span class="badge specimen-category">{specimen.category}</span>
              </div>
              <h3>{specimen.name}</h3>
              <p>{specimen.description}</p>
              <span class="card-link">Inspect /s/{specimen.slug}</span>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="search-empty pillar">
        <p>{query ? "No specimens matched that search." : "Search for a feeling, operator, tag, or specimen name."}</p>
      </div>
    )}
  </section>
</Base>

<style>
  .search-hero {
    padding-bottom: 56px;
  }

  .search-form {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    max-width: 760px;
  }

  .search-input {
    flex: 1 1 280px;
    min-height: 46px;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: rgba(24, 30, 30, 0.72);
    padding: 0.8rem 1rem;
    color: var(--text);
    font: 600 0.95rem/1 var(--font-display);
  }

  .search-input::placeholder {
    color: var(--text-faint);
  }

  .search-input:focus {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }

  .search-results {
    border-top: 1px solid var(--border-faint);
  }

  .collection-toolbar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .collection-total {
    color: var(--text-faint);
    font-size: 0.76rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .search-card-grid {
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  }

  .search-empty {
    padding: 1.2rem 1.25rem;
  }

  .search-empty p {
    margin: 0;
    color: var(--text-muted);
  }
</style>
