---
import { env } from "cloudflare:workers";
import Base from "../layouts/Base.astro";
import { githubOAuthEnabled, type AuthEnv } from "../lib/auth";

export const prerender = false;

// If already signed in, send the user to their profile (or the collection).
const user = Astro.locals.user;
if (user) {
  return Astro.redirect(`/u/${user.handle}`);
}

const githubEnabled = githubOAuthEnabled(env as unknown as AuthEnv);

// `next` lets a gated page (e.g. /submit) bounce the user back after sign-in.
const rawNext = Astro.url.searchParams.get("next") ?? "";
const nextPath = rawNext.startsWith("/") && !rawNext.startsWith("//") ? rawNext : "";

// After clicking the verification link, Better Auth redirects back here with
// ?verified=1 (the callbackURL we pass at sign-up / resend). Show a one-time
// confirmation so the user knows their email is confirmed and to sign in now.
const justVerified = Astro.url.searchParams.get("verified") === "1";
---

<Base
  title="sign in - embody.tools"
  description="Sign in or create an account on embody.tools."
>
  <section class="page-section auth">
    <p class="eyebrow">Account</p>
    <div class="auth-layout">
      <div class="auth-intro">
        <h1 id="auth-heading">sign in</h1>
        <p class="lede">
          Create an account or sign in to contribute Specimens and react to the
          networks you love. It's completely free, and the Collection stays
          fully browsable without an account.
        </p>
        <p class="auth-back">
          <a href="/collection">Browse the Collection instead</a>
        </p>
      </div>

      <div class="auth-card" data-next={nextPath}>
      {justVerified && (
        <p class="auth-verified-banner" role="status">Email verified -- you can sign in below.</p>
      )}
      <div class="auth-toggle" role="tablist" aria-label="Sign in or register">
        <button type="button" class="auth-toggle__btn is-active" data-mode="signin" role="tab" aria-selected="true">
          sign in
        </button>
        <button type="button" class="auth-toggle__btn" data-mode="register" role="tab" aria-selected="false">
          register
        </button>
      </div>

      <p class="auth-error" data-auth-error hidden role="alert"></p>
      <p class="auth-notice" data-auth-notice hidden role="status"></p>
      <p class="auth-resend" data-resend hidden>
        <button type="button" class="auth-resend__btn" data-resend-btn>Resend verification email</button>
      </p>

      <form class="auth-form" data-auth-form novalidate>
        <label class="auth-field" data-field="name" hidden>
          <span>name</span>
          <input type="text" name="name" autocomplete="name" placeholder="Your name" />
        </label>
        <label class="auth-field">
          <span>email</span>
          <input type="email" name="email" autocomplete="email" required placeholder="you@example.com" />
        </label>
        <label class="auth-field">
          <span>password</span>
          <input type="password" name="password" autocomplete="current-password" required minlength="8" placeholder="" />
        </label>
        <button type="submit" class="btn btn--primary auth-submit" data-auth-submit>
          sign in
        </button>
      </form>

      <p class="auth-forgot" data-forgot>
        <a href="/forgot-password">Forgot password?</a>
      </p>

      {githubEnabled && (
        <>
          <div class="auth-divider"><span>or</span></div>
          <button type="button" class="btn btn--outline auth-github" data-github>
            continue with GitHub
          </button>
        </>
      )}
      </div>
    </div>
  </section>
</Base>

<script>
  import { authClient } from "../lib/authClient";

  const card = document.querySelector<HTMLDivElement>(".auth-card");
  const form = document.querySelector<HTMLFormElement>("[data-auth-form]");
  const errorBox = document.querySelector<HTMLParagraphElement>("[data-auth-error]");
  const submitBtn = document.querySelector<HTMLButtonElement>("[data-auth-submit]");
  const nameField = document.querySelector<HTMLLabelElement>('[data-field="name"]');
  const forgotLink = document.querySelector("[data-forgot]") as HTMLParagraphElement | null;
  const passwordInput = form?.querySelector<HTMLInputElement>('input[name="password"]');
  const toggles = Array.from(document.querySelectorAll<HTMLButtonElement>(".auth-toggle__btn"));
  const githubBtn = document.querySelector<HTMLButtonElement>("[data-github]");
  const noticeBox = document.querySelector<HTMLParagraphElement>("[data-auth-notice]");
  const resendWrap = document.querySelector<HTMLParagraphElement>("[data-resend]");
  const resendBtn = document.querySelector<HTMLButtonElement>("[data-resend-btn]");

  // Email of the account awaiting verification -- set after a verify-required
  // register, or after a blocked unverified sign-in. Drives the resend button.
  let pendingEmail: string | null = null;

  let mode: "signin" | "register" = "signin";

  const nextPath = card?.dataset.next || "";
  const fallbackRedirect = "/collection";

  function destination(handle?: string): string {
    if (nextPath) return nextPath;
    if (handle) return `/u/${handle}`;
    return fallbackRedirect;
  }

  function showError(message: string) {
    if (!errorBox) return;
    errorBox.textContent = message;
    errorBox.hidden = false;
  }

  function clearError() {
    if (!errorBox) return;
    errorBox.textContent = "";
    errorBox.hidden = true;
  }

  function showNotice(message: string) {
    clearError();
    if (!noticeBox) return;
    noticeBox.textContent = message;
    noticeBox.hidden = false;
  }

  function clearNotice() {
    if (!noticeBox) return;
    noticeBox.textContent = "";
    noticeBox.hidden = true;
  }

  function showResend() {
    if (resendWrap) resendWrap.hidden = false;
  }

  function hideResend() {
    if (resendWrap) resendWrap.hidden = true;
  }

  // Verify-first: the account exists but has NO session until the email link is
  // clicked. Hide the form, explain what to do, and offer a resend -- instead of
  // silently redirecting into a signed-out page that just says "sign in".
  function showVerifyPending(email: string) {
    pendingEmail = email;
    if (form) form.hidden = true;
    if (forgotLink) forgotLink.hidden = true;
    showNotice(`We sent a verification link to ${email}. Click it to finish, then sign in.`);
    showResend();
  }

  function setMode(next: "signin" | "register") {
    mode = next;
    clearError();
    clearNotice();
    hideResend();
    pendingEmail = null;
    if (form) form.hidden = false;
    for (const btn of toggles) {
      const active = btn.dataset.mode === next;
      btn.classList.toggle("is-active", active);
      btn.setAttribute("aria-selected", active ? "true" : "false");
    }
    if (nameField) nameField.hidden = next !== "register";
    if (forgotLink) forgotLink.hidden = next === "register";
    if (submitBtn) submitBtn.textContent = next === "register" ? "create account" : "sign in";
    if (passwordInput) {
      passwordInput.autocomplete = next === "register" ? "new-password" : "current-password";
      // "At least 8 characters" is a new-password hint -- only show it when
      // registering. Signing in, the field is blank (you know your password).
      passwordInput.placeholder = next === "register" ? "At least 8 characters" : "";
    }
  }

  for (const btn of toggles) {
    btn.addEventListener("click", () => setMode(btn.dataset.mode as "signin" | "register"));
  }

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();
    clearError();
    if (!submitBtn) return;

    const data = new FormData(form);
    const email = String(data.get("email") || "").trim();
    const password = String(data.get("password") || "");
    const name = String(data.get("name") || "").trim();

    if (!email || !password) {
      showError("Email and password are required.");
      return;
    }
    if (mode === "register" && password.length < 8) {
      showError("Password must be at least 8 characters.");
      return;
    }

    submitBtn.disabled = true;
    const original = submitBtn.textContent;
    submitBtn.textContent = mode === "register" ? "creating..." : "signing in...";

    try {
      if (mode === "register") {
        const res = await authClient.signUp.email({
          email,
          password,
          name: name || email.split("@")[0] || email,
          callbackURL: "/signin?verified=1"
        });
        if (res.error) {
          showError(res.error.message || "Could not create the account.");
          return;
        }
        // When email verification is required, sign-up creates the account but
        // returns NO session (token is null). Don't redirect into a signed-out
        // page that just says "sign in" -- tell the user to verify first. When
        // email is unconfigured (e.g. dev) a real token comes back and we fall
        // through to the normal redirect below.
        if (!res.data?.token) {
          showVerifyPending(email);
          return;
        }
      } else {
        const res = await authClient.signIn.email({ email, password });
        if (res.error) {
          // An unverified account is hard-blocked by Better Auth with
          // EMAIL_NOT_VERIFIED (403). Surface a helpful message + a resend, not
          // the generic "invalid password".
          if (res.error.code === "EMAIL_NOT_VERIFIED" || res.error.status === 403) {
            pendingEmail = email;
            showError("Your email isn't verified yet -- check your inbox for the link.");
            showResend();
          } else {
            showError(res.error.message || "Invalid email or password.");
          }
          return;
        }
      }
      // Session cookie is set; the destination page reads it server-side.
      window.location.assign(destination());
    } catch (err) {
      console.error("auth submit failed", err);
      showError("Something went wrong. Please try again.");
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = original;
    }
  });

  githubBtn?.addEventListener("click", async () => {
    clearError();
    try {
      await authClient.signIn.social({
        provider: "github",
        callbackURL: destination()
      });
    } catch (err) {
      console.error("github sign-in failed", err);
      showError("GitHub sign-in failed. Please try again.");
    }
  });

  resendBtn?.addEventListener("click", async () => {
    if (!pendingEmail) return;
    resendBtn.disabled = true;
    const original = resendBtn.textContent;
    resendBtn.textContent = "sending...";
    try {
      await authClient.sendVerificationEmail({
        email: pendingEmail,
        callbackURL: `${window.location.origin}/signin?verified=1`
      });
      showNotice(`Verification link re-sent to ${pendingEmail}. Check your inbox.`);
      showResend();
    } catch (err) {
      console.error("resend verification failed", err);
      showError("Could not resend right now. Please try again.");
    } finally {
      resendBtn.disabled = false;
      resendBtn.textContent = original;
    }
  });

  setMode("signin");

  // Clear the one-time ?verified=1 from the URL so a refresh/back (or switching
  // to register) doesn't re-show the "Email verified" banner. The banner itself
  // is server-rendered for the first paint; this just tidies the address bar.
  if (new URLSearchParams(window.location.search).has("verified")) {
    const url = new URL(window.location.href);
    url.searchParams.delete("verified");
    window.history.replaceState(null, "", url.pathname + url.search);
  }
</script>

<style>
  .auth {
    padding-bottom: 56px;
  }

  /* Two-column: intro copy on the left, form panel on the right. Fills the
     empty right half so the page reads as a balanced, intentional composition.
     The eyebrow lives ABOVE this grid (at section-top, matching every other
     page); the grid's first rows -- the h1 and the panel -- top-align, so the
     panel anchors to the "sign in" heading. Collapses to one column below 860px. */
  .auth-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: start;
  }

  .auth-intro {
    max-width: 32rem;
  }

  @media (min-width: 860px) {
    .auth-layout {
      grid-template-columns: minmax(0, 1fr) minmax(0, 27rem);
      gap: clamp(3rem, 7vw, 6rem);
    }
  }

  .auth-card {
    width: 100%;
    padding: 1.75rem;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }

  .auth-toggle {
    display: flex;
    gap: 0.25rem;
    padding: 0.25rem;
    background: var(--bg);
    border: 1px solid var(--border-faint);
    border-radius: var(--radius-sm);
    margin-bottom: 1.25rem;
  }

  .auth-toggle__btn {
    flex: 1;
    padding: 0.55rem 0.75rem;
    background: transparent;
    border: none;
    border-radius: var(--radius-sm);
    color: var(--text-muted);
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
  }

  .auth-toggle__btn.is-active {
    background: var(--bg-elevated);
    color: var(--text);
    box-shadow: inset 0 0 0 1px var(--border);
  }

  .auth-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .auth-field {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  /* `.auth-field { display: flex }` outranks the UA `[hidden] { display: none }`
     (equal specificity, author wins), so the name field leaked into sign-in mode
     despite its `hidden` attribute. Restore the intended hide. */
  .auth-field[hidden] {
    display: none;
  }

  .auth-field > span {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .auth-field input {
    padding: 0.65rem 0.75rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    color: var(--text);
    font-size: 1rem;
  }

  .auth-field input:focus {
    outline: 2px solid var(--accent);
    outline-offset: 1px;
    border-color: var(--accent);
  }

  .auth-submit {
    margin-top: 0.25rem;
    width: 100%;
    justify-content: center;
  }

  .auth-github {
    width: 100%;
    justify-content: center;
  }

  .auth-forgot {
    margin-top: 0.85rem;
    text-align: center;
    font-size: 0.85rem;
  }

  .auth-forgot a {
    color: var(--text-muted);
    font-family: var(--font-mono);
  }

  .auth-forgot a:hover {
    color: var(--accent);
  }

  .auth-divider {
    display: flex;
    align-items: center;
    text-align: center;
    color: var(--text-faint);
    font-size: 0.8rem;
    margin: 1.1rem 0;
  }

  .auth-divider::before,
  .auth-divider::after {
    content: "";
    flex: 1;
    border-top: 1px solid var(--border-faint);
  }

  .auth-divider span {
    padding: 0 0.75rem;
  }

  .auth-error {
    margin-bottom: 1rem;
    padding: 0.65rem 0.75rem;
    background: rgba(220, 80, 80, 0.12);
    border: 1px solid rgba(220, 80, 80, 0.4);
    border-radius: var(--radius-sm);
    color: #ff9b9b;
    font-size: 0.9rem;
  }

  /* Verify-first success state + the post-verify banner: brand green, not the
     error red. */
  .auth-notice,
  .auth-verified-banner {
    margin-bottom: 1rem;
    padding: 0.65rem 0.75rem;
    background: rgba(110, 230, 104, 0.12);
    border: 1px solid rgba(110, 230, 104, 0.4);
    border-radius: var(--radius-sm);
    color: var(--accent);
    font-size: 0.9rem;
  }

  .auth-verified-banner {
    margin-bottom: 1.25rem;
  }

  .auth-resend {
    margin: 0 0 1rem;
    text-align: center;
  }

  .auth-resend__btn {
    background: transparent;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    color: var(--text-muted);
    padding: 0.4rem 0.85rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    cursor: pointer;
  }

  .auth-resend__btn:hover {
    color: var(--text);
    border-color: var(--accent);
  }

  .auth-resend__btn:disabled {
    opacity: 0.6;
    cursor: default;
  }

  .auth-back {
    margin-top: 1.5rem;
  }

  .auth-back a {
    color: var(--accent);
    font-family: var(--font-display);
    font-weight: 600;
  }

  .auth-back a:hover {
    color: var(--text);
  }
</style>
