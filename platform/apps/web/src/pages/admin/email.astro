---
import { env } from "cloudflare:workers";
import AdminLayout from "../../components/AdminLayout.astro";
import { EMAIL_TEMPLATES, isAdmin } from "../../server/admin";

export const prerender = false;

if (!isAdmin(Astro.locals.user, env)) return Astro.redirect("/");

const myEmail = Astro.locals.user?.email ?? "";
// When RESEND_API_KEY is unset, sends are skipped (no delivery). Surface that so
// a "skipped" result reads as expected rather than a failure.
const resendConfigured = Boolean((env as unknown as CloudflareEnv).RESEND_API_KEY);
---

<AdminLayout title="email" active="email">
  <p class="admin-intro">
    Send yourself (or any address) a real copy of each branded email so you can
    confirm rendering across clients. Templates use the same shell as the live
    emails.
  </p>

  {!resendConfigured && (
    <p class="admin-status" data-kind="error">
      RESEND_API_KEY is not set -- sends are skipped (no email delivered). Set it
      as a Worker secret to test real delivery.
    </p>
  )}

  <form class="admin-email-form" data-email-form>
    <label>template
      <select name="template" class="admin-select">
        {EMAIL_TEMPLATES.map((t) => (<option value={t}>{t}</option>))}
      </select>
    </label>
    <label>send to
      <input type="email" name="to" value={myEmail} class="admin-input" placeholder="you@example.com" />
    </label>
    <button type="submit" class="admin-btn" data-send>send test</button>
  </form>

  <p class="admin-status" data-status hidden role="status"></p>
</AdminLayout>

<script>
  const form = document.querySelector<HTMLFormElement>("[data-email-form]");
  const sendBtn = document.querySelector<HTMLButtonElement>("[data-send]");
  const statusBox = document.querySelector<HTMLParagraphElement>("[data-status]");

  function setStatus(message: string, kind: "ok" | "error" | "info") {
    if (!statusBox) return;
    statusBox.textContent = message;
    statusBox.dataset.kind = kind;
    statusBox.hidden = false;
  }

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();
    if (!sendBtn) return;
    const data = new FormData(form);
    const template = String(data.get("template") || "");
    const to = String(data.get("to") || "").trim();

    sendBtn.disabled = true;
    const original = sendBtn.textContent;
    sendBtn.textContent = "sending...";
    try {
      const res = await fetch("/api/admin/email/test", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ template, to: to || undefined })
      });
      const body: any = await res.json().catch(() => ({}));
      if (!res.ok) {
        setStatus(body.detail || body.error || `Failed (${res.status}).`, "error");
        return;
      }
      if (body.skipped) {
        setStatus(`Skipped (no RESEND_API_KEY). Would send "${template}" to ${body.to}.`, "info");
      } else if (body.sent) {
        setStatus(`Sent "${template}" to ${body.to}. Check that inbox.`, "ok");
      } else if (body.error) {
        setStatus(`Resend error: ${body.error}`, "error");
      } else {
        setStatus(`Done.`, "ok");
      }
    } catch {
      setStatus("Something went wrong. Please try again.", "error");
    } finally {
      sendBtn.disabled = false;
      sendBtn.textContent = original;
    }
  });
</script>

<style>
  .admin-intro {
    color: var(--text-muted);
    font-size: 0.9rem;
    max-width: 40rem;
    margin-bottom: 1.5rem;
  }
</style>
