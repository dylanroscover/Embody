---
import { env } from "cloudflare:workers";
import AdminLayout from "../../components/AdminLayout.astro";
import { isAdmin, TRUST_LEVELS } from "../../server/admin";
import { listUsersForAdmin } from "../../server/db";

export const prerender = false;

if (!isAdmin(Astro.locals.user, env)) return Astro.redirect("/");

const q = (Astro.url.searchParams.get("q") ?? "").trim();
const users = await listUsersForAdmin(env.DB, { q });
const meId = Astro.locals.user?.id ?? "";
---

<AdminLayout title="users" active="users">
  <form class="admin-filter" method="get">
    <input
      type="search"
      name="q"
      value={q}
      placeholder="search handle / email"
      class="admin-input"
      aria-label="Search users"
    />
    <button type="submit" class="admin-btn">search</button>
  </form>

  <p class="admin-status" data-status role="status"></p>

  {users.length === 0 ? (
    <p class="admin-empty">No users{q ? ` matching "${q}"` : ""}.</p>
  ) : (
    <div class="admin-table-wrap" role="region" aria-label="Users table" tabindex="0">
    <table class="admin-table">
      <thead>
        <tr><th>handle</th><th>email</th><th>verified</th><th>joined</th><th>trust</th><th>action</th></tr>
      </thead>
      <tbody>
        {users.map((u) => (
          <tr data-row data-id={u.id} data-self={u.id === meId ? "1" : undefined}>
            <td>
              <a href={`/u/${u.handle}`}>{u.handle}</a>
              {u.banned ? <span class="admin-pill admin-pill--banned" title={u.banned_reason ?? "banned"}>banned</span> : null}
            </td>
            <td>{u.email ?? "-"}</td>
            <td>{u.email_verified ? "yes" : "no"}</td>
            <td>{u.created_at}</td>
            <td>
              <div class="dd" data-dd>
                <button type="button" class="dd__btn" aria-haspopup="listbox" aria-expanded="false" aria-label="Trust level">
                  <span class="dd__val">{u.trust_level}</span>
                  <svg class="dd__chev" width="10" height="6" viewBox="0 0 10 6" fill="none" aria-hidden="true"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.4" /></svg>
                </button>
                <ul class="dd__menu" role="listbox" aria-label="Trust level" hidden>
                  {TRUST_LEVELS.map((t) => (
                    <li class="dd__opt" role="option" data-value={t} aria-selected={t === u.trust_level ? "true" : "false"}>{t}</li>
                  ))}
                </ul>
                <select class="dd__native" data-trust aria-hidden="true" tabindex="-1" aria-label="Trust level">
                  {TRUST_LEVELS.map((t) => (<option value={t} selected={t === u.trust_level}>{t}</option>))}
                </select>
              </div>
              {u.id === meId && <span class="admin-pill">you</span>}
            </td>
            <td>
              <div class="admin-actions">
                <button type="button" class="admin-btn" data-save>save</button>
                {u.id !== meId && (
                  <button
                    type="button"
                    class="admin-btn"
                    data-ban-user
                    data-banned={u.banned ? "1" : "0"}
                    data-handle={u.handle}
                  >{u.banned ? "unban" : "ban"}</button>
                )}
                {u.id !== meId && (
                  <button
                    type="button"
                    class="admin-btn admin-btn--danger"
                    data-delete-user
                    data-handle={u.handle}
                  >delete</button>
                )}
              </div>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
    </div>
  )}
</AdminLayout>

<script>
  import { adminConfirm, adminPrompt } from "../../lib/adminDialog";

  const statusBox = document.querySelector<HTMLParagraphElement>("[data-status]");

  function setStatus(message: string, kind: "ok" | "error") {
    if (!statusBox) return;
    statusBox.textContent = message;
    statusBox.dataset.kind = kind;
  }

  document.querySelectorAll<HTMLButtonElement>("[data-save]").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const row = btn.closest("[data-row]") as HTMLElement | null;
      const id = row?.dataset.id;
      const trustLevel = (row?.querySelector("[data-trust]") as HTMLSelectElement | null)?.value;
      if (!id || !trustLevel) return;
      // Mirror the server-side self-demotion lockout for a friendlier message.
      if (row?.dataset.self === "1" && trustLevel !== "admin") {
        setStatus("You cannot remove your own admin access.", "error");
        return;
      }
      btn.disabled = true;
      try {
        const res = await fetch(`/api/admin/users/${id}`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ trustLevel })
        });
        const body: any = await res.json().catch(() => ({}));
        if (!res.ok) {
          setStatus(body.detail || body.error || `Failed (${res.status}).`, "error");
          return;
        }
        setStatus(`Set ${row?.querySelector("a")?.textContent ?? "user"} to "${trustLevel}".`, "ok");
      } catch {
        setStatus("Something went wrong. Please try again.", "error");
      } finally {
        btn.disabled = false;
      }
    });
  });

  // Ban / unban an account. Banning hides them everywhere (can't sign in/submit)
  // and drops their specimens from the Collection; reversible by unbanning.
  document.querySelectorAll<HTMLButtonElement>("[data-ban-user]").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const row = btn.closest("[data-row]") as HTMLElement | null;
      const id = row?.dataset.id;
      const handle = btn.dataset.handle ?? "user";
      const currentlyBanned = btn.dataset.banned === "1";
      if (!id) return;
      let reason: string | null = null;
      if (currentlyBanned) {
        if (!(await adminConfirm({
          title: "Unban account",
          message: `Unban @${handle}? Their account and specimens become visible again.`,
          okLabel: "unban",
          danger: false
        }))) return;
      } else {
        reason = await adminPrompt({
          title: `Ban @${handle}`,
          message: "They won't be able to sign in or post, and their specimens leave the Collection (reversible).",
          label: "reason (optional)",
          okLabel: "ban"
        });
        // null on Cancel -> abort; "" (OK with no text) -> ban, no reason.
        if (reason === null) return;
      }
      btn.disabled = true;
      try {
        const res = await fetch(`/api/admin/users/${id}`, {
          method: "PATCH",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ banned: !currentlyBanned, reason: reason || undefined })
        });
        const body: any = await res.json().catch(() => ({}));
        if (!res.ok) {
          setStatus(body.detail || body.error || `Failed (${res.status}).`, "error");
          btn.disabled = false;
          return;
        }
        setStatus(`${currentlyBanned ? "Unbanned" : "Banned"} @${handle}.`, "ok");
        location.reload();
      } catch {
        setStatus("Something went wrong. Please try again.", "error");
        btn.disabled = false;
      }
    });
  });

  // Hard-delete a user account (account + every specimen they authored + all
  // their engagement). Irreversible -- explicit confirm naming the handle, then
  // the row is removed from the table on success.
  document.querySelectorAll<HTMLButtonElement>("[data-delete-user]").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const row = btn.closest("[data-row]") as HTMLElement | null;
      const id = row?.dataset.id;
      const handle = btn.dataset.handle ?? "user";
      if (!id) return;
      if (!(await adminConfirm({
        title: `Delete @${handle}`,
        message: "This removes their account AND every specimen they authored, plus all of their reactions, comments, and reports. This cannot be undone.",
        okLabel: "delete account"
      }))) {
        return;
      }
      btn.disabled = true;
      try {
        const res = await fetch(`/api/admin/users/${id}`, { method: "DELETE" });
        const body: any = await res.json().catch(() => ({}));
        if (!res.ok) {
          setStatus(body.detail || body.error || `Failed (${res.status}).`, "error");
          btn.disabled = false;
          return;
        }
        row?.remove();
        setStatus(`Deleted @${handle} and all their content.`, "ok");
      } catch {
        setStatus("Something went wrong. Please try again.", "error");
        btn.disabled = false;
      }
    });
  });
</script>

<style>
  .admin-actions {
    display: inline-flex;
    gap: 0.4rem;
    align-items: center;
  }
  .admin-pill--banned {
    margin-left: 0.5rem;
    border-color: rgba(214, 90, 90, 0.5);
    background: rgba(214, 90, 90, 0.14);
    color: #ff9b9b;
  }
</style>
