---
import { env } from "cloudflare:workers";
import AdminLayout from "../../components/AdminLayout.astro";
import { isAdmin, isReportStatus, REPORT_STATUSES } from "../../server/admin";
import { listReports } from "../../server/db";

export const prerender = false;

if (!isAdmin(Astro.locals.user, env)) return Astro.redirect("/");

const rawStatus = Astro.url.searchParams.get("status") ?? "";
const statusFilter = isReportStatus(rawStatus) ? rawStatus : "";
const reports = await listReports(env.DB, { status: statusFilter || undefined });
---

<AdminLayout title="reports" active="reports">
  <nav class="admin-subfilter" aria-label="Filter by status">
    <a href="/admin/reports" class:list={[{ "is-active": !statusFilter }]}>all</a>
    {REPORT_STATUSES.map((s) => (
      <a href={`/admin/reports?status=${s}`} class:list={[{ "is-active": statusFilter === s }]}>{s}</a>
    ))}
  </nav>

  <p class="admin-status" data-status role="status"></p>

  {reports.length === 0 ? (
    <p class="admin-empty">No reports{statusFilter ? ` with status "${statusFilter}"` : ""}.</p>
  ) : (
    <div class="admin-table-wrap" role="region" aria-label="Reports table" tabindex="0">
    <table class="admin-table">
      <thead>
        <tr><th>when</th><th>specimen</th><th>reason</th><th>by</th><th>status</th><th>action</th></tr>
      </thead>
      <tbody>
        {reports.map((r) => (
          <tr
            data-row
            data-id={r.id}
            data-specimen-id={r.specimen_id ?? undefined}
            data-author-id={r.author_id ?? undefined}
            data-author-handle={r.author_handle ?? undefined}
          >
            <td>{r.created_at}</td>
            <td>
              {r.specimen_slug ? (
                <a href={`/c/${r.specimen_slug}`}>{r.specimen_title ?? r.specimen_slug}</a>
              ) : (
                <span class="admin-pill">deleted</span>
              )}
            </td>
            <td>
              {r.reason}
              {r.details && <div class="report-note" title={r.details}>{r.details}</div>}
            </td>
            <td>{r.reporter_handle ?? "-"}</td>
            <td><span class="admin-pill" data-status-cell>{r.status}</span></td>
            <td>
              <div class="dd" data-dd>
                <button type="button" class="dd__btn" aria-haspopup="listbox" aria-expanded="false" aria-label="New status">
                  <span class="dd__val">{r.status}</span>
                  <svg class="dd__chev" width="10" height="6" viewBox="0 0 10 6" fill="none" aria-hidden="true"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.4" /></svg>
                </button>
                <ul class="dd__menu" role="listbox" aria-label="New status" hidden>
                  {REPORT_STATUSES.map((s) => (
                    <li class="dd__opt" role="option" data-value={s} aria-selected={s === r.status ? "true" : "false"}>{s}</li>
                  ))}
                </ul>
                <select class="dd__native" data-status-select aria-hidden="true" tabindex="-1" aria-label="New status">
                  {REPORT_STATUSES.map((s) => (
                    <option value={s} selected={s === r.status}>{s}</option>
                  ))}
                </select>
              </div>
              <div class="report-actions">
                <button type="button" class="admin-btn" data-apply>save</button>
                {r.specimen_id && (
                  <button type="button" class="admin-btn admin-btn--danger" data-del-specimen data-slug={r.specimen_slug ?? r.specimen_id}>delete specimen</button>
                )}
                {r.author_id && !r.author_banned && (
                  <button type="button" class="admin-btn admin-btn--danger" data-ban-author data-handle={r.author_handle ?? "author"}>ban author</button>
                )}
                {r.author_banned ? <span class="admin-pill admin-pill--banned">author banned</span> : null}
              </div>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
    </div>
  )}
</AdminLayout>

<script>
  import { adminConfirm, adminPrompt } from "../../lib/adminDialog";

  const statusBox = document.querySelector<HTMLParagraphElement>("[data-status]");

  function setStatus(message: string, kind: "ok" | "error") {
    if (!statusBox) return;
    statusBox.textContent = message;
    statusBox.dataset.kind = kind;
  }

  document.querySelectorAll<HTMLButtonElement>("[data-apply]").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const row = btn.closest("[data-row]") as HTMLElement | null;
      const id = row?.dataset.id;
      const select = row?.querySelector("[data-status-select]") as HTMLSelectElement | null;
      if (!id || !select) return;
      btn.disabled = true;
      try {
        const res = await fetch(`/api/admin/reports/${id}`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ status: select.value })
        });
        const body: any = await res.json().catch(() => ({}));
        if (!res.ok) {
          setStatus(body.detail || body.error || `Failed (${res.status}).`, "error");
          return;
        }
        const cell = row?.querySelector("[data-status-cell]");
        if (cell) cell.textContent = select.value;
        setStatus(`Report updated to "${select.value}".`, "ok");
      } catch {
        setStatus("Something went wrong. Please try again.", "error");
      } finally {
        btn.disabled = false;
      }
    });
  });

  // After acting on the reported content, mark the report actioned (best-effort).
  async function markActioned(reportId: string): Promise<void> {
    try {
      await fetch(`/api/admin/reports/${reportId}`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ status: "actioned" })
      });
    } catch {
      /* non-fatal: the content action already succeeded */
    }
  }

  // Act-from-report: delete the reported specimen, then mark the report actioned.
  document.querySelectorAll<HTMLButtonElement>("[data-del-specimen]").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const row = btn.closest("[data-row]") as HTMLElement | null;
      const reportId = row?.dataset.id;
      const specimenId = row?.dataset.specimenId;
      const slug = btn.dataset.slug ?? "this specimen";
      if (!reportId || !specimenId) return;
      if (!(await adminConfirm({
        title: "Delete specimen",
        message: `Delete "${slug}" permanently? This cannot be undone.`,
        okLabel: "delete"
      }))) return;
      btn.disabled = true;
      try {
        const res = await fetch(`/api/admin/specimens/${specimenId}`, { method: "DELETE" });
        const body: any = await res.json().catch(() => ({}));
        if (!res.ok) {
          setStatus(body.detail || body.error || `Failed (${res.status}).`, "error");
          btn.disabled = false;
          return;
        }
        await markActioned(reportId);
        setStatus(`Deleted "${slug}" and marked the report actioned.`, "ok");
        location.reload();
      } catch {
        setStatus("Something went wrong. Please try again.", "error");
        btn.disabled = false;
      }
    });
  });

  // Act-from-report: ban the specimen's author, then mark the report actioned.
  document.querySelectorAll<HTMLButtonElement>("[data-ban-author]").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const row = btn.closest("[data-row]") as HTMLElement | null;
      const reportId = row?.dataset.id;
      const authorId = row?.dataset.authorId;
      const handle = btn.dataset.handle ?? "author";
      if (!reportId || !authorId) return;
      const reason = await adminPrompt({
        title: `Ban @${handle}`,
        message: "They can't sign in or post, and their specimens leave the Collection (reversible).",
        label: "reason (optional)",
        defaultValue: "Reported content",
        okLabel: "ban"
      });
      if (reason === null) return;
      btn.disabled = true;
      try {
        const res = await fetch(`/api/admin/users/${authorId}`, {
          method: "PATCH",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ banned: true, reason: reason || undefined })
        });
        const body: any = await res.json().catch(() => ({}));
        if (!res.ok) {
          setStatus(body.detail || body.error || `Failed (${res.status}).`, "error");
          btn.disabled = false;
          return;
        }
        await markActioned(reportId);
        setStatus(`Banned @${handle} and marked the report actioned.`, "ok");
        location.reload();
      } catch {
        setStatus("Something went wrong. Please try again.", "error");
        btn.disabled = false;
      }
    });
  });
</script>

<style>
  /* The "other"-reason free-text note, shown under the reason in the queue.
     Overrides the admin table's nowrap so it wraps and stays narrow. */
  .report-note {
    max-width: 30ch;
    margin-top: 0.3rem;
    color: var(--text-muted);
    font-size: 0.78rem;
    line-height: 1.4;
    white-space: normal;
    overflow-wrap: anywhere;
  }
  /* Act-from-report controls: status save + delete-specimen + ban-author wrap
     under the status dropdown instead of stretching the row. */
  .report-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem;
    margin-top: 0.4rem;
  }
  .admin-pill--banned {
    border-color: rgba(214, 90, 90, 0.5);
    background: rgba(214, 90, 90, 0.14);
    color: #ff9b9b;
  }
</style>
