---
import { env } from "cloudflare:workers";
import {
  SUBMIT_CATEGORIES,
  SUBMIT_LEVELS,
  SUBMIT_LICENSES,
  SUBMIT_REQUIRE_GROUPS
} from "@embody/contracts";
import Base from "../layouts/Base.astro";
import TdnYamlEditor from "../components/TdnYamlEditor";

export const prerender = false;

// Real session gate: unauthenticated visitors go to sign-in and bounce back.
const user = Astro.locals.user;
if (!user) {
  return Astro.redirect("/signin?next=/contribute");
}

const isDev = String(env.ENVIRONMENT ?? "production") !== "production";

// PUBLIC_TURNSTILE_SITE_KEY is the Cloudflare Turnstile *site* key (safe to ship
// to the browser; the matching TURNSTILE_SECRET stays server-side). When it is
// absent -- or we are in dev -- we skip mounting the real widget and fall back
// to the dev-bypass token so the form keeps working without a configured key.
// The server verifier (verifyTurnstile) still fails closed in production, so an
// unset key there means submissions are rejected rather than silently waved in.
const turnstileSiteKey = String(
  import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? ""
).trim();
const useTurnstileWidget = !isDev && Boolean(turnstileSiteKey);

const levelOptions = SUBMIT_LEVELS;
const categoryOptions = SUBMIT_CATEGORIES;
const requireGroups = SUBMIT_REQUIRE_GROUPS;
const licenseOptions = SUBMIT_LICENSES;
const defaultLicense = licenseOptions[0] ?? { value: "CC-BY-4.0", label: "CC-BY-4.0" };
---

<Base
  title="contribute a specimen - embody.tools"
  description="Share a transparent TouchDesigner Specimen with the Collection."
>
  <section class="page-section submit">
    <p class="eyebrow">contribute</p>
    <h1>share a specimen</h1>
    <p class="lede">
      paste a TDN network to share it with the Collection. every contribution is
      scanned for capability surfaces before it goes live.
    </p>

    <form class="submit-form" data-submit-form novalidate>
      <div class="submit-cols">
      <div class="submit-col submit-col--fields">
      <label class="submit-field">
        <span>title</span>
        <input type="text" name="title" required maxlength="160" placeholder="Feedback Bloom" />
        <small class="submit-error" data-error-for="title" role="alert"></small>
      </label>
      <label class="submit-field">
        <span>description</span>
        <textarea name="description" rows="3" maxlength="4000" placeholder="what it does and how to read it."></textarea>
      </label>
      <label class="submit-field">
        <span>tags <em>(comma separated)</em></span>
        <input type="text" name="tags" placeholder="feedback, generative, TOP" />
      </label>
      <div class="submit-row">
      <div class="submit-field">
        <span class="submit-field__label" id="ddlbl-level">level</span>
        <div class="dd" data-dd>
          <button type="button" class="dd__btn" aria-haspopup="listbox" aria-expanded="false" aria-labelledby="ddlbl-level dd-val-level">
            <span class="dd__val" id="dd-val-level">intermediate</span>
            <svg class="dd__chev" width="10" height="6" viewBox="0 0 10 6" fill="none" aria-hidden="true"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.4" /></svg>
          </button>
          <ul class="dd__menu" role="listbox" aria-labelledby="ddlbl-level" hidden>
            {levelOptions.map((value) => (
              <li class="dd__opt" role="option" data-value={value} aria-selected={value === "intermediate" ? "true" : "false"}>{value}</li>
            ))}
          </ul>
          <select class="dd__native" name="level" aria-hidden="true" tabindex="-1">
            {levelOptions.map((value) => (
              <option value={value} selected={value === "intermediate"}>{value}</option>
            ))}
          </select>
        </div>
      </div>
      <div class="submit-field">
        <span class="submit-field__label" id="ddlbl-categories">categories <em>(max 3)</em></span>
        <div class="msdd" data-msdd data-msdd-max="3">
          <button type="button" class="dd__btn msdd__btn" aria-haspopup="dialog" aria-expanded="false" aria-labelledby="ddlbl-categories msdd-summary-categories" data-msdd-toggle>
            <span class="dd__val msdd__summary" id="msdd-summary-categories" data-msdd-summary>generative</span>
            <svg class="dd__chev" width="10" height="6" viewBox="0 0 10 6" fill="none" aria-hidden="true"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.4" /></svg>
          </button>
          <div class="msdd__panel" data-msdd-panel hidden>
            <input class="msdd__search" type="search" placeholder="" aria-label="Search categories" data-msdd-search />
            <div class="msdd__group" data-msdd-group>
              {categoryOptions.map((value) => (
                <label class="msdd__opt" data-msdd-opt data-label={value.toLowerCase()}>
                  <input type="checkbox" name="categories" value={value} checked={value === "generative"} data-msdd-checkbox />
                  <span class="msdd__opt-label">{value}</span>
                </label>
              ))}
            </div>
            <p class="msdd__empty" data-msdd-empty hidden>no matches.</p>
          </div>
        </div>
      </div>
      <div class="submit-field">
        <span class="submit-field__label" id="ddlbl-requires">requires</span>
        <div class="msdd" data-msdd>
          <button type="button" class="dd__btn msdd__btn" aria-haspopup="dialog" aria-expanded="false" aria-labelledby="ddlbl-requires msdd-summary-requires" data-msdd-toggle>
            <span class="dd__val msdd__summary" id="msdd-summary-requires" data-msdd-summary>none</span>
            <svg class="dd__chev" width="10" height="6" viewBox="0 0 10 6" fill="none" aria-hidden="true"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.4" /></svg>
          </button>
          <div class="msdd__panel" data-msdd-panel hidden>
            <input class="msdd__search" type="search" placeholder="" aria-label="Search requirements" data-msdd-search />
            {requireGroups.map((g) => (
              <div class="msdd__group" data-msdd-group>
                <p class="msdd__group-label">{g.group}</p>
                {g.items.map((item) => (
                  <label class="msdd__opt" data-msdd-opt data-label={item.toLowerCase()}>
                    <input type="checkbox" name="requires" value={item} data-msdd-checkbox />
                    <span class="msdd__opt-label">{item}</span>
                  </label>
                ))}
              </div>
            ))}
            <p class="msdd__empty" data-msdd-empty hidden>no matches.</p>
          </div>
        </div>
      </div>
      </div>
      <div class="submit-field">
        <span class="submit-field__label" id="ddlbl-license">license</span>
        <div class="dd" data-dd>
          <button type="button" class="dd__btn" aria-haspopup="listbox" aria-expanded="false" aria-labelledby="ddlbl-license dd-val-license">
            <span class="dd__val" id="dd-val-license">{defaultLicense.label}</span>
            <svg class="dd__chev" width="10" height="6" viewBox="0 0 10 6" fill="none" aria-hidden="true"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.4" /></svg>
          </button>
          <ul class="dd__menu" role="listbox" aria-labelledby="ddlbl-license" hidden>
            {licenseOptions.map((l) => (
              <li class="dd__opt" role="option" data-value={l.value} aria-selected={l.value === defaultLicense.value ? "true" : "false"}>{l.label}</li>
            ))}
          </ul>
          <select class="dd__native" name="license" aria-hidden="true" tabindex="-1">
            {licenseOptions.map((l) => (
              <option value={l.value} selected={l.value === defaultLicense.value}>{l.label}</option>
            ))}
          </select>
        </div>
      </div>
      <label class="submit-field">
        <span>thumbnail <em>(optional image, resized to 640x360)</em></span>
        <span class="submit-file" data-file>
          <input type="file" name="thumbnail" accept="image/png,image/jpeg,image/webp" class="submit-file__input" data-file-input />
          <span class="submit-file__btn" aria-hidden="true">choose image</span>
          <span class="submit-file__name" data-file-name>no file chosen</span>
        </span>
      </label>
      <div class="submit-field">
        <span class="submit-field__label" id="vislbl">visibility</span>
        <div class="vis-seg" role="radiogroup" aria-labelledby="vislbl">
          <label class="vis-seg__opt">
            <input type="radio" name="visibility" value="private" checked />
            <span class="vis-seg__face">
              <span class="vis-seg__title">private</span>
              <span class="vis-seg__sub">only you can see it</span>
            </span>
          </label>
          <label class="vis-seg__opt">
            <input type="radio" name="visibility" value="public" />
            <span class="vis-seg__face">
              <span class="vis-seg__title">public</span>
              <span class="vis-seg__sub">live in the Collection</span>
            </span>
          </label>
        </div>
        <small class="submit-hint">Defaults to private. You can publish or unpublish anytime from the specimen page.</small>
      </div>
      </div>

      <div class="submit-col submit-col--tdn">
      <div class="submit-field submit-field--editor">
        <span>TDN (YAML)</span>
        <small class="submit-hint">
          quick export from TouchDesigner: with <a href="https://github.com/dylanroscover/Embody/releases/latest">Embody</a> running, select the COMP you want to share and press <kbd>Ctrl</kbd>/<kbd>Cmd</kbd> + <kbd>Shift</kbd> + <kbd>C</kbd>. Embody copies that COMP's whole network to your clipboard as a TDN envelope &mdash; paste it here.
        </small>
        <TdnYamlEditor
          client:load
          name="tdn"
          placeholder={'format: tdn\nversion: \'2.0\'\nname: my_network\ntype: baseCOMP\noperators: []'}
        />
      </div>
      {useTurnstileWidget && (
        <div class="submit-field submit-turnstile">
          <span>verification</span>
          <div class="cf-turnstile" data-sitekey={turnstileSiteKey} data-turnstile></div>
        </div>
      )}
      </div>
      <div class="submit-footer">
        <p class="submit-status" data-submit-status role="status"></p>
        <button type="submit" class="btn btn--primary submit-go" data-submit-go aria-disabled="true">
          contribute specimen
        </button>
      </div>
      </div>
    </form>
  </section>
</Base>

{useTurnstileWidget && (
  <script
    is:inline
    src="https://challenges.cloudflare.com/turnstile/v0/api.js"
    async
    defer
  ></script>
)}

<script define:vars={{ isDev, useTurnstileWidget }}>
  const form = document.querySelector("[data-submit-form]");
  const statusBox = document.querySelector("[data-submit-status]");
  const goBtn = document.querySelector("[data-submit-go]");

  // The Cloudflare Turnstile API object is injected onto window by the api.js
  // loader (only rendered when the widget is mounted). This is a define:vars
  // (inline, untransformed) script, so it must be plain JS -- no TS casts; read
  // the global via bracket access. It may be undefined before the loader runs.
  function getTurnstile() {
    return window["turnstile"];
  }

  function setStatus(message, kind) {
    if (!statusBox) return;
    statusBox.textContent = message;
    statusBox.dataset.kind = kind;
  }

  // Inline field errors render directly beneath the offending field (the slot is
  // <small data-error-for="NAME">). The TDN editor shows its own format error.
  function setFieldError(name, message) {
    const el = form?.querySelector(`[data-error-for="${name}"]`);
    if (!el) return;
    el.textContent = message || "";
  }

  // --- Readiness gate -------------------------------------------------------
  // The submit button is greyed (aria-disabled) until the title is filled AND
  // the TDN parses to a mapping. It stays clickable on purpose: a truly
  // `disabled` button fires no click, so we could never explain WHY it isn't
  // ready. The TDN editor (a React island) validates on every edit and
  // broadcasts a bubbling `tdn:change` event carrying its validity -- so the
  // button never lights up on unparseable YAML and re-checks after any edit.
  function titleEl() {
    return form?.querySelector('[name="title"]');
  }
  function titleMissing() {
    const el = titleEl();
    return !el || !String(el.value || "").trim();
  }

  let tdnValid = false;
  form?.addEventListener("tdn:change", (event) => {
    tdnValid = Boolean(event.detail && event.detail.valid);
    refreshReady();
  });

  function isReady() {
    return !titleMissing() && tdnValid;
  }

  function refreshReady() {
    if (!goBtn) return;
    goBtn.setAttribute("aria-disabled", isReady() ? "false" : "true");
  }

  form?.addEventListener("input", () => {
    if (!titleMissing()) setFieldError("title", "");
    refreshReady();
  });
  refreshReady();

  // NOTE: sign-out lives in a SEPARATE bundled <script> below. A `define:vars`
  // script is emitted inline and untransformed, so `import("../lib/authClient")`
  // here would not be bundled -- the browser would fetch the literal path and
  // 404, silently breaking sign-out. The bundled script gets a real asset URL.

  // Resize a chosen thumbnail to a 640x360 (16:9) cover-cropped WebP on the
  // client, so a multi-MB original never gets uploaded for a small card slot.
  // The API + R2 also enforce WebP + a byte cap as defense in depth.
  async function thumbDataUrl(file) {
    const bitmap = await createImageBitmap(file);
    const W = 640;
    const H = 360;
    const canvas = document.createElement("canvas");
    canvas.width = W;
    canvas.height = H;
    const ctx = canvas.getContext("2d");
    if (!ctx) throw new Error("canvas unavailable");
    // cover: scale to fill the 16:9 box, then center-crop the overflow.
    const scale = Math.max(W / bitmap.width, H / bitmap.height);
    const dw = bitmap.width * scale;
    const dh = bitmap.height * scale;
    ctx.drawImage(bitmap, (W - dw) / 2, (H - dh) / 2, dw, dh);
    bitmap.close();
    return canvas.toDataURL("image/webp", 0.82);
  }

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();
    if (!goBtn) return;
    const data = new FormData(form);

    const title = String(data.get("title") || "").trim();
    const tdnRaw = String(data.get("tdn") || "").trim();
    if (!isReady()) {
      // Summarize what's missing near the button, inline the title error under
      // the title field, and land focus on the first problem. The TDN editor
      // shows its own format error live, so we don't duplicate it here.
      const probs = [];
      if (titleMissing()) probs.push("a title");
      if (!tdnValid) probs.push("a valid TDN network");
      setFieldError("title", titleMissing() ? "add a title." : "");
      const list =
        probs.length === 1
          ? probs[0]
          : probs.slice(0, -1).join(", ") + " and " + probs[probs.length - 1];
      setStatus(`add ${list} before contributing.`, "error");
      const focusTarget = titleMissing() ? titleEl() : form?.querySelector('[name="tdn"]');
      if (focusTarget) {
        focusTarget.focus();
        focusTarget.scrollIntoView({ behavior: "smooth", block: "center" });
      }
      return;
    }
    // The client gates submit on valid-YAML-that-is-a-mapping (see TdnYamlEditor
    // validateTdn). The server re-validates and runs the capability scan.

    const tags = String(data.get("tags") || "")
      .split(",")
      .map((t) => t.trim())
      .filter(Boolean);

    // Categories: at least one is required (max 3 is enforced by the picker).
    const categoriesSel = data.getAll("categories").map(String);
    if (categoriesSel.length === 0) {
      setStatus("choose at least one category.", "error");
      return;
    }

    // Resolve the Turnstile token. When the real widget is mounted
    // (useTurnstileWidget: production with a PUBLIC_TURNSTILE_SITE_KEY), read its
    // response token; the server then verifies it with siteverify. Otherwise
    // (dev, or no site key configured) fall back to the dev-bypass token so the
    // form keeps working -- the server verifier only honors that token outside
    // production and fails closed in prod, so this never weakens the live gate.
    let turnstileToken = "dev-bypass";
    if (useTurnstileWidget) {
      const ts = getTurnstile();
      const fromApi = ts && typeof ts.getResponse === "function" ? ts.getResponse() : "";
      const fromField = String(data.get("cf-turnstile-response") || "");
      turnstileToken = String(fromApi || fromField || "");
      if (!turnstileToken) {
        setStatus("please complete the verification challenge.", "error");
        return;
      }
    }


    // Optional thumbnail: resize to a 640x360 WebP on the client (thumbDataUrl)
    // so a multi-MB original never reaches a small card slot; the API stores the
    // result in R2 (putThumbnail). Skipped when no file is chosen.
    let thumbnail;
    const thumbFile = data.get("thumbnail");
    if (thumbFile && typeof thumbFile === "object" && "size" in thumbFile && thumbFile.size > 0) {
      if (thumbFile.size > 8_000_000) {
        setStatus("thumbnail source is too large (max 8 MB).", "error");
        return;
      }
      try {
        thumbnail = await thumbDataUrl(thumbFile);
      } catch (err) {
        console.error("thumbnail resize failed", err);
        setStatus("could not process the thumbnail image.", "error");
        return;
      }
    }

    const payload = {
      title,
      description: String(data.get("description") || "").trim(),
      tags,
      license: String(data.get("license") || "CC-BY-4.0").trim() || "CC-BY-4.0",
      level: String(data.get("level") || "intermediate"),
      categories: categoriesSel,
      requires: data.getAll("requires").map(String),
      tdn: tdnRaw,
      thumbnail,
      visibility: data.get("visibility") === "public" ? "public" : "private",
      turnstileToken
    };

    goBtn.disabled = true;
    const original = goBtn.textContent;
    goBtn.textContent = "contributing...";
    setStatus("scanning and contributing...", "pending");

    try {
      const res = await fetch("/api/specimens", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload)
      });
      const body = await res.json().catch(() => ({}));
      if (res.status === 401) {
        setStatus("your session expired. redirecting to sign in...", "error");
        window.location.assign("/signin?next=/contribute");
        return;
      }
      if (!res.ok) {
        setStatus(body.detail || body.error || `contribution failed (${res.status}).`, "error");
        return;
      }
      setStatus("contributed. redirecting to your specimen...", "ok");
      window.location.assign(`/c/${body.slug}`);
    } catch (err) {
      console.error("submit failed", err);
      setStatus("something went wrong. please try again.", "error");
    } finally {
      goBtn.disabled = false;
      goBtn.textContent = original;
      refreshReady();
      // Turnstile tokens are single-use; reset the widget so a retry gets a
      // fresh challenge token instead of replaying a now-spent one.
      if (useTurnstileWidget) {
        const ts = getTurnstile();
        if (ts && typeof ts.reset === "function") ts.reset();
      }
    }
  });
</script>

<script>
  // App-native dropdowns for the contribute form. Each .dd wraps a
  // visually-hidden native <select> (the value the form's FormData reads via
  // data.get("level"/"category"/"requires")) plus a styled trigger + ARIA
  // listbox. Choosing an option writes the native select's value and dispatches
  // a 'change' event, so the submitted value tracks the visible choice. Mirrors
  // the collection page's [data-dd] behavior. This is a bundled module script
  // (real asset URL), so it is typed TS like the collection page's dropdown JS.

  // One-open-at-a-time across BOTH dropdown systems (.dd single-selects and the
  // .msdd "requires" multi-select). Opening any dropdown broadcasts this event;
  // every other dropdown listens and closes itself, so only one is ever open.
  const DD_OPEN_EVENT = "contribute:dropdown-open";
  const broadcastDropdownOpen = (source: Element): void => {
    document.dispatchEvent(new CustomEvent(DD_OPEN_EVENT, { detail: { source } }));
  };

  // Multi-select grouped "requires" picker(s). Checkboxes carry name="requires"
  // so FormData.getAll collects them; the trigger summary reflects the count.
  document.querySelectorAll<HTMLElement>("[data-msdd]").forEach((msdd) => {
    const toggle = msdd.querySelector("[data-msdd-toggle]") as HTMLButtonElement | null;
    const panel = msdd.querySelector("[data-msdd-panel]") as HTMLElement | null;
    const summary = msdd.querySelector("[data-msdd-summary]") as HTMLElement | null;
    const search = msdd.querySelector("[data-msdd-search]") as HTMLInputElement | null;
    const empty = msdd.querySelector("[data-msdd-empty]") as HTMLElement | null;
    const groups = Array.from(msdd.querySelectorAll("[data-msdd-group]")) as HTMLElement[];
    const boxes = Array.from(
      msdd.querySelectorAll("[data-msdd-checkbox]")
    ) as HTMLInputElement[];
    if (!toggle || !panel || !summary) return;
    const tg = toggle;
    const pn = panel;
    const sm = summary;
    // Optional selection cap (e.g. categories allow at most 3). Infinity = no cap.
    const max = Number(msdd.getAttribute("data-msdd-max")) || Infinity;
    let open = false;

    const refresh = (): void => {
      const picked = boxes.filter((b) => b.checked).map((b) => b.value);
      sm.textContent =
        picked.length === 0
          ? "none"
          : picked.length === 1
            ? picked[0] ?? ""
            : `${picked.length} selected`;
      // At the cap, lock the remaining unchecked boxes so the user cannot exceed
      // it; unlock them again once a selection is removed.
      if (Number.isFinite(max)) {
        const atCap = picked.length >= max;
        boxes.forEach((b) => { b.disabled = atCap && !b.checked; });
      }
    };
    const applyFilter = (q: string): void => {
      const needle = q.trim().toLowerCase();
      let anyVisible = false;
      groups.forEach((g) => {
        // A group-name match (e.g. "depth") reveals the whole group.
        const groupLabel = (g.querySelector(".msdd__group-label")?.textContent || "").toLowerCase();
        const groupMatch = needle.length > 0 && groupLabel.includes(needle);
        let groupVisible = false;
        g.querySelectorAll<HTMLElement>("[data-msdd-opt]").forEach((opt) => {
          const match = !needle || groupMatch || (opt.getAttribute("data-label") || "").includes(needle);
          opt.hidden = !match;
          if (match) groupVisible = true;
        });
        g.hidden = !groupVisible;
        if (groupVisible) anyVisible = true;
      });
      if (empty) empty.hidden = anyVisible;
    };
    const setOpen = (next: boolean): void => {
      open = next;
      pn.hidden = !next;
      tg.setAttribute("aria-expanded", next ? "true" : "false");
      if (next) {
        broadcastDropdownOpen(msdd);
        if (search) search.focus();
      }
    };

    tg.addEventListener("click", (e) => {
      e.stopPropagation();
      setOpen(!open);
    });
    // Close when any OTHER dropdown opens.
    document.addEventListener(DD_OPEN_EVENT, (e) => {
      if ((e as CustomEvent).detail?.source !== msdd) setOpen(false);
    });
    search?.addEventListener("input", () => applyFilter(search.value));
    boxes.forEach((b) => b.addEventListener("change", refresh));
    document.addEventListener("click", (e) => {
      if (!msdd.contains(e.target as Node)) setOpen(false);
    });
    msdd.addEventListener("keydown", (e) => {
      if ((e as KeyboardEvent).key === "Escape") {
        setOpen(false);
        tg.focus();
      }
    });
    refresh();
  });

  const closeDropdown = (dd: Element): void => {
    dd.removeAttribute("data-open");
    const menu = dd.querySelector(".dd__menu");
    if (menu) (menu as HTMLElement).hidden = true;
    const button = dd.querySelector(".dd__btn");
    if (button) button.setAttribute("aria-expanded", "false");
  };

  // Unique id seed so every option across the dropdowns gets a stable id for
  // aria-activedescendant (the listbox points at the active option's id).
  let ddOptSeq = 0;
  const dropdowns = Array.from(document.querySelectorAll(".dd[data-dd]"));

  dropdowns.forEach((dd) => {
    const btn = dd.querySelector(".dd__btn") as HTMLButtonElement | null;
    const menu = dd.querySelector(".dd__menu") as HTMLElement | null;
    const valEl = dd.querySelector(".dd__val") as HTMLElement | null;
    const native = dd.querySelector(".dd__native") as HTMLSelectElement | null;
    const opts = Array.from(dd.querySelectorAll(".dd__opt")) as HTMLElement[];
    if (!btn || !menu || !valEl || !native) return;

    // Optional search filter (present only on dropdowns with a .dd__search).
    // Hides non-matching options; never steals focus, so arrow-key nav from the
    // button still works exactly as before on dropdowns without a search.
    const ddSearch = dd.querySelector(".dd__search") as HTMLInputElement | null;
    const ddEmpty = dd.querySelector(".dd__empty") as HTMLElement | null;
    const filterOpts = (q: string): void => {
      const needle = q.trim().toLowerCase();
      let any = false;
      opts.forEach((o) => {
        const match = !needle || (o.textContent || "").toLowerCase().includes(needle);
        o.hidden = !match;
        if (match) any = true;
      });
      if (ddEmpty) ddEmpty.hidden = any;
    };
    if (ddSearch) {
      ddSearch.addEventListener("input", () => filterOpts(ddSearch.value));
      ddSearch.addEventListener("keydown", (e: KeyboardEvent) => {
        if (e.key === "Enter") e.preventDefault(); // never submit the form from here
        else if (e.key === "Escape") {
          e.preventDefault();
          closeDropdown(dd);
          btn.focus();
        }
      });
      ddSearch.addEventListener("click", (e) => e.stopPropagation());
    }

    // Give every option a stable id so the listbox can name the ACTIVE option
    // via aria-activedescendant (focus stays on the button; this is how a
    // screen reader announces the highlighted option without moving DOM focus).
    opts.forEach((opt) => {
      if (!opt.id) opt.id = `dd-opt-${ddOptSeq++}`;
    });

    // The active (keyboard-highlighted) option index. -1 == none highlighted.
    let active = -1;
    const setActive = (index: number): void => {
      const next = Math.max(0, Math.min(index, opts.length - 1));
      const opt = opts[next];
      if (!opt) return;
      opts.forEach((o, i) => o.classList.toggle("is-active", i === next));
      active = next;
      menu.setAttribute("aria-activedescendant", opt.id);
      opt.scrollIntoView({ block: "nearest" });
    };
    const clearActive = (): void => {
      active = -1;
      opts.forEach((o) => o.classList.remove("is-active"));
      menu.removeAttribute("aria-activedescendant");
    };

    const open = (highlightSelected = true): void => {
      broadcastDropdownOpen(dd);
      dd.setAttribute("data-open", "");
      menu.hidden = false;
      btn.setAttribute("aria-expanded", "true");
      if (ddSearch) { ddSearch.value = ""; filterOpts(""); }
      if (highlightSelected) {
        // Open with the currently-selected option highlighted (or the first).
        const sel = opts.findIndex((o) => o.getAttribute("aria-selected") === "true");
        setActive(sel >= 0 ? sel : 0);
      }
    };
    const close = (): void => {
      clearActive();
      closeDropdown(dd);
    };
    const choose = (opt: HTMLElement): void => {
      if (opt.hidden) return;
      native.value = opt.getAttribute("data-value") || "";
      native.dispatchEvent(new Event("change", { bubbles: true }));
      valEl.textContent = opt.textContent;
      opts.forEach((o) => o.setAttribute("aria-selected", String(o === opt)));
      close();
      btn.focus();
    };

    btn.addEventListener("click", () => {
      if (dd.hasAttribute("data-open")) close();
      else open();
    });
    // Close when any OTHER dropdown opens (sibling .dd or the .msdd picker).
    document.addEventListener(DD_OPEN_EVENT, (e) => {
      if ((e as CustomEvent).detail?.source !== dd) close();
    });
    btn.addEventListener("keydown", (e: KeyboardEvent) => {
      const isOpen = dd.hasAttribute("data-open");
      switch (e.key) {
        case "Escape":
          if (isOpen) {
            e.preventDefault();
            close();
            btn.focus();
          }
          return;
        case "Tab":
          // Tab moves focus away -- close without swallowing the Tab.
          if (isOpen) close();
          return;
        case "Enter":
        case " ": {
          e.preventDefault();
          if (!isOpen) {
            open();
            return;
          }
          const activeOpt = active >= 0 ? opts[active] : undefined;
          if (activeOpt) choose(activeOpt);
          return;
        }
        case "ArrowDown":
          e.preventDefault();
          if (!isOpen) {
            open();
            return;
          }
          setActive(active < 0 ? 0 : active + 1);
          return;
        case "ArrowUp":
          e.preventDefault();
          if (!isOpen) {
            open();
            return;
          }
          setActive(active < 0 ? opts.length - 1 : active - 1);
          return;
        case "Home":
          if (isOpen) {
            e.preventDefault();
            setActive(0);
          }
          return;
        case "End":
          if (isOpen) {
            e.preventDefault();
            setActive(opts.length - 1);
          }
          return;
        default:
          return;
      }
    });

    // Pointer: hover syncs the active highlight so mouse + keyboard agree.
    opts.forEach((opt, i) => {
      opt.addEventListener("click", () => choose(opt));
      opt.addEventListener("mousemove", () => setActive(i));
    });
  });

  document.addEventListener("click", (e: MouseEvent) => {
    const target = e.target instanceof Node ? e.target : null;
    dropdowns.forEach((dd) => {
      if (dd.hasAttribute("data-open") && (target === null || !dd.contains(target))) {
        closeDropdown(dd);
      }
    });
  });
  document.addEventListener("keydown", (e: KeyboardEvent) => {
    if (e.key === "Escape") dropdowns.forEach((dd) => closeDropdown(dd));
  });

  // App-native file picker: mirror the chosen filename into the styled span
  // (the OS-rendered "No file chosen" text lives on the hidden input and can't
  // be styled). data-has-file switches the name from faint placeholder to text.
  const fileInput = document.querySelector("[data-file-input]") as HTMLInputElement | null;
  const fileName = document.querySelector("[data-file-name]") as HTMLElement | null;
  if (fileInput && fileName) {
    const PLACEHOLDER = "no file chosen";
    fileInput.addEventListener("change", () => {
      const picked = fileInput.files?.[0]?.name ?? "";
      fileName.textContent = picked || PLACEHOLDER;
      if (picked) fileName.setAttribute("data-has-file", "");
      else fileName.removeAttribute("data-has-file");
    });
  }
</script>

<style>
  /* Centered reading column, same treatment as the manifesto body: a narrow
     max-width with auto inline margins so the whole form sits centered on the
     page instead of pinned to the left gutter. */
  .submit {
    max-width: 72rem;
    margin-inline: auto;
    padding-bottom: 56px;
  }

  .submit h1 {
    font-size: clamp(2.3rem, 5.5vw, 4.6rem);
  }

  .submit-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .submit-who {
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  .submit-who a {
    color: var(--accent);
    font-weight: 600;
  }

  .submit-signout {
    margin-left: 0.75rem;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    color: var(--text-muted);
    padding: 0.25rem 0.6rem;
    font-size: 0.8rem;
    cursor: pointer;
  }

  .submit-signout:hover {
    color: var(--text);
    border-color: var(--accent);
  }

  .submit-form {
    margin-top: 2rem;
    max-width: 100%;
  }

  /* Two columns: metadata fields on the left, the large live TDN editor (plus
     verification + status + submit) on the right, so as much as possible sits
     above the fold. The whole form sits inside one bordered panel (matching the
     site's .pillar cards). Collapses to a single column on narrow viewports. */
  .submit-cols {
    display: grid;
    grid-template-columns: minmax(0, 30rem) minmax(0, 1fr);
    column-gap: 2rem;
    /* Row gap (the space above the full-width submit footer) tracks the card's
       bottom padding exactly, so the button is equidistant from the editor's
       bottom edge and the card's bottom edge at every viewport. */
    row-gap: clamp(1.25rem, 3vw, 2rem);
    align-items: start;
    padding: clamp(1.25rem, 3vw, 2rem);
    border: 1px solid var(--border-faint);
    border-radius: var(--radius);
    background: var(--bg-elevated);
  }

  .submit-col {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
    min-width: 0;
  }

  /* Stretch the editor column to the full row height (overriding the grid's
     align-items: start) so the editor's bottom edge lines up with the taller
     fields column. Without this the shorter column leaves dead space, and the
     centered submit button below ends up further from the editor's bottom than
     from the card's bottom edge. The editor field (flex: 1) fills the stretch.
     align-self works against an auto grid row where min-height: 100% does not. */
  .submit-col--tdn {
    align-self: stretch;
  }

  .submit-field--editor {
    flex: 1;
    min-height: 0;
  }

  @media (max-width: 60rem) {
    .submit-cols {
      grid-template-columns: 1fr;
    }
  }

  .submit-field {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  /* Inline error beneath a field (title); the TDN editor renders its own. */
  .submit-error {
    font-size: 0.8rem;
    line-height: 1.4;
    color: #ff9b9b;
  }

  /* The three short dropdowns (level / category / requires) share one
     row on wider screens, collapsing to a stack on narrow viewports. */
  .submit-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.1rem;
    align-items: start;
  }

  @media (max-width: 34rem) {
    .submit-row {
      grid-template-columns: 1fr;
    }
  }

  .submit-field > span {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--text-muted);
    /* Labels never wrap -- a 2-line label shoves its dropdown out of row alignment. */
    white-space: nowrap;
  }

  .submit-field > span em {
    text-transform: none;
    letter-spacing: 0;
    color: var(--text-faint);
    font-style: normal;
  }

  .submit-field input,
  .submit-field textarea {
    padding: 0.65rem 0.75rem;
    background-color: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    color: var(--text);
    /* Match the inputs -- a bare <textarea> defaults to the browser monospace. */
    font-family: inherit;
    font-size: 1rem;
    font-weight: inherit;
  }

  /* ---- App-native dropdown ---- */
  /* A styled trigger + ARIA listbox over a visually-hidden native <select>.
     Replaces the OS/browser-native <select> so the option list matches the
     dark UI instead of the OS theme. Mirrors the collection page's .dd*. The
     hidden <select class="dd__native"> still carries the form value (its
     name + options are submitted via FormData). */
  .dd {
    position: relative;
    display: inline-flex;
    align-self: flex-start;
  }

  /* Visually-hidden value carrier the form's FormData reads/writes. */
  .dd__native {
    position: absolute;
    width: 1px;
    height: 1px;
    margin: -1px;
    padding: 0;
    border: 0;
    opacity: 0;
    overflow: hidden;
    clip: rect(0 0 0 0);
    pointer-events: none;
  }

  .dd__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background-color: var(--bg);
    padding: 0.65rem 0.9rem;
    color: var(--text);
    font-size: 1rem;
    line-height: 1;
    cursor: pointer;
    transition: border-color 140ms ease;
  }

  .dd__btn:hover {
    border-color: var(--accent);
  }

  .dd__btn:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }

  .dd[data-open] .dd__btn {
    border-color: var(--accent);
  }

  .dd__val {
    white-space: nowrap;
  }

  .dd__chev {
    flex: none;
    color: var(--text-faint);
    transition: transform 180ms ease;
  }

  .dd[data-open] .dd__chev {
    transform: rotate(180deg);
  }

  .dd__menu {
    position: absolute;
    top: calc(100% + 6px);
    left: 0;
    z-index: 60;
    min-width: 100%;
    width: max-content;
    /* Wide enough for the longest license label; never past the viewport edge. */
    max-width: min(28rem, calc(100vw - 2rem));
    max-height: 16rem;
    margin: 0;
    padding: 0.3rem;
    list-style: none;
    overflow-y: auto;
    border: 1px solid var(--border);
    border-radius: 12px;
    background: var(--bg-elevated, #14181a);
    box-shadow: 0 18px 44px -20px rgba(0, 0, 0, 0.85);
  }

  .dd__menu[hidden] {
    display: none;
  }

  .dd__opt {
    display: block;
    padding: 0.5rem 0.7rem;
    border-radius: 7px;
    color: var(--text-muted, #b6bfb8);
    font-size: 0.92rem;
    white-space: nowrap;
    cursor: pointer;
  }

  .dd__opt:hover,
  .dd__opt.is-active {
    background: var(--accent-dim, rgba(120, 200, 150, 0.14));
    color: var(--accent);
  }

  .dd__opt[aria-selected="true"] {
    color: var(--accent);
  }

  .dd__opt[hidden] { display: none; }

  /* Sticky search field at the top of a searchable .dd menu (e.g. category). */
  .dd__search-row {
    position: sticky;
    top: -0.3rem;
    margin: -0.3rem -0.3rem 0.3rem;
    padding: 0.3rem;
    background: var(--bg-elevated, #14181a);
  }
  .submit-field .dd__search,
  .submit-field .msdd__search {
    width: 100%;
    padding: 0.4rem 0.6rem 0.4rem 1.9rem;
    border: 1px solid var(--border);
    border-radius: 7px;
    background: var(--bg)
      url("data:image/svg+xml,%3Csvg%20xmlns='http://www.w3.org/2000/svg'%20width='14'%20height='14'%20viewBox='0%200%2024%2024'%20fill='none'%20stroke='%23889'%20stroke-width='2'%20stroke-linecap='round'%3E%3Ccircle%20cx='11'%20cy='11'%20r='7'/%3E%3Cpath%20d='M21%2021l-4.3-4.3'/%3E%3C/svg%3E")
      no-repeat left 0.6rem center;
    background-size: 14px;
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 0.78rem;
  }
  .submit-field .dd__search::placeholder,
  .submit-field .msdd__search::placeholder { color: var(--text-faint); }
  .submit-field input.dd__search:focus,
  .submit-field input.msdd__search:focus { outline: none; border-color: var(--accent); }
  .dd__search::-webkit-search-cancel-button,
  .msdd__search::-webkit-search-cancel-button { cursor: pointer; }
  .dd__empty {
    padding: 0.5rem 0.7rem;
    color: var(--text-faint);
    font-size: 0.85rem;
  }
  .dd__empty[hidden] { display: none; }

  .submit-turnstile .cf-turnstile {
    margin-top: 0.25rem;
    /* Reserve the managed widget's box (~300x65) so the async Cloudflare iframe
       lands into pre-sized space instead of expanding 0 -> 65px and shoving the
       submit footer down after paint. Production-only widget, so DEV never sees
       the shift -- the reserve just makes the first paint match the mounted size. */
    min-height: 65px;
  }

  /* ---- App-native file picker ----
     The OS-rendered "Choose File" button + "No file chosen" text can't be
     restyled via CSS, so the real <input type=file> is visually hidden and a
     styled button + filename span stand in. The input stays inside the <label>,
     so clicking anywhere on the row still opens the native picker; a small
     script (data-file-input) mirrors the chosen filename into .submit-file__name. */
  .submit-file {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    padding: 0.4rem 0.5rem;
    background-color: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: border-color 140ms ease;
  }

  .submit-file:hover {
    border-color: var(--accent);
  }

  /* Visually-hidden real input -- label association still opens the picker. */
  .submit-file__input {
    position: absolute;
    width: 1px;
    height: 1px;
    margin: -1px;
    padding: 0;
    border: 0;
    opacity: 0;
    overflow: hidden;
    clip: rect(0 0 0 0);
  }

  .submit-file__btn {
    display: inline-flex;
    align-items: center;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background-color: var(--bg-elevated);
    padding: 0.4rem 0.85rem;
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    white-space: nowrap;
    transition: border-color 140ms ease, color 140ms ease;
  }

  .submit-file:hover .submit-file__btn {
    border-color: var(--accent);
    color: var(--accent);
  }

  .submit-file__name {
    min-width: 0;
    flex: 1;
    font-size: 0.85rem;
    color: var(--text-faint);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .submit-file__name[data-has-file] {
    color: var(--text);
  }

  /* Keyboard focus ring on the styled button when the hidden input is focused. */
  .submit-file__input:focus-visible ~ .submit-file__btn {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }

  /* Help line under the TDN box: how to grab a network from TD in one shortcut. */
  .submit-hint {
    font-size: 0.8rem;
    line-height: 1.5;
    color: var(--text-faint);
  }

  .submit-hint a {
    color: var(--accent);
    text-decoration: none;
  }

  .submit-hint a:hover {
    text-decoration: underline;
  }

  .submit-hint kbd {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    padding: 0.05rem 0.32rem;
    border: 1px solid var(--border);
    border-bottom-width: 2px;
    border-radius: 4px;
    background: var(--bg);
    color: var(--text-muted);
    white-space: nowrap;
  }

  .submit-field input:focus,
  .submit-field textarea:focus {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }

  /* Visibility: a two-option segmented control (private default / public).
     Native radios drive the value via FormData; the .vis-seg__face is the styled
     surface, lit by the checked radio (the real input is visually hidden). */
  .vis-seg {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.6rem;
  }
  .vis-seg__opt {
    margin: 0;
    cursor: pointer;
  }
  .vis-seg__opt input {
    position: absolute;
    width: 1px;
    height: 1px;
    margin: -1px;
    padding: 0;
    border: 0;
    opacity: 0;
    overflow: hidden;
    clip: rect(0 0 0 0);
  }
  .vis-seg__face {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 0.6rem 0.8rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--bg);
    transition: border-color 140ms ease, background 140ms ease;
  }
  .vis-seg__opt:hover .vis-seg__face {
    border-color: var(--accent);
  }
  .vis-seg__opt input:checked + .vis-seg__face {
    border-color: var(--accent);
    background: rgba(110, 230, 104, 0.08);
  }
  .vis-seg__opt input:focus-visible + .vis-seg__face {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }
  .vis-seg__title {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    text-transform: lowercase;
    color: var(--text);
  }
  .vis-seg__opt input:checked + .vis-seg__face .vis-seg__title {
    color: var(--accent);
  }
  .vis-seg__sub {
    font-size: 0.75rem;
    line-height: 1.3;
    color: var(--text-faint);
  }

  /* Status + submit span both columns at the bottom of the panel, centered
     under the whole form (grid-column: 1 / -1 keeps them inside the card). */
  .submit-footer {
    grid-column: 1 / -1;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* Symmetric vertical breathing room: the gap above the button (the grid's
     row gap, from the editor's bottom edge) matches the gap below it (the card's
     bottom padding). */
  .submit-footer .submit-status {
    width: 100%;
    max-width: 30rem;
    text-align: center;
  }

  /* Space the status from the button ONLY when it carries a message. An empty
     status must add nothing, or it offsets the button and breaks the symmetry.
     This has to be gated on :not(:empty) rather than zeroed via
     .submit-status:empty, because Astro's scoping appends a [data-astro-cid]
     attribute to each compound -- making the two-part descendant selector
     (0,4,0) outweigh the single-part .submit-status:empty (0,3,0), so :empty
     could never win. Gating the margin on content sidesteps the cascade. */
  .submit-footer .submit-status:not(:empty) {
    margin-bottom: 1.1rem;
  }

  /* Not-ready state: greyed while required fields are empty. The button stays
     clickable (aria-disabled, not the disabled attribute) so a click can
     explain what's missing -- a real disabled button fires no click. Higher
     specificity than .btn--primary[:hover] so it wins over the green. */
  .submit-go[aria-disabled="true"],
  .submit-go[aria-disabled="true"]:hover {
    background: var(--bg-elevated-2);
    color: var(--text-faint);
    cursor: not-allowed;
    transform: none;
  }

  .submit-status {
    margin-top: 0;
    padding: 0.65rem 0.75rem;
    border-radius: var(--radius-sm);
    font-size: 0.9rem;
    border: 1px solid var(--border);
  }

  .submit-status[data-kind="error"] {
    background: rgba(220, 80, 80, 0.12);
    border-color: rgba(220, 80, 80, 0.4);
    color: #ff9b9b;
  }

  .submit-status[data-kind="ok"] {
    background: rgba(110, 230, 104, 0.12);
    border-color: rgba(110, 230, 104, 0.4);
    color: var(--accent);
  }

  /* Empty -> collapsed, but the element STAYS in the DOM / a11y tree (never
     display:none or hidden) so this role=status/alert live region is registered
     before its first message lands -- otherwise some screen readers swallow it. */
  .submit-status:empty {
    margin: 0;
    padding: 0;
    border-width: 0;
  }

  .submit-back {
    margin-top: 2rem;
  }

  .submit-back a {
    color: var(--accent);
    font-family: var(--font-display);
    font-weight: 600;
  }

  .submit-back a:hover {
    color: var(--text);
  }

  /* Touch targets: on coarse pointers (touch) the padding-only controls fall
     under the 44px minimum. Bump inputs/selects/file control and the back link
     to >=44px. The submit button is the global .btn (46px), already fine. */
  @media (pointer: coarse) {
    .submit-field input,
    .dd__btn {
      min-height: 44px;
    }

    .dd__opt {
      min-height: 44px;
      display: flex;
      align-items: center;
    }

    .submit-file {
      min-height: 44px;
    }

    .submit-back a {
      display: inline-flex;
      align-items: center;
      min-height: 44px;
    }
  }
</style>
