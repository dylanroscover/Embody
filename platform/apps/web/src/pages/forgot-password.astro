---
import Base from "../layouts/Base.astro";

export const prerender = false;

// If already signed in, there is nothing to reset -- send them to their profile.
const user = Astro.locals.user;
if (user) {
  return Astro.redirect(`/u/${user.handle}`);
}
---

<Base
  title="forgot password - embody.tools"
  description="request a password reset link for your embody.tools account."
>
  <section class="page-section auth">
    <p class="eyebrow">account</p>
    <h1 id="auth-heading">forgot password</h1>
    <p class="lede">
      enter the email address for your account and we&rsquo;ll send a link to
      reset your password. the link expires in one hour.
    </p>

    <div class="auth-card">
      <p class="auth-error" data-auth-error role="alert"></p>
      <p class="auth-notice" data-auth-notice role="status"></p>

      <form class="auth-form" data-forgot-form novalidate>
        <label class="auth-field">
          <span>email</span>
          <input type="email" name="email" autocomplete="email" required placeholder="you@example.com" />
        </label>
        <button type="submit" class="btn btn--primary auth-submit" data-forgot-submit>
          send reset link
        </button>
      </form>
    </div>

    <p class="auth-back">
      <a href="/signin"><span aria-hidden="true">&larr;</span> back to sign in</a>
    </p>
  </section>
</Base>

<script>
  import { authClient } from "../lib/authClient";

  const form = document.querySelector("[data-forgot-form]") as HTMLFormElement | null;
  const errorBox = document.querySelector("[data-auth-error]") as HTMLParagraphElement | null;
  const noticeBox = document.querySelector("[data-auth-notice]") as HTMLParagraphElement | null;
  const submitBtn = document.querySelector("[data-forgot-submit]") as HTMLButtonElement | null;

  function showError(message: string) {
    if (!errorBox) return;
    errorBox.textContent = message;
  }

  function clearError() {
    if (!errorBox) return;
    errorBox.textContent = "";
  }

  function showNotice(message: string) {
    if (!noticeBox) return;
    noticeBox.textContent = message;
  }

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();
    clearError();
    if (!submitBtn) return;

    const data = new FormData(form);
    const email = String(data.get("email") || "").trim();
    if (!email) {
      showError("email is required.");
      return;
    }

    submitBtn.disabled = true;
    const original = submitBtn.textContent;
    submitBtn.textContent = "sending...";

    try {
      // Better Auth sends the reset link to reset-password with ?token=...
      // appended. The send itself no-ops server-side when no email provider is
      // configured, so we always show the same neutral confirmation -- this
      // also avoids leaking whether an address has an account.
      const res = await authClient.requestPasswordReset({
        email,
        redirectTo: `${window.location.origin}/reset-password`
      });
      if (res.error) {
        showError(res.error.message || "could not send the reset link.");
        return;
      }
      form.hidden = true;
      showNotice(
        "If an account exists for that email, a reset link is on its way. Check your inbox."
      );
    } catch (err) {
      console.error("password reset request failed", err);
      showError("something went wrong. please try again.");
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = original;
    }
  });
</script>

<style>
  .auth {
    padding-bottom: 56px;
  }

  .auth-card {
    margin-top: 2rem;
    max-width: 30rem;
    padding: 1.75rem;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }

  /* Center the single card on wide screens so it doesn't strand in the left
     third of the viewport (signin uses a two-column layout; this page is one
     card, so just center it). */
  @media (min-width: 861px) {
    .auth-card {
      margin-inline: auto;
    }
  }

  .auth-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .auth-field {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .auth-field > span {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .auth-field input {
    padding: 0.65rem 0.75rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    color: var(--text);
    font-size: 1rem;
  }

  .auth-field input:focus {
    outline: 2px solid var(--accent);
    outline-offset: 1px;
    border-color: var(--accent);
  }

  .auth-submit {
    margin-top: 0.25rem;
    width: 100%;
    justify-content: center;
  }

  .auth-error {
    margin-bottom: 1rem;
    padding: 0.65rem 0.75rem;
    background: rgba(220, 80, 80, 0.12);
    border: 1px solid rgba(220, 80, 80, 0.4);
    border-radius: var(--radius-sm);
    color: #ff9b9b;
    font-size: 0.9rem;
  }

  .auth-notice {
    padding: 0.65rem 0.75rem;
    background: rgba(110, 230, 104, 0.12);
    border: 1px solid rgba(110, 230, 104, 0.4);
    border-radius: var(--radius-sm);
    color: var(--accent);
    font-size: 0.9rem;
  }

  /* Empty -> collapsed, but the element STAYS in the DOM / a11y tree (never
     display:none or hidden) so this role=status/alert live region is registered
     before its first message lands -- otherwise some screen readers swallow it. */
  .auth-error:empty,
  .auth-notice:empty {
    margin: 0;
    padding: 0;
    border-width: 0;
  }

  .auth-back {
    margin-top: 2rem;
    text-align: right;
  }

  .auth-back a {
    color: var(--accent);
    font-family: var(--font-display);
    font-weight: 600;
  }

  .auth-back a:hover {
    color: var(--text);
  }

  /* Touch targets: bump the tappable link to >=44px on coarse pointers.
     The input/submit are already >=44px, so they are left as-is. */
  @media (pointer: coarse) {
    .auth-back a {
      display: inline-flex;
      align-items: center;
      min-height: 44px;
    }
  }
</style>
