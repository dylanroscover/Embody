---
import { env } from "cloudflare:workers";
import {
  SUBMIT_CATEGORIES,
  SUBMIT_DIFFICULTIES,
  SUBMIT_REQUIRES
} from "@embody/contracts";
import Base from "../layouts/Base.astro";

export const prerender = false;

// Real session gate: unauthenticated visitors go to sign-in and bounce back.
const user = Astro.locals.user;
if (!user) {
  return Astro.redirect("/signin?next=/submit");
}

const isDev = String(env.ENVIRONMENT ?? "production") !== "production";

// PUBLIC_TURNSTILE_SITE_KEY is the Cloudflare Turnstile *site* key (safe to ship
// to the browser; the matching TURNSTILE_SECRET stays server-side). When it is
// absent -- or we are in dev -- we skip mounting the real widget and fall back
// to the dev-bypass token so the form keeps working without a configured key.
// The server verifier (verifyTurnstile) still fails closed in production, so an
// unset key there means submissions are rejected rather than silently waved in.
const turnstileSiteKey = String(
  import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? ""
).trim();
const useTurnstileWidget = !isDev && Boolean(turnstileSiteKey);

const difficultyOptions = SUBMIT_DIFFICULTIES;
const categoryOptions = SUBMIT_CATEGORIES;
const requiresOptions = SUBMIT_REQUIRES;
---

<Base
  title="Submit a Specimen - embody.tools"
  description="Share a transparent TouchDesigner Specimen with the Collection."
>
  <section class="page-section submit">
    <div class="submit-head">
      <p class="eyebrow">Submit</p>
      <p class="submit-who">
        signed in as <a href={`/u/${user.handle}`}>{user.handle}</a>
        <button type="button" class="submit-signout" data-signout>sign out</button>
      </p>
    </div>
    <h1>share a specimen</h1>
    <p class="lede">
      Paste a TDN network to share it with the Collection. Every submission is
      scanned for capability surfaces before it goes live. This form is a working
      scaffold of the submission pipeline.
    </p>

    <p class="submit-status" data-submit-status hidden role="status"></p>

    <form class="submit-form" data-submit-form novalidate>
      <label class="submit-field">
        <span>title</span>
        <input type="text" name="title" required maxlength="160" placeholder="Feedback Bloom" />
      </label>
      <label class="submit-field">
        <span>description</span>
        <textarea name="description" rows="3" maxlength="4000" placeholder="What it does and how to read it."></textarea>
      </label>
      <label class="submit-field">
        <span>tags <em>(comma separated)</em></span>
        <input type="text" name="tags" placeholder="feedback, generative, TOP" />
      </label>
      <label class="submit-field">
        <span>difficulty</span>
        <select name="difficulty" class="submit-select">
          {difficultyOptions.map((value) => (
            <option value={value} selected={value === "intermediate"}>{value}</option>
          ))}
        </select>
      </label>
      <label class="submit-field">
        <span>category</span>
        <select name="category" class="submit-select">
          {categoryOptions.map((value) => (
            <option value={value} selected={value === "generative"}>{value}</option>
          ))}
        </select>
      </label>
      <label class="submit-field">
        <span>requires</span>
        <select name="requires" class="submit-select">
          {requiresOptions.map((value) => (
            <option value={value} selected={value === "none"}>{value}</option>
          ))}
        </select>
      </label>
      <label class="submit-field">
        <span>license</span>
        <input type="text" name="license" value="CC-BY-4.0" maxlength="80" />
      </label>
      <label class="submit-field">
        <span>TDN (YAML)</span>
        <textarea name="tdn" rows="10" required placeholder={'format: tdn\nversion: \'2.0\'\nname: my_network\ntype: baseCOMP\noperators: []'} class="submit-tdn"></textarea>
      </label>
      {useTurnstileWidget && (
        <div class="submit-field submit-turnstile">
          <span>verification</span>
          <div class="cf-turnstile" data-sitekey={turnstileSiteKey} data-turnstile></div>
        </div>
      )}
      <button type="submit" class="btn btn--primary submit-go" data-submit-go>
        submit specimen
      </button>
    </form>
  </section>
</Base>

{useTurnstileWidget && (
  <script
    is:inline
    src="https://challenges.cloudflare.com/turnstile/v0/api.js"
    async
    defer
  ></script>
)}

<script define:vars={{ isDev, useTurnstileWidget }}>
  const form = document.querySelector("[data-submit-form]");
  const statusBox = document.querySelector("[data-submit-status]");
  const goBtn = document.querySelector("[data-submit-go]");
  const signoutBtn = document.querySelector("[data-signout]");

  // The Cloudflare Turnstile API object is injected onto window by the api.js
  // loader (only rendered when the widget is mounted). This is a define:vars
  // (inline, untransformed) script, so it must be plain JS -- no TS casts; read
  // the global via bracket access. It may be undefined before the loader runs.
  function getTurnstile() {
    return window["turnstile"];
  }

  function setStatus(message, kind) {
    if (!statusBox) return;
    statusBox.textContent = message;
    statusBox.dataset.kind = kind;
    statusBox.hidden = false;
  }

  // NOTE: sign-out lives in a SEPARATE bundled <script> below. A `define:vars`
  // script is emitted inline and untransformed, so `import("../lib/authClient")`
  // here would not be bundled -- the browser would fetch the literal path and
  // 404, silently breaking sign-out. The bundled script gets a real asset URL.

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();
    if (!goBtn) return;
    const data = new FormData(form);

    const title = String(data.get("title") || "").trim();
    const tdnRaw = String(data.get("tdn") || "").trim();
    if (!title) {
      setStatus("A title is required.", "error");
      return;
    }
    if (!tdnRaw) {
      setStatus("Paste a TDN network.", "error");
      return;
    }
    // TDN is YAML (a JSON superset). This inline define:vars script can't bundle
    // the yaml parser, so format validation happens server-side (it returns a
    // clear error); the client only checks that something was pasted.

    const tags = String(data.get("tags") || "")
      .split(",")
      .map((t) => t.trim())
      .filter(Boolean);

    // Resolve the Turnstile token. When the real widget is mounted
    // (useTurnstileWidget: production with a PUBLIC_TURNSTILE_SITE_KEY), read its
    // response token; the server then verifies it with siteverify. Otherwise
    // (dev, or no site key configured) fall back to the dev-bypass token so the
    // form keeps working -- the server verifier only honors that token outside
    // production and fails closed in prod, so this never weakens the live gate.
    let turnstileToken = "dev-bypass";
    if (useTurnstileWidget) {
      const ts = getTurnstile();
      const fromApi = ts && typeof ts.getResponse === "function" ? ts.getResponse() : "";
      const fromField = String(data.get("cf-turnstile-response") || "");
      turnstileToken = String(fromApi || fromField || "");
      if (!turnstileToken) {
        setStatus("Please complete the verification challenge.", "error");
        return;
      }
    }


    const payload = {
      title,
      description: String(data.get("description") || "").trim(),
      tags,
      license: String(data.get("license") || "CC-BY-4.0").trim() || "CC-BY-4.0",
      difficulty: String(data.get("difficulty") || "intermediate"),
      category: String(data.get("category") || ""),
      requires: String(data.get("requires") || "none"),
      tdn: tdnRaw,
      turnstileToken
    };

    goBtn.disabled = true;
    const original = goBtn.textContent;
    goBtn.textContent = "submitting...";
    setStatus("Scanning and submitting...", "pending");

    try {
      const res = await fetch("/api/specimens", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload)
      });
      const body = await res.json().catch(() => ({}));
      if (res.status === 401) {
        setStatus("Your session expired. Redirecting to sign in...", "error");
        window.location.assign("/signin?next=/submit");
        return;
      }
      if (!res.ok) {
        setStatus(body.detail || body.error || `Submission failed (${res.status}).`, "error");
        return;
      }
      setStatus("Submitted. Redirecting to your specimen...", "ok");
      window.location.assign(`/c/${body.slug}`);
    } catch (err) {
      console.error("submit failed", err);
      setStatus("Something went wrong. Please try again.", "error");
    } finally {
      goBtn.disabled = false;
      goBtn.textContent = original;
      // Turnstile tokens are single-use; reset the widget so a retry gets a
      // fresh challenge token instead of replaying a now-spent one.
      if (useTurnstileWidget) {
        const ts = getTurnstile();
        if (ts && typeof ts.reset === "function") ts.reset();
      }
    }
  });
</script>

<!-- Sign-out: a plain (non-define:vars) script so Astro/Vite bundles the
     authClient import into a real asset URL. Inlining it above would 404. -->
<script>
  import { authClient } from "../lib/authClient";

  document.querySelector("[data-signout]")?.addEventListener("click", async () => {
    try {
      await authClient.signOut();
    } finally {
      // Navigate home regardless -- a failed sign-out call must not strand the
      // user on a page whose nav still says "account".
      window.location.assign("/");
    }
  });
</script>

<style>
  .submit {
    padding-bottom: 56px;
  }

  .submit-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .submit-who {
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  .submit-who a {
    color: var(--accent);
    font-weight: 600;
  }

  .submit-signout {
    margin-left: 0.75rem;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    color: var(--text-muted);
    padding: 0.25rem 0.6rem;
    font-size: 0.8rem;
    cursor: pointer;
  }

  .submit-signout:hover {
    color: var(--text);
    border-color: var(--accent);
  }

  .submit-form {
    margin-top: 2rem;
    max-width: 42rem;
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }

  .submit-field {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .submit-field > span {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .submit-field > span em {
    text-transform: none;
    letter-spacing: 0;
    color: var(--text-faint);
    font-style: normal;
  }

  .submit-field input,
  .submit-field textarea,
  .submit-field select {
    padding: 0.65rem 0.75rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    color: var(--text);
    font-size: 1rem;
  }

  .submit-turnstile .cf-turnstile {
    margin-top: 0.25rem;
  }

  .submit-tdn {
    font-family: var(--font-mono);
    font-size: 0.85rem;
  }

  .submit-field input:focus,
  .submit-field textarea:focus,
  .submit-field select:focus {
    outline: 2px solid var(--accent);
    outline-offset: 1px;
    border-color: var(--accent);
  }

  .submit-go {
    align-self: flex-start;
  }

  .submit-status {
    margin-top: 1.25rem;
    padding: 0.65rem 0.75rem;
    border-radius: var(--radius-sm);
    font-size: 0.9rem;
    border: 1px solid var(--border);
  }

  .submit-status[data-kind="error"] {
    background: rgba(220, 80, 80, 0.12);
    border-color: rgba(220, 80, 80, 0.4);
    color: #ff9b9b;
  }

  .submit-status[data-kind="ok"] {
    background: rgba(110, 230, 104, 0.12);
    border-color: rgba(110, 230, 104, 0.4);
    color: var(--accent);
  }

  .submit-back {
    margin-top: 2rem;
  }

  .submit-back a {
    color: var(--accent);
    font-family: var(--font-display);
    font-weight: 600;
  }

  .submit-back a:hover {
    color: var(--text);
  }
</style>
