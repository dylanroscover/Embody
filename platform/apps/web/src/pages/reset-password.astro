---
import Base from "../layouts/Base.astro";

export const prerender = false;

// Token arrives as ?token=... (Better Auth redirects the email link here via
// the request-password-reset redirectTo). An invalid/expired token redirects
// with ?error=INVALID_TOKEN instead -- surface that case to the user.
const token = Astro.url.searchParams.get("token") ?? "";
const tokenError = Astro.url.searchParams.get("error") ?? "";
const hasToken = token.length > 0 && !tokenError;
---

<Base
  title="reset password - embody.tools"
  description="choose a new password for your embody.tools account."
>
  <section class="page-section auth">
    <p class="eyebrow">account</p>
    <h1 id="auth-heading">reset password</h1>
    <p class="lede">
      choose a new password for your account. use at least 8 characters.
    </p>

    <div class="auth-card" data-token={token}>
      <p class="auth-error" data-auth-error role="alert"></p>
      <p class="auth-notice" data-auth-notice role="status"></p>

      {hasToken ? (
        <form class="auth-form" data-reset-form novalidate>
          <label class="auth-field">
            <span>new password</span>
            <input type="password" name="password" autocomplete="new-password" required minlength="8" placeholder="at least 8 characters" />
          </label>
          <label class="auth-field">
            <span>confirm password</span>
            <input type="password" name="confirm" autocomplete="new-password" required minlength="8" placeholder="re-enter your new password" />
          </label>
          <button type="submit" class="btn btn--primary auth-submit" data-reset-submit>
            set new password
          </button>
        </form>
      ) : (
        <p class="auth-invalid">
          this reset link is invalid or has expired.
          <a href="/forgot-password">request a new one</a>.
        </p>
      )}
    </div>

    <p class="auth-back">
      <a href="/signin">back to sign in</a>
    </p>
  </section>
</Base>

<script>
  import { authClient } from "../lib/authClient";

  const card = document.querySelector(".auth-card") as HTMLDivElement | null;
  const form = document.querySelector("[data-reset-form]") as HTMLFormElement | null;
  const errorBox = document.querySelector("[data-auth-error]") as HTMLParagraphElement | null;
  const noticeBox = document.querySelector("[data-auth-notice]") as HTMLParagraphElement | null;
  const submitBtn = document.querySelector("[data-reset-submit]") as HTMLButtonElement | null;

  const token = card?.dataset.token || "";

  function showError(message: string) {
    if (!errorBox) return;
    errorBox.textContent = message;
  }

  function clearError() {
    if (!errorBox) return;
    errorBox.textContent = "";
  }

  function showNotice(message: string) {
    if (!noticeBox) return;
    noticeBox.textContent = message;
  }

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();
    clearError();
    if (!submitBtn) return;

    const data = new FormData(form);
    const password = String(data.get("password") || "");
    const confirm = String(data.get("confirm") || "");

    if (password.length < 8) {
      showError("password must be at least 8 characters.");
      return;
    }
    if (password !== confirm) {
      showError("passwords do not match.");
      return;
    }
    if (!token) {
      showError("this reset link is invalid or has expired.");
      return;
    }

    submitBtn.disabled = true;
    const original = submitBtn.textContent;
    submitBtn.textContent = "saving...";

    try {
      const res = await authClient.resetPassword({ newPassword: password, token });
      if (res.error) {
        showError(res.error.message || "could not reset the password. the link may have expired.");
        return;
      }
      form.hidden = true;
      showNotice("your password has been reset. redirecting to sign in...");
      setTimeout(() => window.location.assign("/signin"), 1500);
    } catch (err) {
      console.error("password reset failed", err);
      showError("something went wrong. please try again.");
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = original;
    }
  });
</script>

<style>
  .auth {
    padding-bottom: 56px;
  }

  .auth-card {
    margin-top: 2rem;
    max-width: 30rem;
    padding: 1.75rem;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }

  /* Center the single card on wide screens so it doesn't strand in the left
     third of the viewport (signin uses a two-column layout; this page is one
     card, so just center it). */
  @media (min-width: 861px) {
    .auth-card {
      margin-inline: auto;
    }
  }

  .auth-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .auth-field {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .auth-field > span {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .auth-field input {
    padding: 0.65rem 0.75rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    color: var(--text);
    font-size: 1rem;
  }

  .auth-field input:focus {
    outline: 2px solid var(--accent);
    outline-offset: 1px;
    border-color: var(--accent);
  }

  .auth-submit {
    margin-top: 0.25rem;
    width: 100%;
    justify-content: center;
  }

  .auth-error {
    margin-bottom: 1rem;
    padding: 0.65rem 0.75rem;
    background: rgba(220, 80, 80, 0.12);
    border: 1px solid rgba(220, 80, 80, 0.4);
    border-radius: var(--radius-sm);
    color: #ff9b9b;
    font-size: 0.9rem;
  }

  .auth-notice {
    padding: 0.65rem 0.75rem;
    background: rgba(110, 230, 104, 0.12);
    border: 1px solid rgba(110, 230, 104, 0.4);
    border-radius: var(--radius-sm);
    color: var(--accent);
    font-size: 0.9rem;
  }

  /* Empty -> collapsed, but the element STAYS in the DOM / a11y tree (never
     display:none or hidden) so this role=status/alert live region is registered
     before its first message lands -- otherwise some screen readers swallow it. */
  .auth-error:empty,
  .auth-notice:empty {
    margin: 0;
    padding: 0;
    border-width: 0;
  }

  .auth-invalid {
    font-size: 0.95rem;
    color: var(--text-muted);
  }

  .auth-invalid a {
    color: var(--accent);
    font-weight: 600;
  }

  .auth-back {
    margin-top: 2rem;
  }

  .auth-back a {
    color: var(--accent);
    font-family: var(--font-display);
    font-weight: 600;
  }

  .auth-back a:hover {
    color: var(--text);
  }

  /* Touch targets: bump the tappable link to >=44px on coarse pointers.
     The inputs/submit are already >=44px, so they are left as-is. */
  @media (pointer: coarse) {
    .auth-back a {
      display: inline-flex;
      align-items: center;
      min-height: 44px;
    }
  }
</style>
