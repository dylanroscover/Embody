---
import CopyButton from "../components/CopyButton.astro";
import Base from "../layouts/Base.astro";
import specimens from "../fixtures/specimens.json";
---

<Base
  title="The Field Guide - embody.tools"
  description="Copy-ready prompts that build transparent TouchDesigner networks through your AI agent."
>
  <section class="page-section guide-hero">
    <p class="eyebrow">The Field Guide</p>
    <h1>describe the result, get the network</h1>
    <p class="lede">
      Each row pairs a result you might want with a ready-to-paste prompt for an AI
      agent (Claude, Cursor, etc.) connected to Embody inside TouchDesigner. Find the
      row that matches what you are after, copy the Say this prompt to your agent, and
      it builds the matching Specimen: a real, fully transparent TouchDesigner network
      you own. Then use the Then evolve prompt to push it further in your own project.
    </p>
    <div class="guide-steps">
      <div class="guide-step pillar">
        <span class="guide-step__num">1</span>
        <strong>find the result</strong>
        <p>Scan the Want column for the look or motion you are trying to build.</p>
      </div>
      <div class="guide-step pillar">
        <span class="guide-step__num">2</span>
        <strong>paste the prompt</strong>
        <p>Copy Say this into your connected agent and it builds the Specimen network.</p>
      </div>
      <div class="guide-step pillar">
        <span class="guide-step__num">3</span>
        <strong>evolve it</strong>
        <p>Once the network exists, paste Then evolve to take it in your own direction.</p>
      </div>
    </div>
  </section>

  <section class="page-section tight guide-list" aria-label="Field Guide prompts">
    <div class="guide-grid">
      {specimens.map((specimen) => (
        <article class="guide-card pillar">
          <div class="guide-card__want">
            <p class="eyebrow">Want</p>
            <h2>{specimen.want}</h2>
          </div>

          <div class="guide-card__section">
            <span class="guide-label">Say this</span>
            <div class="copy-shell">
              <p class="copy-shell__text">{specimen.prompt}</p>
              <CopyButton text={specimen.prompt} ariaLabel={`Copy prompt for ${specimen.name}`} />
            </div>
          </div>

          <div class="guide-card__section">
            <span class="guide-label">Specimen</span>
            <a class="specimen-link" href={`/c/${specimen.slug}`}>{specimen.name}</a>
          </div>

          <div class="guide-card__section">
            <span class="guide-label">Then evolve</span>
            <div class="copy-shell">
              <p class="copy-shell__text">{specimen.evolve}</p>
              <CopyButton text={specimen.evolve} ariaLabel={`Copy evolution prompt for ${specimen.name}`} />
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>
</Base>

<style>
  .guide-hero {
    padding-bottom: 56px;
  }

  .guide-steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-top: 2rem;
  }

  .guide-step {
    padding: 1.2rem 1.25rem;
  }

  .guide-step__num,
  .guide-label {
    display: block;
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    line-height: 1;
    text-transform: uppercase;
  }

  .guide-step strong {
    display: block;
    margin: 0.75rem 0 0.35rem;
    color: var(--text);
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 600;
    letter-spacing: -0.015em;
  }

  .guide-step p {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.94rem;
    line-height: 1.5;
  }

  .guide-grid {
    display: grid;
    gap: 1rem;
  }

  .guide-card {
    display: grid;
    grid-template-columns: minmax(180px, 0.72fr) minmax(280px, 1.2fr) minmax(150px, 0.54fr) minmax(260px, 1fr);
    gap: 1rem;
    align-items: stretch;
    padding: 1.2rem;
  }

  .guide-card__want h2 {
    margin: 0;
    font-size: clamp(1.35rem, 2.6vw, 2rem);
    line-height: 1.08;
  }

  .guide-card .eyebrow {
    margin-bottom: 0.75rem;
  }

  .guide-card__section {
    display: grid;
    align-content: start;
    gap: 0.75rem;
    min-width: 0;
  }

  .specimen-link {
    color: var(--text);
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 600;
    letter-spacing: -0.015em;
  }

  .specimen-link:hover {
    color: var(--accent);
  }

  @media (max-width: 980px) {
    .guide-steps,
    .guide-card {
      grid-template-columns: 1fr;
    }
  }
</style>
