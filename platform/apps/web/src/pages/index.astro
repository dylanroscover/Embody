---
import { TdnViewer } from "@embody/tdn-viewer";
import Base from "../layouts/Base.astro";
import specimens from "../fixtures/specimens.json";
import { sampleTdn } from "../fixtures/sample-tdn";
import { specimenThumbnail } from "../lib/specimenThumb";

const featured = specimens.slice(0, 3);
---

<Base
  title="embody.tools - TouchDesigner network specimens"
  description="A fixture-only design review scaffold for the transparent TouchDesigner network Collection."
>
  <section class="hero">
    <div class="hero-graph" aria-hidden="true">
      <TdnViewer tdn={sampleTdn} height="100%" client:load />
    </div>
    <div class="hero-copy">
      <p class="eyebrow">embody.tools</p>
      <h1>speak a TouchDesigner network into being</h1>
      <p class="lede">
        Browse a Specimen, inspect the TDN, copy the network, and evolve it in your project.
        The Collection is built on transparent files instead of opaque recipes.
      </p>
      <div class="actions">
        <a class="btn btn--primary" href="/specimens">Enter the Collection</a>
        <a class="btn btn--outline" href="/specimens/field-guide">Read the Field Guide</a>
      </div>
    </div>
  </section>

  <section class="page-section intro-band">
    <div>
      <p class="eyebrow">The transparent TDN moat</p>
      <h2>every Specimen shows its form</h2>
    </div>
    <p class="lede">
      A Specimen is a tested, instantiable TDN network. The same file powers the node-graph
      preview, the raw JSON reveal, the clipboard payload, and the future platform API.
    </p>
  </section>

  <section class="page-section tight">
    <div class="section-heading">
      <p class="eyebrow">First fixtures</p>
      <h2>signals from the Collection</h2>
    </div>
    <div class="card-grid">
      {featured.map((specimen) => (
        <a class="specimen-card pillar" href={`/s/${specimen.slug}`}>
          <div class="thumb">
            <img
              src={specimenThumbnail(specimen)}
              loading="lazy"
              alt={`${specimen.name} node preview placeholder`}
            />
          </div>
          <div class="specimen-card__body">
            <div class="badge-row">
              <span class="badge">{specimen.category}</span>
              <span class:list={["badge", specimen.requires === "none" ? "stock" : "needs"]}>
                {specimen.requires === "none" ? "stock TD" : `needs ${specimen.requires}`}
              </span>
            </div>
            <h3>{specimen.name}</h3>
            <p>{specimen.description}</p>
          </div>
        </a>
      ))}
    </div>
  </section>
</Base>

<style>
  .hero {
    position: relative;
    display: grid;
    min-height: min(720px, calc(100svh - 128px));
    overflow: hidden;
    align-items: end;
    padding: clamp(8rem, 14vw, 11rem) max(var(--gutter), calc((100vw - var(--content-max)) / 2 + var(--gutter))) clamp(2.5rem, 5vw, 4rem);
  }

  .hero-graph {
    position: absolute;
    inset: -80px -130px -40px 18%;
    z-index: 0;
    opacity: 0.38;
    filter: blur(0.6px);
    pointer-events: none;
  }

  .hero-graph :global(.tdn-viewer) {
    height: 100%;
    border: 0;
    border-radius: 0;
    background-color: transparent;
  }

  .hero::before {
    position: absolute;
    inset: 0;
    z-index: 1;
    content: "";
    background: linear-gradient(102deg, var(--bg) 26%, rgba(24, 30, 30, 0.5) 52%, transparent 80%);
    pointer-events: none;
  }

  .hero::after {
    position: absolute;
    inset: auto 0 0;
    height: 46%;
    z-index: 1;
    content: "";
    background: linear-gradient(transparent, var(--bg));
    pointer-events: none;
  }

  .hero-copy {
    position: relative;
    z-index: 2;
    max-width: 820px;
  }

  .hero-copy h1 {
    text-shadow: 0 2px 30px rgba(8, 12, 8, 0.6);
  }

  .intro-band {
    display: grid;
    grid-template-columns: minmax(240px, 0.8fr) minmax(280px, 1fr);
    gap: 34px;
    max-width: none;
    border-top: 1px solid var(--border-faint);
    border-bottom: 1px solid var(--border-faint);
    background: rgba(40, 48, 40, 0.24);
    padding-top: clamp(2.5rem, 4.5vw, 3.75rem);
    padding-bottom: clamp(2.5rem, 4.5vw, 3.75rem);
    padding-right: max(var(--gutter), calc((100vw - var(--content-max)) / 2 + var(--gutter)));
    padding-left: max(var(--gutter), calc((100vw - var(--content-max)) / 2 + var(--gutter)));
  }

  .section-heading {
    margin-bottom: 28px;
  }

  @media (max-width: 760px) {
    .hero {
      min-height: max(520px, calc(100svh - 180px));
      padding-top: 72px;
    }

    .hero-graph {
      inset: -60px -220px 90px 0;
      opacity: 0.28;
    }

    .intro-band {
      grid-template-columns: 1fr;
    }
  }
</style>
