{
  "name": "embody-tools",
  "private": true,
  "type": "module",
  "description": "embody.tools - the community platform for TouchDesigner networks (Embody v6)",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "npm run --workspaces --if-present build",
